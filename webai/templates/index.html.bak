                      <div class="w-10 h-10 bg-surface-100 dark:bg-surface-800 rounded-xl"></div>
                      <div class="flex-1 space-y-2">
                        <div class="h-2 bg-surface-100 dark:bg-surface-800 rounded w-1/2"></div>
                        <div class="h-2 bg-surface-50 dark:bg-surface-800 rounded w-1/4"></div>
                      </div>
