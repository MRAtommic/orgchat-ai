                  <p class="text-[10px] text-emerald-500 font-bold mt-2 flex items-center gap-1"><i data-lucide="trending-up" class="w-3 h-3"></i> +12 สัปดาห์นี้</p>
                </div>
                
                <div class="glass p-5 rounded-3xl border border-surface-200/50 dark:border-surface-700/50 relative overflow-hidden group hover:-translate-y-1 transition-all duration-300">
                  <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <i data-lucide="message-square" class="w-16 h-16 text-blue-500"></i>
                  </div>
                  <div class="w-8 h-8 bg-blue-500/10 text-blue-500 rounded-lg flex items-center justify-center mb-3">
                    <i data-lucide="message-square" class="w-4 h-4"></i>
                  </div>
                  <p class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1">ข้อความวันนี้</p>
