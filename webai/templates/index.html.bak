              </div>
              <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-sm hover:shadow-md transition-all">
                <div class="flex items-start justify-between mb-4">
                  <div class="p-2 bg-rose-100 dark:bg-rose-900/30 text-rose-600 rounded-xl"><i data-lucide="check-circle" class="w-5 h-5"></i></div>
                  <span class="text-[11px] font-bold text-rose-500">ประสิทธิภาพ</span>
                </div>
                <div class="text-2xl font-black" id="dashStatCompletion">0%</div>
                <div class="text-[11px] font-bold tracking-wide text-surface-400 mt-1">งานเสร็จแล้ว</div>
              </div>
            </div>
            
            <!-- 📁 Drive Insights [NEW] -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
              <!-- Drive Total Files -->
              <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-sm hover:shadow-md transition-all group">
                <div class="flex items-start justify-between mb-4">
                  <div class="p-2 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 rounded-xl group-hover:scale-110 transition-transform">
