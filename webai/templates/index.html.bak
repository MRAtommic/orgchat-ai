          </header>
          
          <div class="flex-1 overflow-y-auto custom-scrollbar p-6 md:p-8 relative z-0">
            <div class="max-w-6xl mx-auto space-y-8">
              
              <!-- Quick Stats Grid -->
              <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="glass p-5 rounded-3xl border border-surface-200/50 dark:border-surface-700/50 relative overflow-hidden group hover:-translate-y-1 transition-all duration-300">
                  <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
