          </div>
        </section>

        <!-- AI Summary View -->
        <section id="view-summary"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-500">
          <header
            class="h-auto md:h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 py-4 md:py-0 bg-white dark:bg-surface-900 sticky top-0 z-10 w-full gap-4">
            <h2 class="font-black text-sm tracking-tight text-brand-600 uppercase">AI Knowledge Summary</h2>

            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 flex-1 md:justify-end max-w-2xl">
              <select id="summaryCategorySelect"
                class="bg-surface-50 dark:bg-surface-800 border-2 border-surface-100 dark:border-surface-700 rounded-xl px-3 py-1.5 text-[10px] font-bold outline-none focus:border-brand-600 transition-all">
                <option value="all">📚 ทุกหมวดหมู่</option>
              </select>

              <div class="relative flex-1">
                <i data-lucide="target" class="absolute left-3 top-1/2 -translate-y-1/2 w-3 h-3 text-surface-400"></i>
                <input type="text" id="summaryFocusInput" placeholder="เน้นหัวข้อพิเศษ (เช่น สวัสดิการ, วันลา)..."
                  class="w-full pl-8 pr-4 py-1.5 bg-surface-50 dark:bg-surface-800 border-2 border-surface-100 dark:border-surface-700 rounded-xl text-[10px] font-bold outline-none focus:border-brand-600 transition-all">
              </div>

              <button id="generateGlobalSummaryBtn"
                class="bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-lg flex items-center justify-center gap-2 whitespace-nowrap">
                <i data-lucide="sparkles" class="w-3.5 h-3.5"></i> สรุปข้อมูล
              </button>
            </div>
          </header>

          <div
            class="flex-1 overflow-y-auto custom-scrollbar p-6 bg-surface-50/30 dark:bg-surface-950 w-full max-w-7xl space-y-8">
            <!-- Empty State -->
            <div id="summaryEmpty" class="flex flex-col items-center justify-center py-24 text-center space-y-6">
              <div
                class="w-24 h-24 rounded-3xl bg-surface-100 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 flex items-center justify-center text-surface-300">
                <i data-lucide="scroll-text" class="w-12 h-12"></i>
              </div>
              <div>
                <h3 class="text-xl font-black mb-2 leading-tight">ยังไม่มีการสร้างสรุป</h3>
                <p class="text-surface-400 text-xs font-medium max-w-sm">คลิกปุ่ม "สรุปข้อมูลทั้งหมด" เพื่อให้ AI
                  ประมวลผลและสร้างบทสรุปของเอกสารทั้งหมดในคลังความรู้ให้คุณ</p>
              </div>
            </div>

            <!-- Loading State -->
            <div id="summaryLoading"
              class="hidden flex flex-col items-center justify-center py-24 text-center space-y-6">
              <div class="relative">
                <div
                  class="w-20 h-20 rounded-full border-4 border-brand-100 dark:border-brand-900/30 border-t-brand-600 animate-spin">
                </div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <i data-lucide="sparkles" class="w-6 h-6 text-brand-600 animate-pulse"></i>
                </div>
              </div>
              <div class="space-y-2">
                <h3 class="text-lg font-black leading-tight">AI กำลังสรุปข้อมูล...</h3>
                <p class="text-surface-400 text-[10px] uppercase font-bold tracking-widest">ใช้เวลาประมาณ 15-30 วินาที
                  ขึ้นอยู่กับจำนวนไฟล์</p>
              </div>
            </div>

            <!-- Result Content -->
            <div id="summaryContentArea"
              class="hidden space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
              <div
                class="glass p-8 rounded-[40px] border border-surface-100 dark:border-surface-800 shadow-xl relative overflow-hidden bg-white dark:bg-surface-900">
                <div class="absolute top-4 right-4 z-20 flex gap-2">
                  <button id="copySummaryBtn"
                    class="px-3 py-1.5 bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 rounded-xl text-[10px] font-bold transition-all flex items-center gap-2">
                    <i data-lucide="copy" class="w-3 h-3"></i> คัดลอก
                  </button>
                </div>
                <div class="absolute top-0 right-0 p-12 opacity-[0.03] pointer-events-none">
                  <i data-lucide="brain-circuit" class="w-64 h-64"></i>
                </div>
                <div class="relative z-10 prose dark:prose-invert prose-brand max-w-none prose-sm leading-relaxed"
                  id="summaryOutput">
                  <!-- AI Content Here -->
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Found Keywords -->
                <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800">
                  <h4 class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-4">
                    คีย์เวิร์ดสำคัญที่พบ</h4>
                  <ul class="flex flex-wrap gap-2" id="summaryKeywords"></ul>
                </div>

                <!-- Source References -->
                <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800">
                  <h4 class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-4">อ้างอิงจากเอกสาร
                  </h4>
                  <div id="summaryRefs" class="space-y-2"></div>
                </div>
              </div>
            </div>
