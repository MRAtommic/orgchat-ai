              <!-- LINE Group Enterprise Mapping Card -->
              <div class="glass bg-white/40 dark:bg-surface-900/40 border border-surface-200/50 dark:border-surface-700/50 rounded-3xl p-6 shadow-sm">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                  <div class="flex items-center gap-2.5">
                    <div class="w-10 h-10 bg-[#00B900]/10 rounded-2xl flex items-center justify-center text-[#00B900]">
                      <i data-lucide="network" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <h3 class="font-black text-sm uppercase tracking-widest text-surface-900 dark:text-white">เชื่อมต่อแชทกลุ่ม LINE องค์กร (B2B Group Mapping)</h3>
                      <p class="text-[10px] text-surface-450 dark:text-surface-400 font-bold uppercase tracking-widest mt-0.5">เชื่อมแชทกลุ่ม LINE เข้ากับระบบจัดเก็บและวิเคราะห์บัญชีอัตโนมัติ</p>
                    </div>
                  </div>
                  <button onclick="refreshGroupMappings()" class="px-3 py-1.5 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-[#00B900]/50 hover:text-[#00B900] rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-sm flex items-center gap-1.5">
                    <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i> โหลดรายการใหม่
                  </button>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                  <!-- Form side -->
                  <div class="lg:col-span-1 space-y-4 pr-0 lg:pr-6 border-r-0 lg:border-r border-surface-200/50 dark:border-surface-700/50">
                    <h4 class="text-xs font-black uppercase tracking-widest text-[#00B900] mb-2 ml-1">➕ ผูกแชทกลุ่มใหม่</h4>
                    
                    <div class="space-y-3">
                      <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1.5 ml-1">LINE Group ID</label>
                        <input type="text" id="lineGroupBindId" class="w-full bg-white dark:bg-surface-950 border border-surface-200 dark:border-surface-700 rounded-xl p-3 text-xs focus:ring-2 focus:ring-[#00B900]/50 focus:border-[#00B900] transition-all outline-none placeholder-surface-300 dark:placeholder-surface-650" placeholder="ตัวอย่างเช่น Cdf123abc...">
                        <p class="text-[9px] text-surface-400 font-medium mt-1 leading-normal pl-1">พิมพ์คำว่า <strong class="text-brand-600">รหัสกลุ่ม</strong> ในห้องแชทกลุ่ม LINE เพื่อเรียกดูไอดีกลุ่ม</p>
                      </div>

                      <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1.5 ml-1">ชื่อกลุ่ม LINE (สำหรับแสดงในระบบ)</label>
                        <input type="text" id="lineGroupBindName" class="w-full bg-white dark:bg-surface-950 border border-surface-200 dark:border-surface-700 rounded-xl p-3 text-xs focus:ring-2 focus:ring-[#00B900]/50 focus:border-[#00B900] transition-all outline-none placeholder-surface-300 dark:placeholder-surface-650" placeholder="ระบุชื่อเพื่อให้จำได้ง่าย เช่น บัญชี/การเงิน">
                      </div>

                      <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1.5 ml-1">โฟลเดอร์ปลายทาง (Folder Selection Bypass)</label>
                        <select id="lineGroupBindFolder" class="w-full bg-white dark:bg-surface-950 border border-surface-200 dark:border-surface-700 rounded-xl p-3 text-xs focus:ring-2 focus:ring-[#00B900]/50 focus:border-[#00B900] transition-all outline-none cursor-pointer text-surface-750 dark:text-surface-300">
                          <option value="">-- แสดงปุ่มเลือกโฟลเดอร์บน LINE --</option>
                        </select>
                        <p class="text-[9px] text-surface-400 font-medium mt-1 leading-normal pl-1">หากเลือกโฟลเดอร์ไว้ บอทจะนำเข้าโฟลเดอร์นี้โดยตรงในพื้นหลังทันทีโดยข้ามปุ่มตัวเลือก</p>
                      </div>

                      <button id="lineGroupBindBtn" onclick="submitGroupBinding()" class="w-full py-3 bg-[#00B900] hover:bg-[#009900] text-white rounded-xl text-xs font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2 shadow-lg shadow-[#00B900]/20 active:scale-98 mt-2">
                        <i data-lucide="link" class="w-4 h-4"></i> ผูกแชทกลุ่ม LINE
                      </button>
                    </div>
                  </div>

                  <!-- List side -->
                  <div class="lg:col-span-2 space-y-4">
                    <h4 class="text-xs font-black uppercase tracking-widest text-surface-400 mb-2 ml-1 flex items-center gap-2">
                      <i data-lucide="list" class="w-4 h-4"></i> รายการแชทกลุ่มที่ผูกไว้ในระบบ
                    </h4>

                    <div class="overflow-x-auto rounded-2xl border border-surface-200/50 dark:border-surface-700/50 bg-white/20 dark:bg-surface-950/20">
                      <table class="w-full text-left border-collapse text-xs">
                        <thead>
                          <tr class="bg-surface-100/50 dark:bg-surface-800/50 border-b border-surface-200/50 dark:border-surface-700/50 text-[10px] font-black uppercase tracking-widest text-surface-400">
                            <th class="p-3 pl-4">ชื่อกลุ่ม LINE</th>
                            <th class="p-3">Group ID (LINE)</th>
                            <th class="p-3">โฟลเดอร์จัดเก็บอัตโนมัติ</th>
                            <th class="p-3 text-center">จัดการ</th>
                          </tr>
                        </thead>
                        <tbody id="lineGroupMappingsList" class="divide-y divide-surface-100/50 dark:divide-surface-800/50">
                          <tr>
                            <td colspan="4" class="p-8 text-center text-surface-450 italic">
                              <i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto mb-2 opacity-50 text-[#00B900]"></i>
                              กำลังโหลดข้อมูลแชทกลุ่ม...
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>

              <script>
                // LINE Group mapping handlers
                async function refreshGroupMappings() {
                    const listBody = document.getElementById('lineGroupMappingsList');
                    if (!listBody) return;
                    
                    listBody.innerHTML = `
                      <tr>
                        <td colspan="4" class="p-8 text-center text-surface-450 italic">
                          <i data-lucide="loader-2" class="w-5 h-5 animate-spin mx-auto mb-2 opacity-50 text-[#00B900]"></i>
                          กำลังดึงข้อมูลแชทกลุ่ม...
                        </td>
                      </tr>
                    `;
                    
                    try {
                        const res = await fetch('/api/line/groups');
                        const data = await res.json();
                        
                        if (!data.ok) {
                            listBody.innerHTML = `
                              <tr>
                                <td colspan="4" class="p-8 text-center text-red-500 font-bold">
                                  ❌ ดึงข้อมูลล้มเหลว: ${data.error || 'Unknown error'}
                                </td>
                              </tr>
                            `;
                            return;
                        }
                        
                        const mappings = data.mappings || [];
                        if (mappings.length === 0) {
                            listBody.innerHTML = `
                              <tr>
                                <td colspan="4" class="p-12 text-center text-surface-400 font-medium">
                                  <i data-lucide="users" class="w-12 h-12 mx-auto mb-3 opacity-20 text-[#00B900]"></i>
                                  ยังไม่มีการเชื่อมต่อแชทกลุ่ม LINE เลยค่ะพี่ 
                                  <p class="text-[10px] text-surface-400 mt-1 uppercase font-black">พิมพ์ "รหัสกลุ่ม" ในกลุ่มแล้วนำมาผูกเพื่อเริ่มใช้งานได้เลยค่ะ!</p>
                                </td>
                              </tr>
                            `;
                            if (window.lucide) window.lucide.createIcons();
                            return;
                        }
                        
                        listBody.innerHTML = mappings.map(m => `
                          <tr class="hover:bg-surface-50/50 dark:hover:bg-surface-800/30 transition-all border-b border-surface-100/50 dark:border-surface-800/50">
                            <td class="p-3 pl-4 font-bold text-surface-900 dark:text-white">${escapeHtml(m.group_name || 'แชทกลุ่ม LINE')}</td>
                            <td class="p-3 font-mono text-[10px] select-all">${escapeHtml(m.group_id)}</td>
                            <td class="p-3">
                              ${m.default_folder_id ? `
                                <span class="px-2.5 py-1 bg-[#00B900]/10 text-[#00B900] text-[10px] font-bold rounded-lg border border-[#00B900]/20 flex items-center gap-1.5 w-max">
                                  <i data-lucide="folder" class="w-3.5 h-3.5"></i>
                                  ${escapeHtml(m.default_folder_name || 'โฟลเดอร์เริ่มต้น')}
                                </span>
                              ` : `
                                <span class="px-2.5 py-1 bg-surface-100 dark:bg-surface-800 text-surface-450 text-[10px] font-bold rounded-lg border border-surface-200 dark:border-surface-700 flex items-center gap-1.5 w-max">
                                  <i data-lucide="help-circle" class="w-3.5 h-3.5"></i>
                                  ถามผ่าน LINE ทุกครั้ง
                                </span>
                              `}
                            </td>
                            <td class="p-3 text-center">
                              <button onclick="unbindGroup('${m.group_id}')" class="p-2 bg-rose-50 hover:bg-rose-100 text-rose-600 dark:bg-rose-900/10 dark:hover:bg-rose-900/20 rounded-lg border border-rose-100 dark:border-rose-900/30 transition-all hover:scale-105 active:scale-95" title="ยกเลิกเชื่อมต่อ">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                              </button>
                            </td>
                          </tr>
                        `).join('');
                        
                        if (window.lucide) window.lucide.createIcons();
                    } catch (err) {
                        listBody.innerHTML = `
                          <tr>
                            <td colspan="4" class="p-8 text-center text-red-500 font-bold">
                              ❌ เกิดข้อผิดพลาดในการดึงข้อมูล: ${err.message}
                            </td>
                          </tr>
                        `;
                    }
                }

                async function loadGoogleFoldersForGroup() {
                    const select = document.getElementById('lineGroupBindFolder');
                    if (!select) return;
                    
                    try {
                        const res = await fetch('/api/google/folders');
                        const data = await res.json();
                        
                        if (data.ok) {
                            const folders = data.folders || [];
                            select.innerHTML = '<option value="">-- แสดงปุ่มเลือกโฟลเดอร์บน LINE --</option>' + 
                              folders.map(f => `<option value="${f.id}">${escapeHtml(f.name)}</option>`).join('');
                        }
                    } catch (err) {
                        console.error("Failed to load Google Drive folders for group mapping dropdown:", err);
                    }
                }

                async function submitGroupBinding() {
                    const groupIdInput = document.getElementById('lineGroupBindId');
                    const groupNameInput = document.getElementById('lineGroupBindName');
                    const folderSelect = document.getElementById('lineGroupBindFolder');
                    const btn = document.getElementById('lineGroupBindBtn');
                    
                    if (!groupIdInput || !groupNameInput || !folderSelect || !btn) return;
                    
                    const group_id = groupIdInput.value.trim();
                    const group_name = groupNameInput.value.trim();
                    
                    if (!group_id) {
                        toast('กรุณากรอก Group ID ของ LINE แชทกลุ่มด้วยนะคะพี่ 😊', 'warning');
                        return;
                    }
                    
                    const default_folder_id = folderSelect.value;
                    const default_folder_name = default_folder_id ? folderSelect.options[folderSelect.selectedIndex].text : '';
                    
                    btn.disabled = true;
                    const originalText = btn.innerHTML;
                    btn.innerHTML = `<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> กำลังบันทึกข้อมูล...`;
                    if (window.lucide) window.lucide.createIcons();
                    
                    try {
                        const res = await fetch('/api/line/groups/bind', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                group_id,
                                group_name,
                                default_folder_id,
                                default_folder_name
                            })
                        });
                        
                        const data = await res.json();
                        if (data.ok) {
                            toast('เชื่อมโยงแชทกลุ่ม LINE สำเร็จเรียบร้อยค่ะ ✨💖', 'success');
                            groupIdInput.value = '';
                            groupNameInput.value = '';
                            folderSelect.value = '';
                            refreshGroupMappings();
                        } else {
                            toast('ผูกบัญชีแชทกลุ่มไม่สำเร็จค่ะ: ' + (data.error || 'Unknown error'), 'error');
                        }
                    } catch (err) {
                        toast('เกิดข้อผิดพลาดในการบันทึกข้อมูล: ' + err.message, 'error');
                    } finally {
                        btn.disabled = false;
                        btn.innerHTML = originalText;
                        if (window.lucide) window.lucide.createIcons();
                    }
                }

                async function unbindGroup(groupId) {
                    if (!confirm('พี่แน่ใจนะคะว่าต้องการยกเลิกการผูกแชทกลุ่ม LINE นี้?')) return;
                    
                    try {
                        const res = await fetch(`/api/line/groups/unbind/${groupId}`, {
                            method: 'DELETE'
                        });
                        const data = await res.json();
                        
                        if (data.ok) {
                            toast('ยกเลิกการผูกแชทกลุ่มเรียบร้อยแล้วค่ะ ✨', 'success');
                            refreshGroupMappings();
                        } else {
                            toast('ยกเลิกไม่สำเร็จค่ะ: ' + (data.error || 'Unknown error'), 'error');
                        }
                    } catch (err) {
                        toast('เกิดข้อผิดพลาดในการทำงาน: ' + err.message, 'error');
                    }
                }

                // Escape HTML utility
                function escapeHtml(text) {
                    if (!text) return '';
                    return text
                        .replace(/&/g, "&amp;")
                        .replace(/</g, "&lt;")
                        .replace(/>/g, "&gt;")
                        .replace(/"/g, "&quot;")
                        .replace(/'/g, "&#039;");
                }

                // Intercept showView once line-manager is loaded
                if (typeof window.originalShowView === 'undefined') {
                    window.originalShowView = window.showView;
                    window.showView = function(viewId) {
                        if (window.originalShowView) window.originalShowView(viewId);
                        if (viewId === 'line-manager') {
                            refreshGroupMappings();
                            loadGoogleFoldersForGroup();
                        }
                    };
                }
              </script>

              <!-- Main Dashboard Area -->
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Left Col: Broadcast -->
                <div class="lg:col-span-2 space-y-6">
                  <div class="glass bg-white/40 dark:bg-surface-900/40 border border-surface-200/50 dark:border-surface-700/50 rounded-3xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-6">
                      <div class="flex items-center gap-2">
                        <i data-lucide="megaphone" class="w-5 h-5 text-orange-500"></i>
                        <h3 class="font-black text-sm uppercase tracking-widest text-surface-900 dark:text-white">บรอดแคสต์ข้อความ (Broadcast)</h3>
                      </div>
                      <span class="text-[10px] px-2 py-1 bg-orange-500/10 text-orange-600 rounded-lg font-bold">โควต้า: 1,000 ข้อความ</span>
                    </div>
                    
                    <div class="space-y-4">
                      <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-surface-400 mb-2 ml-1">ข้อความที่จะส่ง</label>
                        <textarea id="lineManagerBroadcastMsg" rows="4" class="w-full bg-white dark:bg-surface-950 border border-surface-200 dark:border-surface-700 rounded-2xl p-4 text-sm focus:ring-2 focus:ring-[#00B900]/50 focus:border-[#00B900] transition-all outline-none resize-none placeholder-surface-300 dark:placeholder-surface-600" placeholder="พิมพ์ข้อความโปรโมชั่น หรืออัปเดตข่าวสารที่นี่..."></textarea>
                      </div>
                      <div class="flex items-center gap-3">
                        <button class="px-4 py-2.5 bg-surface-100 hover:bg-surface-200 dark:bg-surface-800 dark:hover:bg-surface-700 text-surface-600 dark:text-surface-300 rounded-xl text-xs font-bold transition-all flex items-center gap-2">
                          <i data-lucide="image" class="w-4 h-4"></i> แนบรูปภาพ
                        </button>
                        <button id="lineManagerBroadcastBtn" onclick="window.sendLineBroadcast('lineManagerBroadcastMsg', 'lineManagerBroadcastBtn')" class="px-4 py-2.5 bg-[#00B900] hover:bg-[#009900] text-white rounded-xl text-xs font-black uppercase tracking-wider transition-all flex items-center gap-2 shadow-lg shadow-[#00B900]/20 ml-auto active:scale-95">
                          <i data-lucide="send" class="w-4 h-4"></i> ส่งบรอดแคสต์
                        </button>
                      </div>
                    </div>
                  </div>

                  <div class="glass bg-white/40 dark:bg-surface-900/40 border border-surface-200/50 dark:border-surface-700/50 rounded-3xl overflow-hidden shadow-sm">
                    <div class="p-6 border-b border-surface-200/50 dark:border-surface-700/50 flex items-center justify-between">
                      <div class="flex items-center gap-2">
                        <i data-lucide="history" class="w-5 h-5 text-brand-600"></i>
                        <h3 class="font-black text-sm uppercase tracking-widest text-surface-900 dark:text-white">ประวัติการส่งบรอดแคสต์</h3>
                      </div>
                    </div>
                    <div class="p-6 text-center text-surface-400 py-12">
                      <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 opacity-20"></i>
                      <p class="text-xs font-bold uppercase tracking-widest">ยังไม่มีประวัติการส่ง</p>
                    </div>
                  </div>
                </div>

                <!-- Right Col: Tools & Quick Links -->
                <div class="space-y-6">
                  <!-- AI Settings -->
                  <div class="glass bg-gradient-to-br from-brand-600 to-indigo-700 rounded-3xl p-6 text-white shadow-xl relative overflow-hidden">
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
                    <div class="flex items-center justify-between mb-4 relative z-10">
                      <h3 class="font-black text-sm uppercase tracking-widest">การตั้งค่า AI ตอบกลับ</h3>
                      <div class="w-8 h-4 bg-white/20 rounded-full relative cursor-pointer">
                        <div class="absolute right-1 top-1 w-2 h-2 bg-white rounded-full"></div>
                      </div>
                    </div>
                    <p class="text-xs text-brand-100 mb-6 leading-relaxed relative z-10">บอทกำลังใช้ <strong>Groq Llama 3.3</strong> ในการตอบคำถามลูกค้าอัตโนมัติ โดยใช้ข้อมูลจากฐานความรู้ขององค์กร</p>
                    <button onclick="showView('wiki')" class="w-full py-2.5 bg-white text-brand-700 hover:bg-brand-50 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-md relative z-10">
                      จัดการฐานความรู้ (Wiki)
                    </button>
                  </div>

                  <!-- Quick Settings -->
                  <!-- 📜 Broadcast History -->
                  <div class="glass bg-white/40 dark:bg-surface-900/40 border border-surface-200/50 dark:border-surface-700/50 rounded-3xl p-6 shadow-sm overflow-hidden">
                    <div class="flex items-center justify-between mb-6">
                      <h3 class="font-black text-sm uppercase tracking-widest text-surface-900 dark:text-white">ประวัติการส่งล่าสุด</h3>
                      <button onclick="refreshBroadcastHistory()" class="p-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-xl transition-all">
                        <i data-lucide="refresh-cw" class="w-4 h-4 text-surface-400"></i>
                      </button>
                    </div>
                    
                    <div class="overflow-x-auto">
                      <table class="w-full text-left">
                        <thead>
                          <tr class="text-[10px] font-black uppercase tracking-widest text-surface-400 border-b border-surface-100 dark:border-surface-800">
                            <th class="pb-3 pr-4">วัน/เวลา</th>
                            <th class="pb-3 pr-4">ข้อความ</th>
                            <th class="pb-3">สถานะ</th>
                          </tr>
                        </thead>
                        <tbody id="broadcastHistoryList" class="divide-y divide-surface-50 dark:divide-surface-800/50">
                          <!-- History items injected here -->
                          <tr><td colspan="3" class="py-8 text-center text-surface-400 text-[10px]">กำลังโหลดข้อมูล...</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>

                  <div class="glass bg-white/40 dark:bg-surface-900/40 border border-surface-200/50 dark:border-surface-700/50 rounded-3xl p-6 shadow-sm space-y-4">
                    <h3 class="font-black text-sm uppercase tracking-widest text-surface-900 dark:text-white mb-4">การตั้งค่าพื้นฐาน</h3>
                    
                    <button onclick="toast('ระบบ Rich Menu กำลังเตรียมเปิดใช้งานค่ะ', 'info')" class="w-full flex items-center justify-between p-3 bg-surface-50 dark:bg-surface-800/50 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-xl transition-all group">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-surface-200/50 dark:bg-surface-700 flex items-center justify-center text-surface-600 dark:text-surface-300 group-hover:bg-brand-100 group-hover:text-brand-600 transition-colors">
                          <i data-lucide="layout-template" class="w-4 h-4"></i>
                        </div>
                        <span class="text-xs font-bold text-surface-700 dark:text-surface-300">Rich Menu</span>
                      </div>
                      <i data-lucide="chevron-right" class="w-4 h-4 text-surface-400"></i>
                    </button>

                    <button onclick="openLineSettings()" class="w-full flex items-center justify-between p-3 bg-surface-50 dark:bg-surface-800/50 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-xl transition-all group">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-surface-200/50 dark:bg-surface-700 flex items-center justify-center text-surface-600 dark:text-surface-300 group-hover:bg-brand-100 group-hover:text-brand-600 transition-colors">
                          <i data-lucide="message-square-dashed" class="w-4 h-4"></i>
                        </div>
                        <span class="text-xs font-bold text-surface-700 dark:text-surface-300">ข้อความต้อนรับ (Greeting)</span>
                      </div>
                      <i data-lucide="chevron-right" class="w-4 h-4 text-surface-400"></i>
                    </button>

                    <button onclick="openLineSettings()" class="w-full flex items-center justify-between p-3 bg-surface-50 dark:bg-surface-800/50 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-xl transition-all group">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-surface-200/50 dark:bg-surface-700 flex items-center justify-center text-surface-600 dark:text-surface-300 group-hover:bg-brand-100 group-hover:text-brand-600 transition-colors">
                          <i data-lucide="link" class="w-4 h-4"></i>
                        </div>
                        <span class="text-xs font-bold text-surface-700 dark:text-surface-300">LINE API Keys</span>
                      </div>
                      <i data-lucide="chevron-right" class="w-4 h-4 text-surface-400"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Quotation View -->
