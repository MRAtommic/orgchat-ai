              <div class="space-y-4">
                <h3 class="text-xs font-black uppercase tracking-widest text-surface-400 border-b border-surface-100 dark:border-surface-800 pb-2">ข้อมูลผู้ขาย</h3>
                <div class="space-y-3">
                  <input type="text" id="sellerName" class="input-field text-sm py-2" placeholder="ชื่อบริษัทผู้ขาย" value="บริษัท ออร์กแชท จำกัด">
                  <textarea id="sellerAddress" class="input-field text-sm py-2 h-16 resize-none" placeholder="ที่อยู่ผู้ขาย">123 ตึกสาทรแสควร์ กรุงเทพมหานคร 10500</textarea>
                  <input type="text" id="sellerTaxId" class="input-field text-sm py-2" placeholder="เลขประจำตัวผู้เสียภาษี" value="0105566000000">
                  <input type="text" id="sellerPhone" class="input-field text-sm py-2" placeholder="เบอร์โทรศัพท์" value="02-123-4567">
                </div>

                <h3 class="text-xs font-black uppercase tracking-widest text-surface-400 border-b border-surface-100 dark:border-surface-800 pb-2 pt-2">ข้อมูลเอกสาร</h3>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label class="text-[10px] font-bold text-surface-500">เลขที่เอกสาร</label>
                    <input type="text" id="qtNo" class="input-field text-sm py-2" placeholder="QT-202605001" value="QT-202605001">
                  </div>
                  <div class="space-y-1">
                    <label class="text-[10px] font-bold text-surface-500">วันที่</label>
                    <input type="date" id="qtDate" class="input-field text-sm py-2">
                  </div>
                </div>
                <h3 class="text-xs font-black uppercase tracking-widest text-surface-400 border-b border-surface-100 dark:border-surface-800 pb-2 pt-2">ข้อมูลลูกค้า</h3>
                <div class="space-y-3">
                  <input type="text" id="qtCustomerName" class="input-field text-sm py-2" placeholder="ชื่อบริษัทลูกค้า">
                  <textarea id="qtCustomerAddress" class="input-field text-sm py-2 h-20 resize-none" placeholder="ที่อยู่ลูกค้า"></textarea>
                  <input type="text" id="qtCustomerTaxId" class="input-field text-sm py-2" placeholder="เลขประจำตัวผู้เสียภาษี">
                  <input type="text" id="qtCustomerContact" class="input-field text-sm py-2" placeholder="ชื่อผู้ติดต่อ">
                </div>

                <h3 class="text-xs font-black uppercase tracking-widest text-surface-400 border-b border-surface-100 dark:border-surface-800 pb-2 pt-2 flex justify-between items-center">
                  รายการสินค้า
                  <button id="addQtItemBtn" class="text-brand-600 hover:text-brand-700 p-1"><i data-lucide="plus" class="w-4 h-4"></i></button>
                </h3>
                <div id="qtItemsContainer" class="space-y-3">
                  <!-- Items added here -->
                </div>
                
                <div class="border-t border-surface-200 dark:border-surface-800 pt-4 space-y-2">
                  <div class="flex justify-between items-center">
                    <label class="text-[10px] font-bold text-surface-500">ส่วนลด (บาท)</label>
                    <input type="number" id="qtDiscount" class="input-field text-sm py-1 w-24 text-right" value="0">
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Live Preview Area -->
            <div class="flex-1 bg-surface-100 dark:bg-surface-950 overflow-y-auto p-4 md:p-8 flex justify-center items-start">
              <!-- A4 Paper styling -->
              <div id="quotationPreview" class="bg-white w-[210mm] min-h-[296mm] shadow-xl relative text-black" style="padding: 20mm;">
                <!-- Simple header -->
                <div class="flex justify-between items-start mb-8 border-b-2 border-brand-600 pb-4">
                  <div>
                    <h1 class="text-3xl font-black text-brand-700 tracking-tight">ใบเสนอราคา</h1>
                    <h2 class="text-xl font-bold text-surface-400 tracking-widest mt-1">QUOTATION</h2>
                  </div>
                  <div class="text-right">
                    <h3 class="font-bold text-lg" id="prevSellerName">บริษัท ออร์กแชท จำกัด</h3>
                    <p class="text-xs text-surface-600 mt-1" id="prevSellerInfo">123 ตึกสาทรแสควร์ กรุงเทพมหานคร 10500<br>เลขประจำตัวผู้เสียภาษี: 0105566000000<br>โทร: 02-123-4567</p>
                  </div>
                </div>
                
                <div class="flex justify-between mb-8">
                  <div class="w-1/2 pr-4">
                    <p class="text-[10px] font-bold text-surface-400 uppercase tracking-widest mb-1">เสนอให้ (Customer)</p>
                    <p class="font-bold text-sm" id="prevCustName">ชื่อบริษัทลูกค้า</p>
                    <p class="text-xs text-surface-600 mt-1 whitespace-pre-wrap" id="prevCustAddress">ที่อยู่ลูกค้า</p>
                    <p class="text-xs text-surface-600 mt-1">เลขประจำตัวผู้เสียภาษี: <span id="prevCustTaxId">-</span></p>
                    <p class="text-xs text-surface-600 mt-1">ผู้ติดต่อ: <span id="prevCustContact">-</span></p>
                  </div>
                  <div class="w-1/3 bg-surface-50 p-4 rounded-xl border border-surface-200">
                    <div class="flex justify-between mb-2">
                      <span class="text-xs text-surface-500 font-bold">เลขที่ (No.)</span>
                      <span class="text-xs font-black" id="prevQtNo">QT-202605001</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-xs text-surface-500 font-bold">วันที่ (Date)</span>
                      <span class="text-xs font-black" id="prevQtDate">-</span>
                    </div>
                  </div>
                </div>
                
                <table class="w-full mb-8 text-sm">
                  <thead>
                    <tr class="bg-brand-600 text-white">
                      <th class="py-2 px-3 text-left w-12 rounded-tl-lg">ลำดับ</th>
                      <th class="py-2 px-3 text-left">รายการสินค้า (Description)</th>
                      <th class="py-2 px-3 text-right w-20">จำนวน</th>
                      <th class="py-2 px-3 text-right w-28">ราคาต่อหน่วย</th>
                      <th class="py-2 px-3 text-right w-32 rounded-tr-lg">จำนวนเงิน</th>
                    </tr>
                  </thead>
                  <tbody id="prevItemsBody">
                    <!-- Rendered via JS -->
                  </tbody>
                </table>
                
                <div class="flex justify-end mb-8">
                  <div class="w-1/2">
                    <div class="flex justify-between py-2 border-b border-surface-100">
                      <span class="text-xs font-bold text-surface-500">รวมเป็นเงิน (Sub Total)</span>
                      <span class="text-sm font-bold" id="prevSubTotal">0.00</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-surface-100 text-red-500">
                      <span class="text-xs font-bold">หักส่วนลด (Discount)</span>
                      <span class="text-sm font-bold" id="prevDiscount">0.00</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-surface-100">
                      <span class="text-xs font-bold text-surface-500">จำนวนเงินหลังหักส่วนลด</span>
                      <span class="text-sm font-bold" id="prevAfterDiscount">0.00</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-surface-100">
                      <span class="text-xs font-bold text-surface-500">ภาษีมูลค่าเพิ่ม (VAT 7%)</span>
                      <span class="text-sm font-bold" id="prevVat">0.00</span>
                    </div>
                    <div class="flex justify-between py-3 bg-brand-50 border-t-2 border-brand-600 px-3 rounded-b-xl">
                      <span class="text-sm font-black text-brand-800">จำนวนเงินสุทธิ (Grand Total)</span>
                      <span class="text-lg font-black text-brand-800" id="prevGrandTotal">0.00</span>
                    </div>
                  </div>
                </div>
                
                <div class="absolute bottom-[20mm] left-[20mm] right-[20mm] flex justify-between mt-12 pt-8 border-t border-surface-200">
                  <div class="text-center w-1/3">
                    <div class="border-b border-surface-300 h-8 mb-2"></div>
                    <p class="text-[10px] font-bold text-surface-500">ผู้ตกลงสั่งซื้อ / Customer</p>
                    <p class="text-[10px] text-surface-400 mt-1">วันที่ / Date: ........................</p>
                  </div>
                  <div class="text-center w-1/3">
                    <div class="border-b border-surface-300 h-8 mb-2"></div>
                    <p class="text-[10px] font-bold text-surface-500">ผู้อนุมัติ / Authorized Signature</p>
                    <p class="text-[10px] text-surface-400 mt-1">วันที่ / Date: ........................</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
