  <!-- 🌩️ Weather Detail Modal -->
  <div id="weatherDetailModal" class="fixed inset-0 z-[9999] bg-black/60 backdrop-blur-xl hidden flex items-center justify-center animate-in fade-in duration-500 p-0 sm:p-4">
    <div class="bg-white dark:bg-surface-900 w-full h-full sm:w-[95%] sm:max-w-xl sm:h-auto flex flex-col sm:rounded-[3rem] shadow-[0_0_100px_rgba(0,0,0,0.5)] overflow-hidden border border-white/20">
       <header class="p-8 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between bg-gradient-to-br from-brand-600 via-brand-700 to-indigo-800 text-white relative overflow-hidden">
