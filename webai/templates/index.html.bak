            <div class="flex items-center gap-3">
              <button class="px-4 py-2 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-[#00B900]/50 hover:text-[#00B900] rounded-xl text-xs font-bold transition-all shadow-sm flex items-center gap-2">
                <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i> ซิงค์ข้อมูล
              </button>
