        <!-- Knowledge Base View -->
        <section id="view-kb"
          class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full">
            <h2 class="font-semibold text-sm">คลังความรู้ส่วนตัว</h2>
            <div class="flex items-center gap-4">
              <div
                class="text-[11px] font-bold text-surface-400 flex items-center gap-3 border-r border-surface-100 pr-4">
                <div><span id="statFiles" class="text-surface-900 dark:text-white">0</span> ไฟล์</div>
                <div><span id="statChunks" class="text-surface-900 dark:text-white">0</span> ชิ้นส่วน</div>
              </div>
              <button id="refreshFilesBtn"
                class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors">↻
                รีเฟรช</button>
            </div>
          </header>
          <div class="flex-1 w-full flex flex-col md:flex-row overflow-hidden">
            <!-- KB Sidebar -->
            <aside
              class="w-full md:w-64 border-b md:border-b-0 md:border-r border-surface-100 dark:border-surface-800 bg-surface-50/50 dark:bg-surface-900 flex flex-col flex-shrink-0">
              <div class="p-4">
                <button onclick="addKBCategory()"
                  class="w-full flex items-center justify-center gap-2 bg-white dark:bg-surface-800 border-2 border-dashed border-surface-200 dark:border-surface-700 p-3 rounded-xl text-[10px] font-bold text-surface-400 hover:border-brand-600 hover:text-brand-600 transition-all">
                  <i data-lucide="plus" class="w-3.5 h-3.5"></i>เพิ่มหมวดหมู่ใหม่
                </button>
              </div>
              <nav id="kbCategorySidebar" class="flex-1 overflow-y-auto overflow-x-hidden px-2 space-y-1 custom-scrollbar max-h-32 md:max-h-none">
                <!-- Categories injected here -->
                <div class="p-4 text-center text-[11px] text-surface-400 italic">กำลังโหลดหมวดหมู่...</div>
              </nav>
            </aside>

            <!-- KB Content Area -->
            <div class="flex-1 flex flex-col bg-surface-50/30 dark:bg-surface-950 overflow-hidden">
              <!-- Search & Control Header -->
              <div class="p-4 flex flex-col sm:flex-row gap-4 items-center justify-between">
                <div class="relative w-full sm:w-96 group">
                  <i data-lucide="search"
                    class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400 group-focus-within:text-brand-600 transition-colors"></i>
                  <input type="text" id="kbSearchInput" placeholder="ค้นหาเนื้อหาภายในไฟล์ทั้งหมด..."
                    class="w-full pl-10 pr-4 py-2 bg-white dark:bg-surface-800 border-2 border-surface-100 dark:border-surface-700 rounded-xl text-xs focus:ring-4 focus:ring-brand-600/10 focus:border-brand-600 transition-all outline-none">
                </div>

                <div class="flex items-center gap-2">
                  <button id="addFileBtn" onclick="fileInput.click()"
                    class="bg-brand-600 hover:bg-brand-700 text-white p-2 rounded-xl transition-all shadow-sm flex items-center gap-2 px-4 text-xs font-bold">
                    <i data-lucide="plus" class="w-4 h-4"></i> เพิ่มข้อมูล
                  </button>
                </div>
              </div>

              <!-- Main Upload & Status Section (Nested inside scrollable area) -->
              <div class="p-4 space-y-6 overflow-y-auto custom-scrollbar flex-1">
                <div id="uploadZone"
                  class="group border-2 border-dashed border-surface-200 dark:border-surface-800 hover:border-brand-600 rounded-2xl p-8 text-center cursor-pointer transition-all bg-white dark:bg-surface-900/30 hover:bg-brand-50/30">
                  <input type="file" id="fileInput" multiple class="hidden" />
                  <div
                    class="w-12 h-12 bg-white dark:bg-surface-800 border border-surface-100 dark:border-surface-700 text-surface-400 group-hover:text-brand-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="upload-cloud" class="w-6 h-6"></i>
                  </div>
                  <h3 class="font-bold text-sm mb-1">ลากไฟล์มาวาง หรือคลิกเพื่ออัปโหลด</h3>
                  <p class="text-[10px] text-surface-400 uppercase font-black tracking-widest">PDF, CSV, TXT, Excel,
                    Word, Images</p>
                </div>

                <div id="uploadProgress"
                  class="hidden p-4 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl shadow-sm">
                  <div class="flex justify-between text-[11px] font-bold mb-2">
                    <span id="progressLabel" class="text-surface-600">กำลังอัปโหลด...</span>
                    <span id="progressPercent" class="text-brand-600">0%</span>
                  </div>
                  <div class="w-full bg-surface-100 dark:bg-surface-800 h-1.5 rounded-full overflow-hidden">
                    <div id="progressBar" class="bg-brand-600 h-full w-0 transition-all"></div>
                  </div>
                </div>

                <div id="bulkActionBar"
                  class="hidden items-center justify-between p-4 bg-brand-50 dark:bg-brand-900/20 border border-brand-100 dark:border-brand-800/50 rounded-2xl">
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 text-brand-600 font-bold text-xs uppercase tracking-wider">
                      <i data-lucide="check-square" class="w-4 h-4"></i>
                      เลือกแล้ว <span id="selectedCount">0</span> รายการ
                    </div>
                    <button id="selectAllFiles"
                      class="text-[11px] font-bold text-surface-400 hover:text-brand-600 tracking-wide transition-colors">เลือกทั้งหมด</button>
                  </div>
                  <div class="flex items-center gap-2">
                    <select id="bulkDeptMove"
                      class="text-[10px] font-bold bg-white dark:bg-surface-800 border-surface-200 dark:border-surface-700 rounded-lg focus:ring-brand-600">
                      <option value="">ย้ายแผนก...</option>
                      <option value="General">General</option>
                      <option value="HR">HR</option>
                      <option value="IT">IT</option>
                      <option value="Sales">Sales</option>
                    </select>
                    <button id="bulkCompareBtn" class="flex items-center gap-2 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 text-white py-1.5 px-3 text-[10px] uppercase font-bold rounded-xl shadow-lg shadow-purple-500/20 transition-all active:scale-95">
                      <i data-lucide="split" class="w-3.5 h-3.5"></i> เปรียบเทียบไฟล์
                    </button>
                    <button id="bulkDeleteBtn" class="btn-danger py-1.5 px-3 text-[11px] font-bold">ลบที่เลือก</button>
                  </div>
                </div>

                <!-- File List Grid -->
                <div id="fileList" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 3xl:grid-cols-6 gap-6 auto-rows-min pb-10">
                  <!-- Files injected here -->
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Google Drive View -->
        <section id="view-drive" class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300 w-full bg-surface-50 dark:bg-surface-950">
          <header class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full shrink-0">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-sky-50 dark:bg-sky-900/30 rounded-xl text-sky-600">
                <i data-lucide="cloud" class="w-5 h-5"></i>
              </div>
              <div>
                <h2 class="font-bold text-base">Google Drive Explorer</h2>
                <div id="driveBreadcrumbs" class="flex items-center gap-1 text-[10px] font-bold text-surface-400 uppercase tracking-widest overflow-x-auto no-scrollbar py-1">
                   <!-- Breadcrumbs here -->
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="loadDriveContents(state.drive.currentFolderId)" class="p-2 text-surface-400 hover:text-brand-600 rounded-lg transition-colors" title="Refresh">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i>
              </button>
            </div>
          </header>
          
          <div class="flex-1 overflow-y-auto custom-scrollbar p-4 md:p-6">
            <!-- Loading State -->
            <div id="driveLoading" class="hidden flex flex-col items-center justify-center py-20">
              <div class="w-10 h-10 border-4 border-brand-100 border-t-brand-600 rounded-full animate-spin mb-4"></div>
              <p class="text-xs font-bold text-surface-400">กำลังดึงข้อมูลจาก Google Drive...</p>
            </div>

            <!-- Empty State -->
            <div id="driveEmptyState" class="hidden flex flex-col items-center justify-center py-20 text-center">
              <div class="w-16 h-16 bg-surface-100 dark:bg-surface-800 rounded-2xl flex items-center justify-center mb-4 text-surface-300">
                <i data-lucide="folder-open" class="w-8 h-8"></i>
              </div>
              <p class="font-bold text-surface-600">ไม่พบไฟล์หรือโฟลเดอร์</p>
            </div>

            <!-- Drive Grid -->
            <div id="driveGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
              <!-- Content injected here -->
            </div>
          </div>
        </section>

        <!-- Smart Search View -->
        <section id="view-search"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-500 w-full bg-surface-50/20 dark:bg-surface-950">

          <!-- Header -->
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white/80 dark:bg-surface-900/80 backdrop-blur-md w-full flex-shrink-0">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-surface-100 dark:bg-surface-800 flex items-center justify-center">
                <i data-lucide="search" class="w-4 h-4 text-surface-600 dark:text-surface-400"></i>
              </div>
              <h2 class="font-bold text-sm tracking-tight text-surface-900 dark:text-surface-100">Smart Search</h2>
              <span
                class="text-[8px] font-bold uppercase tracking-[0.15em] px-2 py-0.5 rounded-full bg-brand-500/10 text-brand-600 border border-brand-500/20">AI
                Core</span>
            </div>
          </header>

          <!-- Content Area -->
          <div class="flex-1 w-full flex flex-col items-center overflow-y-auto custom-scrollbar px-6 py-12">
            <div class="w-full max-w-2xl">

              <!-- Hero Search Box -->
              <div class="mb-16">
                <div class="relative group">
                  <div
                    class="absolute -inset-2 bg-gradient-to-r from-brand-600/10 to-indigo-600/10 rounded-[2rem] blur-2xl opacity-0 group-focus-within:opacity-100 transition-opacity duration-700">
                  </div>
                  <div
                    class="relative flex items-center bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl shadow-sm group-focus-within:border-brand-500/50 group-focus-within:ring-4 group-focus-within:ring-brand-500/5 transition-all duration-500 overflow-hidden">
                    <i data-lucide="search"
                      class="w-5 h-5 text-surface-300 group-focus-within:text-brand-500 transition-colors ml-6 flex-shrink-0"></i>
                    <input id="searchInput" type="text" placeholder="พิมพ์สิ่งที่คุณต้องการค้นหาจากเอกสาร..."
                      class="flex-1 bg-transparent border-none focus:ring-0 text-base py-6 px-4 outline-none placeholder-surface-300 dark:placeholder-surface-600 font-medium text-surface-800 dark:text-surface-100"
                      autocomplete="off" spellcheck="false" />
                    <div id="searchSpinner" class="hidden mr-6">
                      <div class="w-4 h-4 border-2 border-brand-500/20 border-t-brand-500 rounded-full animate-spin">
                      </div>
                    </div>
                  </div>
                </div>
                <p class="mt-4 text-center text-[10px] text-surface-400 font-bold uppercase tracking-widest opacity-60">
                  ระบบจะเริ่มค้นหาทันทีที่คุณเริ่มพิมพ์</p>
              </div>

              <!-- Results Container -->
              <div id="searchResults">
                <!-- Empty State -->
                <div id="searchEmptyState"
                  class="flex flex-col items-center justify-center py-10 text-center animate-in fade-in slide-in-from-bottom-4 duration-700">
                  <div
                    class="w-20 h-20 bg-surface-100 dark:bg-surface-900 rounded-[2rem] flex items-center justify-center mb-8 border border-white dark:border-surface-800 shadow-xl shadow-surface-200/50 dark:shadow-none">
                    <div class="relative">
                      <i data-lucide="sparkles"
                        class="w-4 h-4 text-amber-500 absolute -top-1 -right-1 animate-pulse"></i>
                      <i data-lucide="database" class="w-8 h-8 text-surface-400"></i>
                    </div>
                  </div>
                  <h3 class="text-xl font-bold tracking-tight mb-3 text-surface-900 dark:text-surface-100">
                    ค้นหาข้อมูลอัจฉริยะ</h3>
                  <p class="text-surface-500 dark:text-surface-400 text-sm leading-relaxed max-w-sm mx-auto">
                    ค้นหาข้อมูลเชิงลึกจากนโยบาย ระเบียบ และเอกสารทั้งหมดในคลังความรู้ของคุณได้ในพริบตา
                  </p>

                  <div class="mt-10 flex flex-wrap gap-2 justify-center">
                    <button
                      class="px-4 py-2 text-[11px] font-bold text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl hover:border-brand-500 hover:text-brand-600 transition-all shadow-sm"
                      onclick="document.getElementById('searchInput').value='นโยบายการลา'; document.getElementById('searchInput').dispatchEvent(new Event('input'))">นโยบายการลา</button>
                    <button
                      class="px-4 py-2 text-[11px] font-bold text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl hover:border-brand-500 hover:text-brand-600 transition-all shadow-sm"
                      onclick="document.getElementById('searchInput').value='ข้อมูลพนักงาน'; document.getElementById('searchInput').dispatchEvent(new Event('input'))">ข้อมูลพนักงาน</button>
                    <button
                      class="px-4 py-2 text-[11px] font-bold text-surface-600 dark:text-surface-400 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl hover:border-brand-500 hover:text-brand-600 transition-all shadow-sm"
                      onclick="document.getElementById('searchInput').value='สวัสดิการ'; document.getElementById('searchInput').dispatchEvent(new Event('input'))">สวัสดิการ</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Analytics (Charts) View -->
        <section id="view-viz"
          class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300 w-full">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full">
            <div class="flex items-center gap-4">
              <h2 class="font-bold text-sm">การวิเคราะห์ข้อมูลองค์กร</h2>
              <div class="flex items-center gap-1.5 p-1 bg-surface-100 dark:bg-surface-800 rounded-xl">
                <button onclick="setVizMode('chart')" id="viz-mode-chart"
                  class="viz-mode-btn active px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-white dark:bg-surface-700 shadow-sm transition-all text-brand-600">วิเคราะห์กราฟ</button>
                <button onclick="setVizMode('table')" id="viz-mode-table"
                  class="viz-mode-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-surface-400 hover:text-brand-600 transition-all">ตารางข้อมูล</button>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <button id="downloadChartBtn"
                class="text-[10px] font-black text-surface-400 hover:text-brand-600 uppercase transition-colors flex items-center gap-1">
                <i data-lucide="download" class="w-3.5 h-3.5"></i> บันทึกภาพกราฟ
              </button>
            </div>
          </header>
          <div class="flex-1 overflow-y-auto custom-scrollbar p-6 w-full">
            <div class="w-full space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-4 gap-4 bg-surface-50 dark:bg-surface-900/50 p-6 rounded-2xl border border-surface-100 dark:border-surface-800/50 shadow-inner">
                <div class="space-y-1">
                  <label class="text-[10px] font-black text-surface-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="file-search" class="w-3 h-3"></i> เลือกไฟล์ข้อมูล</label>
                  <select id="vizFileSelect" class="input-field w-full text-xs font-bold"></select>
                </div>
                <div class="space-y-1">
                  <label class="text-[10px] font-black text-surface-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="hash" class="w-3 h-3"></i> แกน X (หัวข้อ)</label>
                  <select id="vizXSelect" class="input-field w-full text-xs font-bold"></select>
                </div>
                <div class="space-y-1">
                  <label class="text-[10px] font-black text-surface-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="activity" class="w-3 h-3"></i> แกน Y (ค่าตัวเลข)</label>
                  <select id="vizYSelect" class="input-field w-full text-xs font-bold"></select>
                </div>
                <div class="space-y-1">
                  <label class="text-[10px] font-black text-surface-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="layout" class="w-3 h-3"></i> ประเภทกราฟ</label>
                  <div class="flex gap-1">
                    <button class="viz-type-btn p-2 rounded-xl active bg-white dark:bg-surface-800 shadow-sm border border-surface-200 dark:border-surface-700" data-type="bar" title="กราฟแท่ง"><i data-lucide="bar-chart-big" class="w-4 h-4"></i></button>
                    <button class="viz-type-btn p-2 rounded-xl bg-white dark:bg-surface-800 shadow-sm border border-surface-200 dark:border-surface-700" data-type="line" title="กราฟเส้น"><i data-lucide="trending-up" class="w-4 h-4"></i></button>
                    <button class="viz-type-btn p-2 rounded-xl bg-white dark:bg-surface-800 shadow-sm border border-surface-200 dark:border-surface-700" data-type="pie" title="กราฟวงกลม"><i data-lucide="pie-chart" class="w-4 h-4"></i></button>
                  </div>
                </div>
                <div id="vizTableControls" class="hidden col-span-1 md:col-span-4 mt-2 space-y-1">
                  <label class="text-[10px] font-black text-surface-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="columns" class="w-3 h-3"></i> แสดงคอลัมน์</label>
                  <div id="vizColumnSelectors" class="flex flex-wrap gap-1.5 pt-1"></div>
                </div>
              </div>

              <div id="vizStatsRow" class="grid grid-cols-1 md:grid-cols-3 gap-4 hidden">
                <div class="bg-indigo-50/50 dark:bg-indigo-900/10 p-6 rounded-3xl border border-indigo-100 dark:border-indigo-800/20 text-center space-y-1">
                  <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">ค่าเฉลี่ย (AVERAGE)</p>
                  <p id="statsAvg" class="text-2xl font-black text-indigo-600">0</p>
                </div>
                <div class="bg-emerald-50/50 dark:bg-emerald-900/10 p-6 rounded-3xl border border-emerald-100 dark:border-emerald-800/20 text-center space-y-1">
                  <p class="text-[10px] font-black text-emerald-400 uppercase tracking-widest">ค่าสูงสุด (MAXIMUM)</p>
                  <p id="statsMax" class="text-2xl font-black text-emerald-600">0</p>
                </div>
                <div class="bg-rose-50/50 dark:bg-rose-900/10 p-6 rounded-3xl border border-rose-100 dark:border-rose-800/20 text-center space-y-1">
                  <p class="text-[10px] font-black text-rose-400 uppercase tracking-widest">ค่าต่ำสุด (MINIMUM)</p>
                  <p id="statsMin" class="text-2xl font-black text-rose-600">0</p>
                </div>
              </div>

              <div id="chartViewArea" class="bg-white dark:bg-surface-900 p-8 rounded-3xl border border-surface-200 dark:border-surface-800 shadow-sm min-h-[500px] flex items-center justify-center relative overflow-hidden">
                <div id="vizEmptyState" class="text-center text-surface-300">
                  <div class="w-20 h-20 bg-surface-50 dark:bg-surface-800 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="bar-chart-2" class="w-10 h-10 opacity-20"></i>
                  </div>
                  <p class="font-bold">เลือกไฟล์ CSV เพื่อดูสรุปกราฟ</p>
                </div>
                <canvas id="vizChart" class="hidden"></canvas>
              </div>

              <div id="tableViewArea" class="hidden bg-white dark:bg-surface-900 rounded-3xl border border-surface-200 dark:border-surface-800 shadow-sm overflow-hidden flex flex-col">
                <div class="overflow-x-auto custom-scrollbar">
                  <table class="w-full text-[11px] text-left border-collapse">
                    <thead id="vizTableHead" class="bg-surface-50 dark:bg-surface-800/50 sticky top-0 z-10 text-[10px] font-black text-surface-400 uppercase">
                    </thead>
                    <tbody id="vizTableBody" class="divide-y divide-surface-100 dark:divide-surface-800">
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- AI Insight Section for Analytics -->
              <div id="vizAiSummaryBox" class="hidden bg-white dark:bg-surface-900 p-6 rounded-[2rem] border border-surface-200 dark:border-surface-800 shadow-sm space-y-4">
                 <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                       <div class="p-2 bg-brand-50 dark:bg-brand-900/30 rounded-lg text-brand-600">
                          <i data-lucide="sparkles" class="w-4 h-4"></i>
                       </div>
                       <h3 class="font-bold text-sm">AI สรุปข้อมูลอัจฉริยะ</h3>
                    </div>
                    <button id="generateAiSummaryBtn" class="bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-xl text-xs font-bold transition-all flex items-center gap-2 shadow-lg shadow-brand-500/20">
                       <i data-lucide="wand-2" class="w-3.5 h-3.5"></i> วิเคราะห์ผล
                    </button>
                 </div>
                 <div id="aiSummaryContent" class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed font-medium">
                    คลิก "วิเคราะห์ผล" เพื่อให้ AI ช่วยสรุปแนวโน้มของข้อมูลชุดนี้...
                 </div>
              </div>
            </div>
          </div>
        </section>

        <!-- CSV Explorer View (Detailed Filters & Table) -->
        <section id="view-csv-explorer"
          class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300 w-full bg-surface-50 dark:bg-surface-950">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full shrink-0">
            <div class="flex items-center gap-3">
              <div class="p-2 bg-emerald-50 dark:bg-emerald-900/30 rounded-xl text-emerald-600">
                <i data-lucide="file-spreadsheet" class="w-5 h-5"></i>
              </div>
              <div>
                <h2 class="font-bold text-base">สำรวจข้อมูล CSV อัจฉริยะ</h2>
                <p class="text-[11px] text-surface-400 font-bold uppercase tracking-widest">Multi-level filtering & Column selection</p>
              </div>
            </div>
            <button id="explorerExportCsvBtn"
              class="bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-lg shadow-emerald-500/20 flex items-center gap-2">
              <i data-lucide="download" class="w-4 h-4"></i> ส่งออกไฟล์ที่กรองแล้ว
            </button>
          </header>
          
          <div class="flex-1 overflow-y-auto custom-scrollbar p-4 md:p-6 w-full space-y-6">
            <!-- Source & Columns -->
            <div class="bg-white dark:bg-surface-900 p-8 rounded-[2.5rem] border border-surface-200 dark:border-surface-800 shadow-sm space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="space-y-2">
                  <label class="text-xs font-black text-surface-400 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="file-search" class="w-4 h-4"></i> เลือกไฟล์ฐานข้อมูล
                  </label>
                  <select id="explorerFileSelect" class="input-field w-full text-sm font-bold h-11"></select>
                </div>
                <div class="md:col-span-2 space-y-2">
                  <label class="text-xs font-black text-surface-400 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="columns" class="w-4 h-4"></i> แสดงคอลัมน์
                  </label>
                  <div id="explorerColumnSelectors" class="flex flex-wrap gap-2.5 pt-1">
                    <span class="text-xs text-surface-400 italic">เลือกไฟล์เพื่อเริ่มต้น...</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Filter Manager -->
            <div id="explorerFilterContainer" class="bg-white dark:bg-surface-900 p-8 rounded-[2rem] border border-surface-200 dark:border-surface-800 shadow-sm space-y-5">
              <div class="flex items-center justify-between">
                <h3 class="text-xs font-black uppercase tracking-widest text-surface-400 flex items-center gap-2.5">
                  <i data-lucide="filter" class="w-4 h-4 text-brand-600"></i> ตัวจัดการตัวกรอง
                </h3>
                <div class="flex items-center gap-4 flex-1 max-w-md mx-6">
                   <div class="relative flex-1">
                      <i data-lucide="search" class="w-3.5 h-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-surface-400"></i>
                      <input type="text" id="explorerGlobalSearch" placeholder="ค้นหาทั่วทั้งเอกสาร (Global Search)..." 
                             class="input-field pl-9 w-full text-xs font-bold h-10">
                   </div>
                </div>
                <button id="explorerAddFilterBtn" class="text-xs font-black uppercase tracking-widest bg-brand-50 hover:bg-brand-100 text-brand-600 px-4 py-2 rounded-xl border border-brand-100 transition-all flex items-center gap-2">
                  <i data-lucide="plus" class="w-3.5 h-3.5"></i> เพิ่มชั้นการกรอง
                </button>
              </div>
              <div id="explorerFilterList" class="space-y-3"></div>
              <div id="explorerFilterStatus" class="hidden pt-3 border-t border-surface-50 dark:border-surface-800/50 flex items-center justify-between">
                <span class="text-xs font-bold text-surface-400">พบคัดกรองแล้ว <span id="explorerFilteredCount" class="text-brand-600 text-sm font-black">0</span> แถว (จากทั้งหมด <span id="explorerTotalCount">0</span>)</span>
                <button onclick="state.explorer.filters = []; renderExplorerFilters(); updateExplorerData();" class="text-xs font-black text-rose-500 uppercase hover:underline">ล้างทั้งหมด</button>
              </div>
            </div>

            <!-- Table Result Area -->
            <div id="explorerTableArea" class="bg-white dark:bg-surface-900 rounded-[2rem] border border-surface-200 dark:border-surface-800 shadow-sm overflow-hidden flex flex-col min-h-[500px]">
              <div class="flex-1 overflow-x-auto custom-scrollbar">
                <table class="w-full text-sm text-left border-collapse">
                  <thead id="explorerTableHead" class="bg-surface-50 dark:bg-surface-800/50 sticky top-0 z-10">
                    <!-- Headers -->
                  </thead>
                  <tbody id="explorerTableBody" class="divide-y divide-surface-100 dark:divide-surface-800">
                    <!-- Rows -->
                  </tbody>
                </table>
                <div id="explorerEmpty" class="py-20 text-center text-surface-300">
                  <div class="w-16 h-16 bg-surface-50 dark:bg-surface-800 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="database" class="w-8 h-8 opacity-20"></i>
                  </div>
                  <p class="font-bold">ยังไม่มีข้อมูลที่จะแสดง</p>
                  <p class="text-[10px] opacity-60">กรุณาเลือกไฟล์และตั้งค่าการกรอง</p>
                </div>
              </div>
              <!-- Pagination Control Area -->
              <div id="explorerPagination" class="hidden h-14 border-t border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-surface-50/50 dark:bg-surface-800/20 shrink-0">
                <div class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">
                  หน้า <span id="explorerCurrentPage" class="text-surface-900 dark:text-white">1</span> / <span id="explorerTotalPages">1</span>
                </div>
                <div class="flex items-center gap-2">
                  <button id="explorerPrevBtn" class="p-2 rounded-lg hover:bg-surface-200 dark:hover:bg-surface-700 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"><i data-lucide="chevron-left" class="w-4 h-4 text-surface-600 dark:text-surface-400"></i></button>
                  <div id="explorerPageNumbers" class="flex gap-1"></div>
                  <button id="explorerNextBtn" class="p-2 rounded-lg hover:bg-surface-200 dark:hover:bg-surface-700 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"><i data-lucide="chevron-right" class="w-4 h-4 text-surface-600 dark:text-surface-400"></i></button>
                </div>
                <div class="flex items-center gap-2">
                   <span class="text-[10px] font-black uppercase text-surface-400">แสดงหน้าละ</span>
                   <select id="explorerPageSize" class="bg-transparent text-xs font-black outline-none cursor-pointer">
                      <option value="25">25</option>
                      <option value="50">50</option>
                      <option value="100" selected>100</option>
                   </select>
                </div>
              </div>
            </div>

            <!-- AI Insight Section -->
            <div id="explorerAiInsight" class="hidden bg-gradient-to-br from-brand-600/5 to-emerald-600/5 dark:from-brand-900/10 dark:to-emerald-900/10 rounded-[2rem] border border-brand-100/50 dark:border-brand-800/30 p-8 space-y-5">
               <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <i data-lucide="sparkles" class="w-5 h-5 text-brand-600"></i>
                    <h3 class="text-sm font-black uppercase tracking-widest text-surface-700 dark:text-surface-200">AI Analytic Insight</h3>
                  </div>
                  <button id="explorerAiBtn" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all">วิเคราะห์ผลลัพธ์นี้</button>
               </div>
               <div id="explorerAiContent" class="text-sm text-surface-600 dark:text-surface-400 leading-relaxed font-medium"></div>
            </div>
          </div>
        </section>


        <section id="view-calendar"
          class="view hidden flex-1 overflow-y-auto flex flex-col items-center p-6 custom-scrollbar bg-surface-50/30 dark:bg-surface-950">
          <div class="max-w-[1600px] w-full flex items-center justify-between mb-6 flex-shrink-0">
            <div>
              <h2 class="text-3xl font-black tracking-tight mb-1">ปฏิทินกิจกรรม</h2>
              <p class="text-surface-500 text-sm font-medium">จัดการตารางนัดหมายและแผนงานองค์กร</p>
            </div>
            <div class="flex gap-3">
              <button id="archivePastSchedulesBtn"
                class="bg-amber-50 hover:bg-amber-100 text-amber-600 px-4 py-2.5 rounded-xl font-bold text-sm border border-amber-200 transition-all flex items-center gap-2">
                <i data-lucide="archive" class="w-4 h-4"></i> เก็บเข้ากรุ (Archive)
              </button>

              <button id="addScheduleBtn"
                class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg shadow-brand-600/20 transition-all flex items-center gap-2">
                <i data-lucide="plus" class="w-4 h-4"></i> เพิ่มกิจกรรม
              </button>
            </div>
          </div>
          
          <!-- Calendar Toolbar: Search, Filters, Export -->
          <div class="max-w-[1600px] w-full mb-6 glass px-6 py-4 rounded-3xl flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-4 flex-1">
              <!-- Search -->
              <div class="relative w-full md:w-64">
                <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-surface-400"></i>
                <input type="text" id="calendarSearchInput" placeholder="ค้นหากำหนดการ..." 
                       class="w-full pl-9 pr-4 py-2 rounded-xl bg-surface-100 dark:bg-surface-800/50 border-transparent focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10 text-xs font-bold transition-all outline-none">
              </div>
              
              <!-- Category Filter -->
              <div class="flex items-center gap-1.5 p-1 bg-surface-100 dark:bg-surface-800/50 rounded-xl overflow-hidden">
                <button class="cal-filter-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all active bg-white dark:bg-surface-700 shadow-sm text-brand-600" data-cat="all">All</button>
                <button class="cal-filter-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all text-surface-400 hover:text-brand-600" data-cat="Meeting">Meeting</button>
                <button class="cal-filter-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all text-surface-400 hover:text-brand-600" data-cat="Task">Task</button>
                <button class="cal-filter-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all text-surface-400 hover:text-brand-600" data-cat="Event">Event</button>
                <button class="cal-filter-btn px-3 py-1.5 rounded-lg text-[10px] font-black uppercase transition-all text-surface-400 hover:text-brand-600" data-cat="Holiday">Holiday</button>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <button id="exportCalendarBtn" 
                      class="px-4 py-2 rounded-xl bg-surface-100 hover:bg-surface-200 dark:bg-surface-800 dark:hover:bg-surface-700 text-surface-600 dark:text-surface-300 text-xs font-black transition-all flex items-center gap-2 border border-transparent hover:border-surface-200 dark:hover:border-surface-700">
                <i data-lucide="download" class="w-4 h-4"></i> Export .ics
              </button>
            </div>
          </div>

          <div class="max-w-[1600px] w-full flex flex-col lg:flex-row gap-6 pb-8 items-start">

            <!-- Calendar Grid -->
            <div class="flex-1 glass rounded-3xl p-4 md:p-6 flex flex-col min-w-0 w-full max-w-full"
              style="min-height: 520px;">
              <div class="flex items-center justify-between mb-4 md:mb-6">
                <h3 id="calendarMonth" class="text-xl font-bold text-surface-900 dark:text-white"></h3>
                <div class="flex gap-2">
                  <button id="prevMonth"
                    class="p-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-lg transition-colors"><i
                      data-lucide="chevron-left" class="w-5 h-5"></i></button>
                  <button id="nextMonth"
                    class="p-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-lg transition-colors"><i
                      data-lucide="chevron-right" class="w-5 h-5"></i></button>
                </div>
              </div>
              <div class="w-full overflow-x-auto custom-scrollbar pb-2">
                <div
                  class="grid grid-cols-7 gap-px bg-surface-200 dark:bg-surface-800 rounded-2xl overflow-hidden border border-surface-200 dark:border-surface-800 flex-1 min-w-[700px]">
                  <!-- Weekdays Header -->
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-rose-600">
                    Sun</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-surface-400">
                    Mon</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-surface-400">
                    Tue</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-surface-400">
                    Wed</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-surface-400">
                    Thu</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-surface-400">
                    Fri</div>
                  <div
                    class="bg-surface-50 dark:bg-surface-900 py-3 text-center text-[10px] font-black uppercase tracking-widest text-rose-600">
                    Sat</div>

                  <!-- Days Grid Container -->
                  <div id="calendarGrid" class="contents"></div>
                </div>
              </div>
            </div>

            <!-- Right Sidebar: Upcoming + Todo -->
            <div class="w-full lg:w-80 flex-shrink-0 flex flex-col gap-4">

              <!-- Upcoming Schedules -->
              <div class="glass rounded-3xl p-6 flex flex-col">
                <h3 class="text-sm font-bold uppercase tracking-widest text-surface-400 mb-4">นัดหมายเร็วๆ นี้</h3>
                <div id="upcomingSchedules" class="space-y-3 max-h-64 overflow-y-auto pr-2 custom-scrollbar">
                  <!-- Upcoming items -->
                </div>
              </div>

              <!-- ─── Task To-Do List ─────────────────────── -->
              <div class="glass rounded-3xl p-6 flex flex-col gap-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-sm font-bold uppercase tracking-widest text-surface-400 flex items-center gap-2">
                    <i data-lucide="check-square" class="w-4 h-4 text-brand-600"></i> รายการงาน (To-Do)
                  </h3>
                  <span id="todoCountBadge"
                    class="text-[10px] font-black bg-brand-100 dark:bg-brand-900/40 text-brand-600 px-2 py-0.5 rounded-full"></span>
                </div>

                <!-- Add Task Input -->
                <div class="flex gap-2">
                  <input id="todoInput" type="text" placeholder="เพิ่มงานใหม่..." maxlength="120"
                    class="flex-1 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-xl text-xs py-2 px-3 focus:ring-2 focus:ring-brand-500 outline-none transition-all"
                    onkeydown="if(event.key==='Enter') addTodoTask()" />
                  <button onclick="addTodoTask()"
                    class="flex-shrink-0 w-8 h-8 bg-brand-600 hover:bg-brand-700 text-white rounded-xl flex items-center justify-center transition-all shadow-sm">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                  </button>
                </div>

                <!-- Filter Tabs -->
                <div class="flex gap-1 text-[10px] font-black uppercase tracking-widest">
                  <button id="todoTab-all" onclick="setTodoFilter('all')"
                    class="todo-tab px-3 py-1 rounded-lg bg-brand-600 text-white transition-all">ทั้งหมด</button>
                  <button id="todoTab-pending" onclick="setTodoFilter('pending')"
                    class="todo-tab px-3 py-1 rounded-lg bg-surface-100 dark:bg-surface-800 text-surface-500 hover:bg-surface-200 dark:hover:bg-surface-700 transition-all">ค้างอยู่</button>
                  <button id="todoTab-done" onclick="setTodoFilter('done')"
                    class="todo-tab px-3 py-1 rounded-lg bg-surface-100 dark:bg-surface-800 text-surface-500 hover:bg-surface-200 dark:hover:bg-surface-700 transition-all">เสร็จแล้ว</button>
                </div>

                <!-- Task List -->
                <div id="todoList" class="space-y-2 max-h-80 overflow-y-auto pr-1 custom-scrollbar">
                  <div class="text-center py-6 text-surface-400 text-xs animate-pulse">กำลังโหลดรายการงาน...</div>
                </div>
              </div>

            </div>

          </div>
        </section>


        <!-- Social Feed View -->
        <section id="view-feed"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-auto md:h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 py-2 md:py-0 bg-white dark:bg-surface-900 sticky top-0 z-10 w-full gap-4">
            <h2 class="font-semibold text-sm">ฟีดกิจกรรมองค์กร</h2>
            <div id="feedFilters" class="flex gap-2 overflow-x-auto no-scrollbar py-1.5 ml-4">
              <button class="feed-filter-chip active" data-cat="All">
                <span class="chip-dot"></span>ทั้งหมด
              </button>
              <button class="feed-filter-chip" data-cat="General">
                <span class="chip-dot"></span>ทั่วไป
              </button>
              <button class="feed-filter-chip" data-cat="Meeting">
                <span class="chip-dot"></span>ประชุม
              </button>
              <button class="feed-filter-chip" data-cat="Event">
                <span class="chip-dot"></span>กิจกรรม
              </button>
              <button class="feed-filter-chip" data-cat="Holiday">
                <span class="chip-dot"></span>วันหยุด
              </button>
            </div>
          </header>
          <div class="flex-1 overflow-y-auto w-full max-w-5xl p-4 md:p-8">
            <div class="space-y-6">
              <!-- AI Daily Digest -->
              <div id="dailyDigest" class="hidden animate-in fade-in slide-in-from-top-4 duration-700">
                <div
                  class="bg-gradient-to-br from-brand-600 to-indigo-700 rounded-3xl p-6 text-white shadow-xl relative overflow-hidden group">
                  <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:scale-110 transition-transform">
                    <i data-lucide="sparkles" class="w-32 h-32"></i>
                  </div>
                  <div class="relative z-10 flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-2">
                        <div class="p-2 bg-white/20 rounded-xl backdrop-blur-md">
                          <i data-lucide="wand-2" class="w-5 h-5"></i>
                        </div>
                        <div>
                          <h3 class="font-bold text-sm tracking-tight">AI Daily Digest</h3>
                          <p class="text-[10px] opacity-70 font-medium uppercase tracking-widest">สรุปภาพรวมวันนี้</p>
                        </div>
                      </div>
                      <button id="refreshDigestBtn" class="p-2 hover:bg-white/10 rounded-full transition-colors"
                        title="รีเฟรชสรุป">
                        <i data-lucide="rotate-cw" class="w-4 h-4"></i>
                      </button>
                    </div>
                    <div id="digestContent" class="text-sm leading-relaxed font-medium">
                      กำลังเตรียมสรุปข่าวสารองค์กรสำหรับคุณวันนี้...
                    </div>
                  </div>
                </div>
              </div>

              <!-- Post Composer -->
              <div
                class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl p-4 shadow-sm">
                <div class="flex gap-4">
                  <div
                    class="w-10 h-10 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-600 flex-shrink-0">
                    <i data-lucide="user" class="w-5 h-5"></i>
                  </div>
                  <div class="flex-1 space-y-3">
                    <textarea id="postInput" placeholder="แชร์อะไรบางอย่างกับทุกคน..."
                      class="w-full bg-transparent border-none focus:ring-0 text-sm resize-none min-h-[80px]"
                      rows="3"></textarea>

                    <!-- Link Input (Hidden by default, toggled via button) -->
                    <div id="linkInputContainer"
                      class="hidden flex items-center gap-2 px-3 py-2 bg-surface-50 dark:bg-surface-800/50 rounded-lg border border-surface-100 dark:border-surface-700">
                      <i data-lucide="link" class="w-4 h-4 text-surface-400"></i>
                      <input type="text" id="postLink" placeholder="วางลิงก์ที่นี่ (เช่น https://...)"
                        class="flex-1 bg-transparent border-none text-xs focus:ring-0">
                      <button onclick="linkInputContainer.classList.add('hidden'); postLink.value='';"
                        class="text-surface-400 hover:text-red-500"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
                    </div>

                    <!-- Attachment Preview Area -->
                    <div id="postAttachmentPreview" class="flex flex-wrap gap-2"></div>

                    <div
                      class="flex flex-wrap items-center justify-between gap-3 pt-3 border-t border-surface-100 dark:border-surface-800">
                      <div class="flex flex-wrap items-center gap-1">
                        <select id="postCategory"
                          class="bg-surface-50 dark:bg-surface-800 border-none rounded-lg text-xs py-1.5 px-3 focus:ring-1 focus:ring-brand-500 min-w-[120px]">
                          <option value="General">หมวดหมู่: ทั่วไป</option>
                          <option value="Meeting">หมวดหมู่: ประชุม</option>
                          <option value="Event">หมวดหมู่: กิจกรรม</option>
                          <option value="Holiday">หมวดหมู่: วันหยุด</option>
                        </select>
                        <div class="flex items-center gap-0.5">
                          <button onclick="linkInputContainer.classList.remove('hidden'); postLink.focus();"
                            class="p-2 text-surface-400 hover:text-brand-600 rounded-lg transition-colors"
                            title="เพิ่มลิงก์">
                            <i data-lucide="link-2" class="w-4 h-4"></i>
                          </button>
                          <button onclick="postFileInput.click()"
                            class="p-2 text-surface-400 hover:text-brand-600 rounded-lg transition-colors"
                            title="แนบไฟล์">
                            <i data-lucide="paperclip" class="w-4 h-4"></i>
                          </button>
                          <!-- New Poll Button -->
                          <button onclick="togglePollComposer()"
                            class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-50 dark:bg-surface-800 text-surface-500 rounded-xl hover:bg-brand-50 dark:hover:bg-brand-900/40 hover:text-brand-600 transition-all border border-surface-100 dark:border-surface-700/50"
                            title="สร้างโพลล์">
                            <i data-lucide="bar-chart-2" class="w-3.5 h-3.5"></i>
                            <span class="text-[10px] font-bold uppercase tracking-wider">โพลล์</span>
                          </button>
                        </div>
                        <input type="file" id="postFileInput" multiple class="hidden"
                          accept=".pdf,.doc,.docx,.png,.jpg,.jpeg">
                      </div>

                      <!-- Poll Composer Area (Hidden by default) -->
                      <div id="pollComposer"
                        class="hidden w-full space-y-3 p-4 bg-surface-50 dark:bg-surface-800/50 rounded-2xl border border-surface-100 dark:border-surface-700 animate-in fade-in slide-in-from-top-2 duration-300">
                        <div class="flex items-center justify-between mb-2">
                          <h4
                            class="text-[10px] font-black uppercase tracking-widest text-brand-600 flex items-center gap-1.5">
                            <i data-lucide="bar-chart-2" class="w-3.5 h-3.5"></i> สร้างโพลล์สำรวจ
                          </h4>
                          <button onclick="togglePollComposer(false)" class="text-surface-400 hover:text-red-500"><i
                              data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                        <input type="text" id="pollQuestion" placeholder="คำถามของคุณคืออะไร?"
                          class="w-full bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl text-xs py-2 px-3 focus:ring-1 focus:ring-brand-500">
                        <div id="pollOptionsContainer" class="space-y-2">
                          <!-- Options will be added here -->
                          <div class="flex gap-2">
                            <input type="text" placeholder="ตัวเลือกที่ 1"
                              class="poll-option-input flex-1 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl text-xs py-2 px-3 focus:ring-1 focus:ring-brand-500">
                          </div>
                          <div class="flex gap-2">
                            <input type="text" placeholder="ตัวเลือกที่ 2"
                              class="poll-option-input flex-1 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-700 rounded-xl text-xs py-2 px-3 focus:ring-1 focus:ring-brand-500">
                          </div>
                        </div>
                        <button onclick="addPollOption()"
                          class="text-[10px] font-bold text-brand-600 hover:text-brand-700 flex items-center gap-1 mt-1 transition-colors">
                          <i data-lucide="plus-circle" class="w-3.5 h-3.5"></i> เพิ่มตัวเลือก
                        </button>
                      </div>
                      <button id="submitPostBtn"
                        class="btn-primary py-2 px-6 text-xs flex-shrink-0 ml-auto sm:ml-0">โพสต์</button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Feed Container -->
              <div id="feedPosts" class="space-y-4">
                <!-- Posts will be injected here -->
                <div class="text-center py-10 text-surface-400">
                  <div class="animate-pulse">กำลังโหลดฟีด...</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Profile Settings View -->
        <section id="view-profile"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 sticky top-0 z-10 w-full">
            <h2 class="font-semibold text-sm">การตั้งค่าโปรไฟล์ส่วนตัว</h2>
          </header>
          <div class="flex-1 min-h-0 overflow-y-auto w-full max-w-2xl p-4 md:p-8 space-y-8">
            <div
              class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-3xl overflow-hidden shadow-sm">
              <!-- Profile Header/Cover Preview -->
              <div id="profileCoverPreview" class="h-32 bg-brand-600 relative">
                <div class="absolute -bottom-10 left-8">
                  <div class="relative group">
                    <div id="profileAvatarPreview"
                      class="w-24 h-24 rounded-2xl bg-white dark:bg-surface-800 p-1 shadow-xl overflow-hidden border-4 border-white dark:border-surface-900">
                      <div
                        class="w-full h-full bg-surface-100 dark:bg-surface-700 flex items-center justify-center text-surface-400">
                        <i data-lucide="user" class="w-10 h-10"></i>
                      </div>
                    </div>
                    <button onclick="document.getElementById('avatarUploadInput').click()"
                      class="absolute inset-0 bg-black/40 text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center rounded-2xl">
                      <i data-lucide="camera" class="w-6 h-6"></i>
                    </button>
                    <input type="file" id="avatarUploadInput" class="hidden" accept="image/*">
                  </div>
                </div>
              </div>

              <div class="pt-14 p-8 space-y-8">
                <!-- Account Information Section -->
                <div class="space-y-4">
                  <div class="flex items-center gap-2 pb-2 border-b border-surface-100 dark:border-surface-800">
                    <i data-lucide="user-cog" class="w-4 h-4 text-brand-600"></i>
                    <h3 class="text-xs font-black uppercase tracking-widest text-surface-500">ข้อมูลบัญชีผู้ใช้</h3>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                      <label
                        class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">ชื่อที่แสดง</label>
                      <input type="text" id="profileNameInput" class="input-field w-full"
                        placeholder="ระบุชื่อที่คุณต้องการให้คนอื่นเห็น">
                    </div>
                    <div class="space-y-2">
                      <label class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">Username
                        (แก้ไขไม่ได้)</label>
                      <input type="text" id="profileUsernameDisplay"
                        class="input-field w-full opacity-50 cursor-not-allowed" readonly>
                    </div>
                  </div>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
                    <div class="space-y-2">
                      <label class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">องค์กร / บริษัท</label>
                      <input type="text" id="profileOrgDisplay"
                        class="input-field w-full opacity-70 cursor-not-allowed bg-surface-50 dark:bg-surface-800" readonly value="Default Organization">
                    </div>
                    <div class="space-y-2">
                      <label class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">แพ็กเกจปัจจุบัน</label>
                      <div class="flex items-center gap-2">
                        <span id="profilePlanBadge" class="px-2.5 py-1 rounded-lg text-xs font-black uppercase tracking-wider bg-surface-100 text-surface-600 dark:bg-surface-800 dark:text-surface-400">FREE PLAN</span>
                        <a href="/onboarding" class="text-xs font-bold text-brand-600 hover:underline">จัดการแพ็กเกจ →</a>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Appearance Section -->
                <div class="space-y-4 pt-4">
                  <div class="flex items-center gap-2 pb-2 border-b border-surface-100 dark:border-surface-800">
                    <i data-lucide="palette" class="w-4 h-4 text-brand-600"></i>
                    <h3 class="text-xs font-black uppercase tracking-widest text-surface-500">การปรับแต่งแอปพลิเคชัน
                    </h3>
                  </div>
                  <div class="space-y-3">
                    <label class="text-[10px] font-bold text-surface-400 uppercase tracking-widest">ธีมพื้นหลัง</label>
                    <div class="grid grid-cols-4 md:grid-cols-6 gap-3">
                      <button
                        class="bg-preset-btn w-full aspect-square rounded-xl border-2 border-transparent transition-all overflow-hidden bg-brand-600"
                        data-bg="linear-gradient(135deg, #2563eb, #1d4ed8)"></button>
                      <button
                        class="bg-             
              <button onclick="openQRScanner()" 
                class="btn-primary w-full py-4 bg-emerald-600 hover:bg-emerald-700 text-xs font-black uppercase tracking-widest shadow-lg shadow-emerald-500/20 flex items-center justify-center gap-2 border-none">
                <i data-lucide="camera" class="w-5 h-5"></i> เปิดกล้องสแกน QR Code เพื่อ Login
              </button>
            </div>

            <!-- ═══ Google Drive & Sheets Connection ═══ -->
            <div id="googleDriveSection" class="p-6 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl space-y-4">
              <h3 class="font-bold text-sm mb-1 uppercase text-surface-500 flex items-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg">
                  <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da"/>
                  <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-20.4 35.3c-.8 1.4-1.2 2.95-1.2 4.5h27.5z" fill="#00ac47"/>
                  <path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.5l5.85 13.95z" fill="#ea4335"/>
                  <path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d"/>
                  <path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc"/>
                  <path d="m73.4 26.5-10.1-17.5c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 23.5h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00"/>
                </svg>
                Google Drive & Sheets
              </h3>
              <p class="text-xs text-surface-400">
                เชื่อมต่อบัญชี Google ของคุณเพื่อให้ข้อมูลเอกสาร สลิป ใบกำกับภาษีทั้งหมด ถูกบันทึกลงใน Google Drive & Sheets ส่วนตัวของคุณโดยตรง
              </p>

              <!-- Connection Status Container -->
              <div id="googleConnectContainer">
                <!-- Loading state -->
                <div id="googleConnectLoading" class="flex items-center justify-center py-6">
                  <div class="animate-pulse text-xs text-surface-400">กำลังตรวจสอบสถานะการเชื่อมต่อ...</div>
                </div>

                <!-- Not Connected state -->
                <div id="googleNotConnected" class="hidden space-y-4">
                  <div class="p-4 bg-amber-50 dark:bg-amber-900/10 rounded-2xl border border-amber-200 dark:border-amber-800/30">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                      <span class="text-[10px] font-black uppercase tracking-wider text-amber-600">ยังไม่ได้เชื่อมต่อ</span>
                    </div>
                    <p class="text-[11px] text-amber-700 dark:text-amber-400">ข้อมูลเอกสารกำลังใช้ระบบส่วนกลาง (Service Account ของ Admin)</p>
                  </div>
                  <a href="/api/auth/google/start" id="googleConnectBtn"
                    class="flex items-center justify-center gap-3 w-full py-4 px-6 bg-white hover:bg-gray-50 dark:bg-surface-800 dark:hover:bg-surface-700 border-2 border-surface-200 dark:border-surface-600 rounded-2xl transition-all shadow-sm hover:shadow-md group">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    <span class="text-sm font-bold text-surface-700 dark:text-surface-200 group-hover:text-brand-600 transition-colors">
                      เชื่อมต่อ Google Drive & Sheets
                    </span>
                  </a>
                  <p id="googleOAuthNotConfigured" class="hidden text-[10px] text-red-500 text-center">
                    ⚠️ ระบบ OAuth2 ยังไม่ได้ตั้งค่า กรุณาติดต่อผู้ดูแลระบบ
                  </p>
                </div>

                <!-- Connected state -->
                <div id="googleConnected" class="hidden space-y-4">
                  <div class="p-4 bg-emerald-50 dark:bg-emerald-900/10 rounded-2xl border border-emerald-200 dark:border-emerald-800/30">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                      <span class="text-[10px] font-black uppercase tracking-wider text-emerald-600">เชื่อมต่อแล้ว</span>
                    </div>
                    <p class="text-sm font-bold text-emerald-700 dark:text-emerald-400" id="googleConnectedEmail">—</p>
                    <p class="text-[10px] text-emerald-600 mt-1">ข้อมูลเอกสารทั้งหมดจะถูกบันทึกลงใน Google Drive & Sheets ส่วนตัวของคุณ</p>
                  </div>

                  <!-- Quick Links -->
                  <div class="grid grid-cols-2 gap-3">
                    <a id="googleSheetLink" href="#" target="_blank"
                      class="flex items-center gap-2 p-3 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 transition-all group">
                      <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-green-600 group-hover:scale-110 transition-transform">
                        <i data-lucide="table-2" class="w-4 h-4"></i>
                      </div>
                      <div>
                        <p class="text-[10px] font-black uppercase tracking-wider text-surface-400">Google Sheets</p>
                        <p class="text-[10px] text-brand-600 font-bold">เปิดชีตของฉัน →</p>
                      </div>
                    </a>
                    <a id="googleDriveLink" href="#" target="_blank"
                      class="flex items-center gap-2 p-3 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 transition-all group">
                      <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
                        <i data-lucide="hard-drive" class="w-4 h-4"></i>
                      </div>
                      <div>
                        <p class="text-[10px] font-black uppercase tracking-wider text-surface-400">Google Drive</p>
                        <p class="text-[10px] text-brand-600 font-bold">เปิดไดรฟ์ของฉัน →</p>
                      </div>
                    </a>
                  </div>

                  <!-- Disconnect Button -->
                  <button id="googleDisconnectBtn" onclick="disconnectGoogleDrive()"
                    class="w-full py-3 px-4 bg-surface-50 hover:bg-red-50 dark:bg-surface-800 dark:hover:bg-red-900/20 border border-surface-200 dark:border-surface-700 hover:border-red-300 dark:hover:border-red-800 rounded-xl text-xs font-bold text-surface-500 hover:text-red-600 transition-all flex items-center justify-center gap-2">
                    <i data-lucide="unplug" class="w-4 h-4"></i> ยกเลิกการเชื่อมต่อ Google
                  </button>
                </div>
              </div>
            </div>

            <!-- App Installation Section -->
            <div id="pwaInstallSection"
              class="p-6 bg-white dark:bg-surface-900 border border-surface-200 rounded-xl space-y-4">
              <h3 class="font-bold text-sm mb-1 uppercase text-surface-500 flex items-center gap-2">
                <i data-lucide="smartphone" class="w-4 h-4 text-brand-600"></i> ดาวน์โหลด/ติดตั้ง APK (ผ่าน PWA)
              </h3>
              <p class="text-xs text-surface-400">ติดตั้งแอป OrgChat ลงในหน้าจอโฮมเพื่อการใช้งานที่สะดวกเหมือนแอปมือถือ
                (ทดแทน APK แบบเดิม)</p>

              <button id="installAppBtn"
                class="btn-primary w-full py-3 text-[11px] font-black uppercase tracking-widest shadow-lg shadow-brand-500/20 flex items-center justify-center gap-2">
                <i data-lucide="download-cloud" class="w-4 h-4"></i> ติดตั้งคัดลอกลงมือถือ (APK Style)
              </button>
            </div>
          </div>
        </section>

        <!-- Leave Management View -->
        <section id="view-leave" class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300 w-full">
          <header class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 sticky top-0 z-10 w-full shrink-0">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-rose-50 dark:bg-rose-900/30 flex items-center justify-center text-rose-500">
                <i data-lucide="log-out" class="w-4 h-4"></i>
              </div>
              <h2 class="font-bold text-sm">ระบบลางาน (Leave Request)</h2>
            </div>
          </header>
          
          <div class="flex-1 min-h-0 overflow-y-auto w-full max-w-4xl p-4 md:p-8 space-y-8 custom-scrollbar">
            <!-- Summary Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
              <div class="p-6 bg-white dark:bg-surface-900 border border-surface-100 dark:border-surface-800 rounded-3xl shadow-sm text-center">
                <p class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-2">สิทธิการลาปีนี้</p>
                <div class="flex items-baseline justify-center gap-1">
                  <span class="text-3xl font-black text-brand-600">30</span>
                  <span class="text-xs font-bold text-surface-400 uppercase tracking-widest">วัน</span>
                </div>
              </div>
              <div class="p-6 bg-white dark:bg-surface-900 border border-surface-100 dark:border-surface-800 rounded-3xl shadow-sm text-center">
                <p class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-2">ใช้ไปแล้ว</p>
                <div class="flex items-baseline justify-center gap-1">
                  <span class="text-3xl font-black text-rose-500" id="leaveUsedDays">0</span>
                  <span class="text-xs font-bold text-surface-400 uppercase tracking-widest">วัน</span>
                </div>
              </div>
              <div class="p-6 bg-white dark:bg-surface-900 border border-emerald-500/20 dark:border-emerald-500/10 rounded-3xl shadow-sm text-center bg-emerald-50/20 dark:bg-emerald-500/5">
                <p class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-2">คงเหลือ</p>
                <div class="flex items-baseline justify-center gap-1">
                  <span class="text-3xl font-black text-emerald-500" id="leaveRemainingDays">30</span>
                  <span class="text-xs font-bold text-surface-400 uppercase tracking-widest">วัน</span>
                </div>
              </div>
            </div>

            <!-- New Leave Request Form -->
            <div class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-[32px] overflow-hidden shadow-xl">
              <div class="p-8 space-y-6">
                <div class="flex items-center gap-3 pb-4 border-b border-surface-100 dark:border-surface-800">
                  <i data-lucide="plus-circle" class="w-5 h-5 text-brand-600"></i>
                  <h3 class="text-lg font-black text-surface-900 dark:text-white">ส่งคำขอลาใหม่</h3>
                </div>
                
                <form id="leaveRequestForm" class="space-y-6">
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                      <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">ประเภทการลา</label>
                      <select id="leaveType" class="input-field w-full cursor-pointer appearance-none bg-no-repeat bg-[right_1rem_center]" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22currentColor%22 stroke-width=%223%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E');">
                        <option value="Sick">ลาป่วย (Sick Leave)</option>
                        <option value="Personal">ลากิจ (Personal Leave)</option>
                        <option value="Vacation">ลาพักร้อน (Vacation Leave)</option>
                        <option value="Military">ลาเกณฑ์ทหาร</option>
                        <option value="Maternity">ลาคลอด</option>
                        <option value="Other">อื่นๆ (Other)</option>
                      </select>
                    </div>
                    <div class="space-y-2">
                      <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1 invisible">Placeholder</label>
                      <div class="p-4 bg-brand-50/50 dark:bg-brand-900/10 rounded-2xl border border-brand-100 dark:border-brand-900/20 text-[10px] font-bold text-brand-600 leading-relaxed">
                        โปรดแจ้งล่วงหน้าอย่างน้อย 3 วันสำหรับการลาพักร้อน และ 1 วันสำหรับการลากิจ
                      </div>
                    </div>
                    
                    <div class="space-y-2">
                      <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">วันที่เริ่ม</label>
                      <input type="date" id="leaveStartDate" class="input-field w-full">
                    </div>
                    <div class="space-y-2">
                      <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">วันที่สิ้นสุด</label>
                      <input type="date" id="leaveEndDate" class="input-field w-full">
                    </div>
                  </div>
                  
                  <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">เหตุผลการลา / รายละเอียดเพิ่มเติม</label>
                    <textarea id="leaveReason" placeholder="ระบุเหตุผล เช่น ลาไปทำธุระครอบครัว, ไม่สบายมีอาการไข้..." class="input-field w-full min-h-[120px] resize-none"></textarea>
                  </div>
                  
                  <div class="flex justify-end pt-4">
                    <button type="submit" class="btn-primary px-10 py-4 rounded-2xl font-black shadow-lg shadow-brand-500/30 transition-all hover:scale-[1.02] active:scale-[0.98]">
                      <i data-lucide="send" class="w-4 h-4 mr-2"></i> ส่งคำขอลา
                    </button>
                  </div>
                </form>
              </div>
            </div>

            <!-- History Section -->
            <div class="space-y-4 pb-20">
              <div class="flex items-center justify-between px-2">
                <h3 class="text-xs font-black uppercase tracking-widest text-surface-500 flex items-center gap-2">
                  <i data-lucide="history" class="w-4 h-4"></i> ประวัติการลาล่าสุด
                </h3>
              </div>
              
              <div id="leaveHistoryList" class="grid grid-cols-1 gap-4">
                <!-- Loading indicator -->
                <div class="text-center py-12 bg-white dark:bg-surface-900 rounded-[32px] border border-surface-100 dark:border-surface-800 shadow-sm animate-pulse">
                  <p class="text-surface-400 text-sm font-bold">กำลังโหลดประวัติการลา...</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Stats View -->
        <section id="view-stats"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full">
            <h2 class="font-semibold text-sm">การวิเคราะห์และสถิติองค์กร</h2>
          </header>
          <div class="p-8 flex-1 min-h-0 overflow-y-auto w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="p-8 glass rounded-2xl flex flex-col items-center justify-center text-center">
              <div class="text-4xl font-bold text-brand-600 mb-2" id="statTotalQueries">0</div>
              <div class="text-xs font-bold text-surface-400 uppercase">จำนวนคำถามทั้งหมด</div>
            </div>
            <div class="p-8 glass rounded-2xl flex flex-col items-center justify-center text-center">
              <div class="flex gap-4 mb-2">
                <div class="flex items-center gap-1.5 text-emerald-500"><i data-lucide="thumbs-up"
                    class="w-5 h-5"></i><span class="text-2xl font-bold" id="statLikes">0</span></div>
                <div class="flex items-center gap-1.5 text-red-500"><i data-lucide="thumbs-down"
                    class="w-5 h-5"></i><span class="text-2xl font-bold" id="statDislikes">0</span></div>
              </div>
              <div class="text-xs font-bold text-surface-400 uppercase">ความพึงพอใจต่อคำตอบ</div>
            </div>
            <div class="md:col-span-2 p-8 glass rounded-2xl">
              <h3 class="font-bold text-sm mb-6 uppercase text-surface-500">สถานะการทำงานของระบบ</h3>
              <div class="space-y-4">
                <div class="flex items-center justify-between"><span class="text-sm font-medium">Embedding
                    Provider</span><span id="statEmbedProvider"
                    class="px-2 py-0.5 bg-brand-50 text-brand-600 text-[10px] font-bold rounded">Local
                    (FastEmbed)</span></div>
                <div class="flex items-center justify-between"><span class="text-sm font-medium">Database
                    Persistence</span><span
                    class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[10px] font-bold rounded">Active</span>
                </div>
              </div>
            </div>
            <div id="auditLogSection" class="md:col-span-2 p-8 glass rounded-2xl">
              <h3 class="font-bold text-sm mb-6 uppercase text-surface-500">System Activity Audit Log</h3>
              <div id="auditLogList" class="space-y-2 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                <div class="text-center py-4 text-surface-400 text-xs">กำลังโหลดบันทึกกิจกรรม...</div>
              </div>
            </div>
          </div>
        </section>


        <!-- Admin Dashboard View -->
        <section id="view-admin"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300 w-full">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full">
            <h2 class="font-semibold text-sm">แผงควบคุมผู้ดูแลระบบ</h2>
          </header>
          <div class="p-8 flex-1 min-h-0 overflow-y-auto w-full max-w-4xl space-y-8">

            <!-- System Health Dashboard -->
            <div id="admin-stats-cards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <div
                class="p-5 bg-white dark:bg-surface-800 border border-surface-100 dark:border-surface-700 rounded-2xl shadow-sm flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1">Total
                  Queries</span>
                <div id="admin-total-queries" class="text-2xl font-black text-brand-600 dark:text-brand-400">...</div>
              </div>
              <div
                class="p-5 bg-white dark:bg-surface-800 border border-surface-100 dark:border-surface-700 rounded-2xl shadow-sm flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1">Total
                  Users</span>
                <div id="admin-total-users" class="text-2xl font-black text-brand-600 dark:text-brand-400">...</div>
              </div>
              <div
                class="p-5 bg-white dark:bg-surface-800 border border-surface-100 dark:border-surface-700 rounded-2xl shadow-sm flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1">Uploads
                  Size</span>
                <div id="admin-uploads-size" class="text-2xl font-black text-brand-600 dark:text-brand-400">... MB
                </div>
              </div>
              <div
                class="p-5 bg-white dark:bg-surface-800 border border-surface-100 dark:border-surface-700 rounded-2xl shadow-sm flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-widest text-surface-400 mb-1">KB Size</span>
                <div id="admin-kb-size" class="text-2xl font-black text-brand-600 dark:text-brand-400">...</div>
              </div>
            </div>

            <!-- Analytics Charts -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <!-- Daily Activity Chart -->
              <div
                class="bg-white dark:bg-surface-900 border border-surface-100 dark:border-surface-800 rounded-2xl p-6 shadow-sm">
                <div class="flex items-center gap-3 mb-5">
                  <div
                    class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-600 flex items-center justify-center text-white shadow-md flex-shrink-0">
                    <i data-lucide="trending-up" class="w-4 h-4"></i>
                  </div>
                  <div>
                    <h3 class="text-sm font-black text-surface-900 dark:text-white">กิจกรรม 7 วันล่าสุด</h3>
                    <p class="text-[10px] text-surface-400 font-bold uppercase tracking-widest">AI Queries · โพสต์ · แชท
                    </p>
                  </div>
                </div>
                <div class="relative h-48">
                  <canvas id="activityChart"></canvas>
                </div>
              </div>

              <!-- Top Posters Chart -->
              <div
                class="bg-white dark:bg-surface-900 border border-surface-100 dark:border-surface-800 rounded-2xl p-6 shadow-sm">
                <div class="flex items-center gap-3 mb-5">
                  <div
                    class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center text-white shadow-md flex-shrink-0">
                    <i data-lucide="bar-chart-2" class="w-4 h-4"></i>
                  </div>
                  <div>
                    <h3 class="text-sm font-black text-surface-900 dark:text-white">Top 5 นักโพสต์</h3>
                    <p class="text-[10px] text-surface-400 font-bold uppercase tracking-widest">จำนวนโพสต์สะสม</p>
                  </div>
                </div>
                <div class="relative h-48">
                  <canvas id="topPostersChart"></canvas>
                </div>
              </div>
            </div>

            <!-- Leaderboard -->
            <div
              class="bg-white dark:bg-surface-900 border border-surface-100 dark:border-surface-800 rounded-2xl p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-5">
                <div
                  class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white shadow-md flex-shrink-0">
                  <i data-lucide="trophy" class="w-4 h-4"></i>
                </div>
                <h3 class="text-sm font-black text-surface-900 dark:text-white">Leaderboard — นักโพสต์ยอดนิยม</h3>
              </div>
              </div>

            <!-- LINE OA Broadcast Card [NEW] -->
            <div class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl overflow-hidden shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-800/50 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white shadow-md">
                        <i data-lucide="message-square" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-base text-surface-900 dark:text-white">LINE OA Broadcast</h3>
                        <p class="text-[10px] font-semibold text-surface-500 uppercase tracking-wider">ส่งประกาศถึงผู้ใช้งานทุกคนผ่าน LINE OA</p>
                    </div>
                </div>
                <div class="p-6 space-y-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">ข้อความประกาศ</label>
                        <textarea id="lineBroadcastMsg" placeholder="พิมพ์ข้อความที่ต้องการส่งถึงทุกคนใน LINE OA..." 
                            class="input-field w-full min-h-[120px] resize-none text-sm border-surface-200 dark:border-surface-700 bg-surface-50/50 dark:bg-surface-800/30 rounded-xl p-4 focus:ring-2 focus:ring-emerald-500/20 transition-all outline-none"></textarea>
                    </div>
                    <div class="flex justify-between items-center bg-emerald-50/50 dark:bg-emerald-900/10 p-3 rounded-xl border border-emerald-100/50 dark:border-emerald-800/30">
                        <div class="flex items-center gap-2 text-[10px] font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-tight">
                            <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                            ระบบจะส่งไปยังทุกคนที่ติดตาม LINE OA
                        </div>
                        <button id="lineBroadcastBtn" onclick="sendLineBroadcast()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 shadow-lg shadow-emerald-600/20 transition-all hover:scale-[1.02] active:scale-[0.98]">
                            <i data-lucide="send" class="w-4 h-4"></i> ส่งประกาศทันที
                        </button>
                    </div>
                </div>
            </div>






            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

              <!-- Danger Zone -->
              <div
                class="p-6 bg-gradient-to-br from-red-50 to-white dark:from-red-900/10 dark:to-surface-900 border border-red-100 dark:border-red-800/30 rounded-2xl flex flex-col justify-center items-center text-center shadow-sm relative overflow-hidden group">
                <div
                  class="absolute -right-6 -bottom-6 text-red-500/5 rotate-12 group-hover:scale-110 transition-transform duration-500 pointer-events-none">
                  <i data-lucide="shield-alert" class="w-40 h-40"></i>
                </div>
                <div class="relative z-10 flex flex-col items-center">
                  <div
                    class="w-16 h-16 rounded-full bg-red-100 dark:bg-red-900/50 flex items-center justify-center text-red-600 dark:text-red-400 mb-4 border border-red-200 dark:border-red-800/50 shadow-inner">
                    <i data-lucide="shield-alert" class="w-8 h-8"></i>
                  </div>
                  <h3 class="font-black text-red-600 dark:text-red-400 text-base mb-1 uppercase tracking-wide">Danger
                    Zone
                  </h3>
                  <p class="text-xs text-red-600/70 dark:text-red-400/70 font-medium leading-relaxed mb-5 max-w-xs">
                    การล้างฐานข้อมูลจะลบข้อมูลแชทและฐานความรู้ออกทั้งหมด การกระทำนี้ไม่สามารถย้อนกลับได้</p>
                  <button id="wipeDataBtn"
                    class="px-5 py-2.5 bg-white dark:bg-surface-800 border-2 border-red-500 text-red-600 dark:text-red-400 font-bold rounded-xl hover:bg-red-500 hover:text-white uppercase transition-colors text-xs shadow-sm hover:shadow-md flex items-center justify-center gap-2 w-full max-w-[240px]">
                    <i data-lucide="trash-2" class="w-4 h-4"></i> ล้างข้อมูลแชท & ฐานความรู้
                  </button>
                  <button onclick="adminClearAllNotifs()"
                    class="mt-3 px-5 py-2.5 bg-white dark:bg-surface-800 border-2 border-orange-500 text-orange-600 dark:text-orange-400 font-bold rounded-xl hover:bg-orange-500 hover:text-white uppercase transition-colors text-xs shadow-sm hover:shadow-md flex items-center justify-center gap-2 w-full max-w-[240px]">
                    <i data-lucide="bell-off" class="w-4 h-4"></i> ล้างการแจ้งเตือนทั้งหมด
                  </button>
                </div>
              </div>

              <!-- Admin Status -->
              <!-- Chat Management (Individual Deletion) -->
              <div
                class="p-6 bg-gradient-to-br from-indigo-50 to-white dark:from-indigo-900/10 dark:to-surface-900 border border-indigo-100 dark:border-indigo-800/30 rounded-2xl flex flex-col justify-center items-center text-center shadow-sm relative overflow-hidden group">
                <div
                  class="absolute -right-6 -bottom-6 text-indigo-500/5 rotate-12 group-hover:scale-110 transition-transform duration-500 pointer-events-none">
                  <i data-lucide="messages-square" class="w-40 h-40"></i>
                </div>
                <div class="relative z-10 flex flex-col items-center">
                  <div
                    class="w-16 h-16 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-4 border border-indigo-200 dark:border-indigo-800/50 shadow-inner">
                    <i data-lucide="message-square-plus" class="w-8 h-8"></i>
                  </div>
                  <h3 class="font-black text-indigo-600 dark:text-indigo-400 text-base mb-1 uppercase tracking-wide">
                    แชทแมนเนเจอร์
                  </h3>
                  <p
                    class="text-xs text-indigo-600/70 dark:text-indigo-400/70 font-medium leading-relaxed mb-5 max-w-xs">
                    จัดการแชทกลุ่ม ห้องแชท และ DM รายบุคคล สามารถเลือกลบข้อความเฉพาะจุดได้ตามที่ต้องการ</p>
                  <button onclick="openAdminChatPanel()"
                    class="px-5 py-2.5 bg-white dark:bg-surface-800 border-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 font-bold rounded-xl hover:bg-indigo-500 hover:text-white uppercase transition-colors text-xs shadow-sm hover:shadow-md flex items-center justify-center gap-2 w-full max-w-[240px]">
                    <i data-lucide="shield" class="w-4 h-4"></i> เปิดเครื่องมือจัดการแชท
                  </button>
                </div>
              </div>

            </div>

              <!-- Leave Requests Approval (Admin) -->
              <div class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl overflow-hidden shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-800/50 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-rose-500 to-rose-600 flex items-center justify-center text-white shadow-md">
                      <i data-lucide="clipboard-list" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <h3 class="font-bold text-base text-surface-900 dark:text-white">จัดการคำขอลา (Leave Management)</h3>
                      <p class="text-[10px] font-semibold text-surface-500 uppercase tracking-wider">Review & Approve Requests</p>
                    </div>
                  </div>
                  <button onclick="refreshAdminLeaves()" class="p-2 hover:bg-surface-100 dark:hover:bg-surface-700 rounded-lg transition-colors text-surface-400">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                  </button>
                </div>
                <div class="p-0 overflow-x-auto">
                  <table class="w-full text-left text-xs">
                    <thead class="bg-surface-50 dark:bg-surface-800/30 text-surface-400 font-black uppercase tracking-widest border-b border-surface-100 dark:border-surface-800">
                      <tr>
                        <th class="px-6 py-4">ผู้ขอลา</th>
                        <th class="px-6 py-4">ประเภท</th>
                        <th class="px-6 py-4">วันที่ลา</th>
                        <th class="px-6 py-4">เหตุผล</th>
                        <th class="px-6 py-4">สถานะ</th>
                        <th class="px-6 py-4 text-right">จัดการ</th>
                      </tr>
                    </thead>
                    <tbody id="adminLeaveTableBody" class="divide-y divide-surface-100 dark:divide-surface-800">
                      <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-surface-400">กำลังโหลดข้อมูลคำขอลา...</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              {% if is_admin %}
            <!-- ═══ Google Drive & Sheets Connection ═══ -->
            <div id="googleDriveSection" class="p-6 bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl space-y-4 shadow-sm mb-6">
              <h3 class="font-bold text-sm mb-1 uppercase text-surface-500 flex items-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg">
                  <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da"/>
                  <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-20.4 35.3c-.8 1.4-1.2 2.95-1.2 4.5h27.5z" fill="#00ac47"/>
                  <path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.5l5.85 13.95z" fill="#ea4335"/>
                  <path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d"/>
                  <path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc"/>
                  <path d="m73.4 26.5-10.1-17.5c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 23.5h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00"/>
                </svg>
                Google Drive & Sheets (แผงเชื่อมต่อองค์กร)
              </h3>
              <p class="text-xs text-surface-400">
                เชื่อมต่อบัญชี Google ของคุณเพื่อให้ข้อมูลเอกสาร สลิป ใบกำกับภาษีทั้งหมด ถูกบันทึกลงใน Google Drive & Sheets ส่วนตัวของคุณโดยตรง
              </p>

              <!-- Connection Status Container -->
              <div id="googleConnectContainer">
                <!-- Loading state -->
                <div id="googleConnectLoading" class="flex items-center justify-center py-6">
                  <div class="animate-pulse text-xs text-surface-400">กำลังตรวจสอบสถานะการเชื่อมต่อ...</div>
                </div>

                <!-- Not Connected state -->
                <div id="googleNotConnected" class="hidden space-y-4">
                  <div class="p-4 bg-amber-50 dark:bg-amber-900/10 rounded-2xl border border-amber-200 dark:border-amber-800/30">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-amber-400"></div>
                      <span class="text-[10px] font-black uppercase tracking-wider text-amber-600">ยังไม่ได้เชื่อมต่อ</span>
                    </div>
                    <p class="text-[11px] text-amber-700 dark:text-amber-400">ข้อมูลเอกสารกำลังใช้ระบบส่วนกลาง (Service Account ของ Admin)</p>
                  </div>
                  <a href="/api/auth/google/start" id="googleConnectBtn"
                    class="flex items-center justify-center gap-3 w-full py-4 px-6 bg-white hover:bg-gray-50 dark:bg-surface-800 dark:hover:bg-surface-700 border-2 border-surface-200 dark:border-surface-600 rounded-2xl transition-all shadow-sm hover:shadow-md group">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    <span class="text-sm font-bold text-surface-700 dark:text-surface-200 group-hover:text-brand-600 transition-colors">
                      เชื่อมต่อ Google Drive & Sheets
                    </span>
                  </a>
                  <p id="googleOAuthNotConfigured" class="hidden text-[10px] text-red-500 text-center">
                    ⚠️ ระบบ OAuth2 ยังไม่ได้ตั้งค่า กรุณาติดต่อผู้ดูแลระบบ
                  </p>
                </div>

                <!-- Connected state -->
                <div id="googleConnected" class="hidden space-y-4">
                  <div class="p-4 bg-emerald-50 dark:bg-emerald-900/10 rounded-2xl border border-emerald-200 dark:border-emerald-800/30">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                      <span class="text-[10px] font-black uppercase tracking-wider text-emerald-600">เชื่อมต่อแล้ว</span>
                    </div>
                    <p class="text-sm font-bold text-emerald-700 dark:text-emerald-400" id="googleConnectedEmail">—</p>
                    <p class="text-[10px] text-emerald-600 mt-1">ข้อมูลเอกสารทั้งหมดจะถูกบันทึกลงใน Google Drive & Sheets ส่วนตัวของคุณ</p>
                  </div>

                  <!-- Quick Links -->
                  <div class="grid grid-cols-2 gap-3">
                    <a id="googleSheetLink" href="#" target="_blank"
                      class="flex items-center gap-2 p-3 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 transition-all group">
                      <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-green-600 group-hover:scale-110 transition-transform">
                        <i data-lucide="table-2" class="w-4 h-4"></i>
                      </div>
                      <div>
                        <p class="text-[10px] font-black uppercase tracking-wider text-surface-400">Google Sheets</p>
                        <p class="text-[10px] text-brand-600 font-bold">เปิดชีตของฉัน →</p>
                      </div>
                    </a>
                    <a id="googleDriveLink" href="#" target="_blank"
                      class="flex items-center gap-2 p-3 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700 hover:border-brand-300 dark:hover:border-brand-700 transition-all group">
                      <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
                        <i data-lucide="hard-drive" class="w-4 h-4"></i>
                      </div>
                      <div>
                        <p class="text-[10px] font-black uppercase tracking-wider text-surface-400">Google Drive</p>
                        <p class="text-[10px] text-brand-600 font-bold">เปิดไดรฟ์ของฉัน →</p>
                      </div>
                    </a>
                  </div>

                  <!-- Disconnect Button -->
                  <button id="googleDisconnectBtn" onclick="disconnectGoogleDrive()"
                    class="w-full py-3 px-4 bg-surface-50 hover:bg-red-50 dark:bg-surface-800/50 dark:hover:bg-red-900/20 border border-surface-200 dark:border-surface-700 hover:border-red-300 dark:hover:border-red-800 rounded-xl text-xs font-bold text-surface-500 hover:text-red-600 transition-all flex items-center justify-center gap-2">
                    <i data-lucide="unplug" class="w-4 h-4"></i> ยกเลิกการเชื่อมต่อ Google
                  </button>
                </div>
              </div>
            </div>
            {% endif %}

            <!-- System Configuration Box -->
            <div
              class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl overflow-hidden shadow-sm mb-6">
              <div
                class="px-6 py-4 border-b border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-800/50 flex items-center gap-3">
                <div
                  class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-brand-600 flex items-center justify-center text-white shadow-md">
                  <i data-lucide="settings-2" class="w-5 h-5"></i>
                </div>
                <div>
                  <h3 class="font-bold text-base">ตั้งค่าระบบ</h3>
                  <p class="text-[11px] font-semibold text-surface-500 uppercase tracking-wider">System Configuration
                  </p>
                </div>
              </div>
              <div id="settingAllowUserEditContainer" class="p-6 hidden">
                <div
                  class="flex items-center justify-between p-4 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700">
                  <div class="flex items-center gap-4">
                    <div
                      class="w-10 h-10 rounded-full bg-brand-100 dark:bg-brand-900/40 text-brand-600 dark:text-brand-400 flex items-center justify-center">
                      <i data-lucide="edit-3" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <h4 class="text-sm font-bold">อนุญาตให้ผู้ใช้ทั่วไปแก้ไขไฟล์ได้</h4>
                      <p class="text-[11px] text-surface-500 font-medium">หากเปิดใช้งาน
                        ผู้ใช้ทุกคนจะสามารถอัปโหลด แก้ไข และลบไฟล์ในคลังข้อมูลได้</p>
                    </div>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="settingAllowUserEdit" class="sr-only peer">
                    <div
                      class="w-11 h-6 bg-surface-200 peer-focus:outline-none rounded-full peer dark:bg-surface-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-brand-600">
                    </div>
                  </label>
                </div>
                </div>

              <!-- Email Whitelist Setting -->
              <div class="p-6 border-t border-surface-100 dark:border-surface-700">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 flex items-center justify-center">
                      <i data-lucide="mail" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <h4 class="text-sm font-bold">จำกัดการเข้าถึงด้วยอีเมล (Email Whitelist)</h4>
                      <p class="text-[11px] text-surface-500 font-medium">ใช้ได้กับการ Login ผ่าน Google เท่านั้น — เฉพาะอีเมลที่กำหนดไว้จึงจะเข้าสู่ระบบผ่าน Google ได้</p>
                    </div>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="settingEmailWhitelist" onchange="toggleEmailWhitelist(this.checked)" class="sr-only peer">
                    <div class="w-11 h-6 bg-surface-200 peer-focus:outline-none rounded-full peer dark:bg-surface-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600"></div>
                  </label>
                </div>

                <div id="whitelistContainer" class="hidden mt-4 pl-14">
                  <div class="flex gap-2 mb-3">
                    <input type="email" id="whitelistEmailInput" placeholder="กรอกอีเมลเพื่อเพิ่มเข้าระบบ..." class="input-field flex-1 text-sm py-2">
                    <button onclick="addWhitelistEmail()" class="btn-primary py-2 px-4 whitespace-nowrap text-xs shadow-none">
                      <i data-lucide="plus" class="w-4 h-4 mr-1"></i> เพิ่มอีเมล
                    </button>
                  </div>
                  <div class="bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-200 dark:border-surface-700 max-h-[200px] overflow-y-auto">
                    <ul id="whitelistEmailList" class="divide-y divide-surface-200 dark:divide-surface-700">
                      <!-- Whitelist items will be loaded here -->
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <!-- User Management Box -->
            <div
              class="bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-2xl overflow-hidden shadow-sm">
              <div
                class="px-6 py-4 border-b border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-800/50 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div
                    class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white shadow-md">
                    <i data-lucide="users" class="w-5 h-5"></i>
                  </div>
                  <div>
                    <h3 class="font-bold text-base">จัดการผู้ใช้</h3>
                    <p class="text-[11px] font-semibold text-surface-500 uppercase tracking-wider">User Management</p>
                  </div>
                </div>
                <div id="adminUserStats" class="flex flex-wrap items-center gap-2">
                  <div class="admin-stat-chip"><span id="totalUsersCount">0</span> ผู้ใช้ทั้งหมด</div>
                  <div class="admin-stat-chip" style="color:#10b981; background:rgba(16,185,129,.1);"><span
                      id="activeUsersCount">0</span> ใช้งานอยู่</div>
                  <div class="admin-stat-chip" style="color:#ef4444; background:rgba(239,68,68,.1);"><span
                      id="inactiveUsersCount">0</span> ระงับ</div>
                  <button onclick="openCreateUserModal()"
                    class="ml-2 px-3 py-1.5 bg-brand-600 hover:bg-brand-700 text-white text-[11px] font-bold rounded-xl shadow-sm transition-all flex items-center gap-1.5">
                    <i data-lucide="user-plus" class="w-3.5 h-3.5"></i>
                    เพิ่มผู้ใช้ใหม่
                  </button>
                </div>
              </div>

              <div id="adminUserList"
                class="p-4 grid grid-cols-1 md:grid-cols-2 gap-3 max-h-[500px] overflow-y-auto custom-scrollbar">
                <div style="text-align:center;padding:40px;color:#94a3b8;grid-column:1/-1;">กำลังโหลดข้อมูลผู้ใช้...
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Notifications View -->
        <section id="view-notifications" class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300 w-full bg-surface-50/30 dark:bg-surface-950/30">
          <header class="h-16 border-b border-surface-200/50 dark:border-surface-800/50 flex items-center justify-between px-4 sm:px-8 bg-white/80 dark:bg-surface-900/80 w-full sticky top-0 z-20 backdrop-blur-xl shadow-sm">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-orange-400 to-amber-500 shadow-lg shadow-orange-500/20 flex items-center justify-center">
                <i data-lucide="bell" class="w-4 h-4 text-white"></i>
              </div>
              <div>
                <h2 class="font-black text-sm tracking-tight text-surface-900 dark:text-white">การแจ้งเตือน</h2>
                <div class="text-[10px] font-bold text-surface-400 uppercase tracking-widest mt-0.5">Notifications</div>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3">
              <button onclick="readAllNotifications()" class="px-3 py-2 sm:px-4 sm:py-2.5 bg-surface-100 dark:bg-surface-800 hover:bg-surface-200 dark:hover:bg-surface-700 text-surface-600 dark:text-surface-300 text-[10px] sm:text-xs font-black rounded-xl transition-all flex items-center gap-1.5 uppercase tracking-wide">
                <i data-lucide="check-check" class="w-3.5 h-3.5"></i> <span class="hidden sm:inline">อ่านทั้งหมด</span>
              </button>
              <button onclick="clearAllNotifications()" class="px-3 py-2 sm:px-4 sm:py-2.5 bg-rose-50 dark:bg-rose-900/20 hover:bg-rose-100 dark:hover:bg-rose-900/40 text-rose-600 dark:text-rose-400 text-[10px] sm:text-xs font-black rounded-xl transition-all flex items-center gap-1.5 uppercase tracking-wide border border-rose-100 dark:border-rose-900/50">
                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> <span class="hidden sm:inline">ลบทั้งหมด</span>
              </button>
            </div>
          </header>
          <div class="flex-1 w-full max-w-3xl mx-auto p-4 lg:p-6 overflow-y-auto custom-scrollbar">
            <div id="notificationsContainer" class="space-y-3">
              <p class="text-center text-sm font-medium text-surface-400 py-10"><i data-lucide="loader-2"
                  class="w-6 h-6 animate-spin mx-auto mb-2 opacity-50"></i>กำลังโหลด...</p>
            </div>
          </div>
        </section>

        <!-- Whiteboard View -->
        <section id="view-whiteboard" class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300 w-full h-full">
          <header class="h-16 border-b border-surface-200/50 dark:border-surface-800/50 flex items-center justify-between px-4 sm:px-8 bg-white/80 dark:bg-surface-900/80 w-full z-20 backdrop-blur-xl shadow-sm">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 shadow-lg shadow-purple-500/20 flex items-center justify-center">
                <i data-lucide="palette" class="w-4 h-4 text-white"></i>
              </div>
              <div>
                <h2 class="font-black text-sm tracking-tight text-surface-900 dark:text-white">ไวท์บอร์ดอัจฉริยะ</h2>
                <div class="text-[10px] font-bold text-surface-400 uppercase tracking-widest mt-0.5">Real-time Whiteboard</div>
              </div>
            </div>
            
            <div class="flex items-center gap-2">
              <button onclick="clearWhiteboardLocal(true)" class="p-2 text-surface-400 hover:text-red-500 transition-colors" title="ล้างกระดาน">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>
              <button onclick="downloadWhiteboard()" class="px-3 sm:px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-xl text-xs font-bold shadow-sm flex items-center gap-2 transition-all">
                <i data-lucide="download" class="w-3.5 h-3.5"></i>
                <span class="hidden sm:inline">บันทึกเป็นรูปภาพ</span>
              </button>
            </div>
          </header>

          <div class="flex-1 relative bg-surface-100 dark:bg-surface-950 overflow-hidden cursor-crosshair" id="whiteboardContainer">
            <canvas id="whiteboardCanvas" class="absolute inset-0 w-full h-full"></canvas>
            <canvas id="whiteboardOverlay" class="absolute inset-0 w-full h-full pointer-events-auto"></canvas>
            
            <!-- Toolbar -->
            <div class="wb-toolbar absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2 p-2.5 bg-white/90 dark:bg-surface-900/90 backdrop-blur-xl border border-surface-200/30 dark:border-surface-800/30 rounded-2xl shadow-2xl z-20">
              <div class="wb-toolbar-section flex items-center gap-1 border-r border-surface-200 dark:border-surface-800 pr-2 mr-1">
                <button onclick="setWhiteboardTool('pencil')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all bg-brand-600 text-white" id="tool-pencil">
                  <i data-lucide="pencil" class="w-4 h-4"></i>
                </button>
                <button onclick="setWhiteboardTool('eraser')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-600 dark:text-surface-400" id="tool-eraser">
                  <i data-lucide="eraser" class="w-4 h-4"></i>
                </button>
                <div class="w-px h-6 bg-surface-200 dark:bg-surface-800 mx-1 hidden sm:block"></div>
                <button onclick="setWhiteboardTool('line')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-600 dark:text-surface-400" id="tool-line">
                  <i data-lucide="minus" class="w-4 h-4"></i>
                </button>
                <button onclick="setWhiteboardTool('rect')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-600 dark:text-surface-400" id="tool-rect">
                  <i data-lucide="square" class="w-4 h-4"></i>
                </button>
                <button onclick="setWhiteboardTool('circle')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-600 dark:text-surface-400" id="tool-circle">
                  <i data-lucide="circle" class="w-4 h-4"></i>
                </button>
                <button onclick="setWhiteboardTool('text')" class="wb-tool-btn w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-surface-100 dark:hover:bg-surface-800 text-surface-600 dark:text-surface-400" id="tool-text">
                  <i data-lucide="type" class="w-4 h-4"></i>
                </button>
              </div>

              <div class="wb-toolbar-section flex items-center gap-2 px-1">
                <div onclick="setWhiteboardColor('#000000', this)" class="wb-color-btn w-6 h-6 rounded-full border-2 border-white shadow-sm cursor-pointer ring-2 ring-brand-500" style="background: #000000;" data-color="#000000"></div>
                <div onclick="setWhiteboardColor('#ef4444', this)" class="wb-color-btn w-6 h-6 rounded-full border-2 border-white shadow-sm cursor-pointer" style="background: #ef4444;" data-color="#ef4444"></div>
                <div onclick="setWhiteboardColor('#3b82f6', this)" class="wb-color-btn w-6 h-6 rounded-full border-2 border-white shadow-sm cursor-pointer" style="background: #3b82f6;" data-color="#3b82f6"></div>
                <div onclick="setWhiteboardColor('#10b981', this)" class="wb-color-btn w-6 h-6 rounded-full border-2 border-white shadow-sm cursor-pointer" style="background: #10b981;" data-color="#10b981"></div>
                <div onclick="setWhiteboardColor('#f59e0b', this)" class="wb-color-btn w-6 h-6 rounded-full border-2 border-white shadow-sm cursor-pointer" style="background: #f59e0b;" data-color="#f59e0b"></div>
              </div>

              <div class="wb-toolbar-section flex items-center gap-3 border-l border-surface-200 dark:border-surface-800 pl-3 ml-1">
                <input type="range" min="1" max="20" value="3" id="brushSize" class="w-16 sm:w-24 accent-brand-600">
                <span class="text-[10px] font-black w-4 text-surface-500" id="sizeDisplay">3</span>
              </div>
            </div>

            <!-- Active Users on Whiteboard -->
            <div class="absolute top-4 left-4 pointer-events-none">
              <div id="whiteboardUsers" class="flex items-center -space-x-2">
                <!-- User bubbles injected by JS -->
              </div>
            </div>
          </div>
        </section>

        <!-- Kanban Board View -->
        <section id="view-kanban"
          class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full flex-shrink-0">
            <div class="flex items-center gap-3">
              <div class="w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
                <i data-lucide="layout-dashboard" class="w-3.5 h-3.5 text-indigo-600"></i>
              </div>
              <h2 class="font-bold text-sm tracking-tight">กระดานคัมบัง</h2>
              <span
                class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 border border-indigo-100 dark:border-indigo-800">Kanban
                Board</span>
            </div>
            <div class="flex items-center gap-2">
              <button id="addKanbanColumnBtn" class="btn-secondary text-xs flex items-center gap-1.5">
                <i data-lucide="columns-2" class="w-3.5 h-3.5"></i> เพิ่มคอลัมน์
              </button>
              <button id="addKanbanCardBtn" class="btn-primary text-xs flex items-center gap-1.5">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> เพิ่มการ์ด
              </button>
            </div>
          </header>
          <div id="kanbanBoard"
            class="flex-1 flex overflow-x-auto overflow-y-hidden custom-scrollbar p-6 gap-4 items-start">
            <!-- Kanban columns injected by JS -->
            <div id="kanbanEmptyState"
              class="flex flex-col items-center justify-center min-h-[300px] w-full text-center text-surface-300">
              <i data-lucide="layout-dashboard" class="w-20 h-20 mx-auto mb-6 opacity-10"></i>
              <p class="font-bold text-sm">กำลังโหลดกระดาน...</p>
            </div>
          </div>
        </section>

        <!-- Internal Wiki View -->
        <section id="view-wiki" class="view hidden flex-1 overflow-hidden animate-in fade-in duration-300">
          <div class="wiki-layout">
            <aside class="wiki-sidebar">
              <div class="p-4 border-b border-surface-100 dark:border-surface-800">
                <button id="newWikiBtn" class="btn-primary w-full text-xs flex items-center justify-center gap-1.5">
                  <i data-lucide="plus" class="w-3.5 h-3.5"></i> สร้างบทความใหม่
                </button>
              </div>
              <div id="wikiPagesList" class="flex-1 overflow-y-auto custom-scrollbar">
                <div class="px-4 py-8 text-center text-surface-400 text-xs italic">กำลังโหลด...</div>
              </div>
            </aside>
            <main class="wiki-content-area overflow-y-auto custom-scrollbar">
              <div id="wikiViewArea" class="max-w-4xl mx-auto p-8 lg:p-12 hidden">
                <div
                  class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 pb-6 border-b border-surface-100 dark:border-surface-800">
                  <div id="wikiMeta"
                    class="text-[10px] font-black uppercase tracking-widest text-brand-600/60 dark:text-brand-400/60">
                  </div>
                  <div class="flex flex-wrap items-center gap-2">
                    <div
                      class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-50 dark:bg-surface-800/50 rounded-xl border border-surface-100 dark:border-surface-700 mr-2">
                      <i data-lucide="download" class="w-3.5 h-3.5 text-surface-400"></i>
                      <span class="text-[10px] font-black uppercase tracking-widest text-surface-500">Export</span>
                    </div>
                    <button onclick="exportWiki('docx')"
                      class="px-3 py-1.5 bg-blue-50 hover:bg-blue-100 dark:bg-blue-900/20 dark:hover:bg-blue-900/40 rounded-xl transition-all text-blue-600 flex items-center gap-1.5 text-[10px] font-black uppercase tracking-wider border border-blue-100 dark:border-blue-900/50 shadow-sm"
                      title="ส่งออก Word">
                      <i data-lucide="file-down" class="w-4 h-4"></i> Word
                    </button>
                    <button onclick="exportWiki('pdf')"
                      class="px-3 py-1.5 bg-rose-50 hover:bg-rose-100 dark:bg-rose-900/20 dark:hover:bg-rose-900/40 rounded-xl transition-all text-rose-600 flex items-center gap-1.5 text-[10px] font-black uppercase tracking-wider border border-rose-100 dark:border-rose-900/50 shadow-sm"
                      title="ส่งออก PDF">
                      <i data-lucide="file-text" class="w-4 h-4"></i> PDF
                    </button>
                    <button onclick="exportWiki('txt')"
                      class="px-3 py-1.5 bg-surface-50 hover:bg-surface-100 dark:bg-surface-800/50 dark:hover:bg-surface-800 rounded-xl transition-all text-surface-600 flex items-center gap-1.5 text-[10px] font-black uppercase tracking-wider border border-surface-200 dark:border-surface-700 shadow-sm"
                      title="ส่งออก Text">
                      <i data-lucide="file-output" class="w-4 h-4"></i> Text
                    </button>
                    <div class="w-px h-6 bg-surface-200 dark:bg-surface-700 mx-2"></div>
                    <button id="editWikiBtn"
                      class="p-2 bg-white dark:bg-surface-800 hover:bg-surface-100 dark:hover:bg-surface-700 rounded-xl transition-all border border-surface-200 dark:border-surface-700 shadow-sm"
                      title="แก้ไข">
                      <i data-lucide="edit-3" class="w-4 h-4 text-brand-600"></i>
                    </button>
                    <button id="deleteWikiBtn"
                      class="p-2 bg-rose-50 dark:bg-rose-900/20 hover:bg-rose-100 dark:hover:bg-rose-900/40 rounded-xl transition-all border border-rose-100 dark:border-rose-900/50"
                      title="ลบ">
                      <i data-lucide="trash-2" class="w-4 h-4 text-rose-500"></i>
                    </button>
                  </div>
                </div>
                <h1 id="wikiTitleDisplay"
                  class="text-3xl font-black mb-6 leading-tight text-surface-900 dark:text-white"></h1>
                <div id="wikiContentDisplay" class="max-w-none leading-relaxed"></div>
              </div>
              <div id="wikiEditorArea" class="max-w-3xl mx-auto p-8 hidden">
                <input type="text" id="wikiTitleInput"
                  class="wiki-editor-title w-full bg-transparent border-none outline-none mb-4 placeholder-surface-300 dark:placeholder-surface-600 text-surface-900 dark:text-white"
                  placeholder="ตั้งชื่อบทความ...">
                <div class="border border-surface-200 dark:border-surface-700 rounded-2xl overflow-hidden">
                  <div
                    class="bg-surface-50 dark:bg-surface-800 px-4 py-2 text-[9px] font-black uppercase tracking-widest text-surface-400 border-b border-surface-200 dark:border-surface-700">
                    Markdown Editor</div>
                  <textarea id="wikiContentInput" rows="20"
                    class="w-full bg-white dark:bg-surface-900 px-6 py-4 text-sm font-mono resize-none outline-none text-surface-700 dark:text-surface-300 leading-relaxed"
                    placeholder="เขียนเนื้อหาของคุณที่นี่ (รองรับ Markdown)..."></textarea>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                  <button id="cancelWikiBtn" class="btn-secondary px-6">ยกเลิก</button>
                  <button id="saveWikiBtn" class="btn-primary px-8 flex items-center gap-2">
                    <i data-lucide="save" class="w-4 h-4"></i> บันทึกบทความ
                  </button>
                </div>
              </div>
              <div id="wikiEmptyState" class="flex flex-col items-center justify-center h-full text-center p-8">
                <div
                  class="w-24 h-24 bg-surface-50 dark:bg-surface-900 rounded-3xl flex items-center justify-center text-surface-200 mb-6">
                  <i data-lucide="book-open" class="w-12 h-12"></i>
                </div>
                <h3 class="text-lg font-black mb-2">Internal Wiki</h3>
                <p class="text-surface-400 text-sm font-medium max-w-xs">เลือกบทความจากแถบด้านซ้าย หรือสร้างบทความใหม่
                </p>
              </div>
            </main>
          </div>
        </section>

        <!-- Reconciliation View -->
        <section id="view-reconciliation" class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300">
          <header class="h-14 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-6 bg-white dark:bg-surface-900 w-full">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 rounded-lg flex items-center justify-center">
                <i data-lucide="scale" class="w-5 h-5"></i>
              </div>
              <h2 class="font-bold text-sm">ระบบกระทบยอดอัตโนมัติ (Reconciliation)</h2>
            </div>
            <div id="reconLastRun" class="text-[10px] text-surface-400 font-medium">ยังไม่มีการประมวลผล</div>
          </header>

          <div class="flex-1 w-full overflow-y-auto p-6 bg-surface-50/30 dark:bg-surface-950">
            <div class="max-w-6xl mx-auto space-y-6">
              <!-- Upload Section -->
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="glass p-6 rounded-2xl border border-surface-100 dark:border-surface-800 space-y-4">
                  <div class="flex items-center gap-2 mb-2">
                    <i data-lucide="shopping-cart" class="w-4 h-4 text-orange-500"></i>
                    <h3 class="text-xs font-bold">1. ระบบขาย (Marketplace)</h3>
                  </div>
                  <input type="file" id="reconMPFiles" multiple class="hidden" accept=".xlsx,.xls,.csv">
                  <div onclick="document.getElementById('reconMPFiles').click()" class="border-2 border-dashed border-surface-200 dark:border-surface-800 rounded-xl p-4 text-center cursor-pointer hover:border-orange-500 transition-all bg-white/50 dark:bg-surface-900/50">
                    <i data-lucide="upload" class="w-6 h-6 text-surface-300 mx-auto mb-2"></i>
                    <p class="text-[9px] text-surface-400 uppercase font-black">Shopee / Lazada Reports</p>
                    <div id="reconMPList" class="mt-2 text-[10px] text-brand-600 font-bold"></div>
                  </div>
                </div>

                <div class="glass p-6 rounded-2xl border border-surface-100 dark:border-surface-800 space-y-4">
                  <div class="flex items-center gap-2 mb-2">
                    <i data-lucide="package" class="w-4 h-4 text-blue-500"></i>
                    <h3 class="text-xs font-bold">2. ระบบคลัง (Shipnity)</h3>
                  </div>
                  <input type="file" id="reconShipFiles" multiple class="hidden" accept=".xlsx,.xls,.csv">
                  <div onclick="document.getElementById('reconShipFiles').click()" class="border-2 border-dashed border-surface-200 dark:border-surface-800 rounded-xl p-4 text-center cursor-pointer hover:border-blue-500 transition-all bg-white/50 dark:bg-surface-900/50">
                    <i data-lucide="upload" class="w-6 h-6 text-surface-300 mx-auto mb-2"></i>
                    <p class="text-[9px] text-surface-400 uppercase font-black">Shipnity Exports</p>
                    <div id="reconShipList" class="mt-2 text-[10px] text-brand-600 font-bold"></div>
                  </div>
                </div>

                <div class="glass p-6 rounded-2xl border border-surface-100 dark:border-surface-800 space-y-4">
                  <div class="flex items-center gap-2 mb-2">
                    <i data-lucide="file-text" class="w-4 h-4 text-indigo-500"></i>
                    <h3 class="text-xs font-bold">3. ระบบบัญชี (PEAK)</h3>
                  </div>
                  <input type="file" id="reconPeakFiles" multiple class="hidden" accept=".xlsx,.xls,.csv">
                  <div onclick="document.getElementById('reconPeakFiles').click()" class="border-2 border-dashed border-surface-200 dark:border-surface-800 rounded-xl p-4 text-center cursor-pointer hover:border-indigo-500 transition-all bg-white/50 dark:bg-surface-900/50">
                    <i data-lucide="upload" class="w-6 h-6 text-surface-300 mx-auto mb-2"></i>
                    <p class="text-[9px] text-surface-400 uppercase font-black">Peak Tax Reports</p>
                    <div id="reconPeakList" class="mt-2 text-[10px] text-brand-600 font-bold"></div>
                  </div>
                </div>
              </div>

              <!-- Local PND53 Scan Control Card -->
              <div class="glass p-6 rounded-3xl border border-surface-200/50 dark:border-surface-850 bg-gradient-to-br from-indigo-500/5 via-brand-500/5 to-purple-500/5 backdrop-blur-xl shadow-xl flex flex-col md:flex-row items-center justify-between gap-6 transition-all hover:shadow-2xl">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white shadow-lg shadow-indigo-500/30 shrink-0">
                    <i data-lucide="folder-search" class="w-6 h-6 animate-pulse"></i>
                  </div>
                  <div>
                    <h3 class="text-sm font-black text-surface-900 dark:text-white flex items-center gap-2 flex-wrap">
                      สแกนและประมวลผล ภ.ง.ด. 53 ในเครื่อง
                      <span class="px-2 py-0.5 rounded-full bg-indigo-500/10 text-indigo-500 text-[9px] font-black uppercase tracking-wider border border-indigo-500/20">Local Ingestion</span>
                    </h3>
                    <p class="text-[11px] text-surface-500 font-medium mt-1 leading-relaxed max-w-xl">
                      สแกนไฟล์เอกสาร 'ใบเสร็จรับเงิน/ใบกำกับภาษี' และ 'สลิปโอนเงิน' ในโฟลเดอร์เครื่องเซิร์ฟเวอร์อัตโนมัติ เพื่อนำเข้าระบบ RAG และกระทบยอดบัญชีบน Google Sheets ทันที
                    </p>
                  </div>
                </div>
                
                <button id="startLocalScanBtn" class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white px-6 py-3 rounded-2xl font-black text-xs uppercase tracking-widest transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-indigo-500/20 flex items-center gap-2 shrink-0">
                  <i data-lucide="scan" class="w-4 h-4"></i> สแกนโฟลเดอร์ ภงด. 53
                </button>
              </div>

              <!-- Action Buttons -->
              <div class="flex justify-center gap-3">
                <button id="startReconBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-2xl font-black text-xs uppercase tracking-widest transition-all shadow-xl shadow-indigo-500/20 flex items-center gap-3">
                  <i data-lucide="play" class="w-4 h-4"></i> เริ่มการกระทบยอดข้อมูล
                </button>
                <button id="resetReconBtn" class="hidden bg-surface-200 dark:bg-surface-800 hover:bg-rose-100 dark:hover:bg-rose-900/30 text-surface-600 dark:text-surface-300 hover:text-rose-600 px-6 py-3 rounded-2xl font-black text-xs uppercase tracking-widest transition-all flex items-center gap-2">
                  <i data-lucide="rotate-ccw" class="w-4 h-4"></i> ล้างข้อมูล
                </button>
              </div>

              <!-- Summary Dashboard -->
              <div id="reconSummary" class="hidden space-y-4 animate-in fade-in slide-in-from-bottom-2">
                <!-- Row 1: Order Stats -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                  <div class="bg-white dark:bg-surface-900 p-5 rounded-2xl border border-surface-100 dark:border-surface-800 shadow-sm">
                    <div class="text-[9px] font-black text-surface-400 uppercase tracking-widest mb-1">รายการทั้งหมด</div>
                    <div id="reconStatTotal" class="text-2xl font-black text-surface-900 dark:text-white">0</div>
                  </div>
                  <div class="bg-white dark:bg-surface-900 p-5 rounded-2xl border border-surface-100 dark:border-surface-800 shadow-sm">
                    <div class="text-[9px] font-black text-emerald-500 uppercase tracking-widest mb-1">สถานะปกติ</div>
                    <div id="reconStatNormal" class="text-2xl font-black text-emerald-500">0</div>
                  </div>
                  <div class="bg-white dark:bg-surface-900 p-5 rounded-2xl border border-surface-100 dark:border-surface-800 shadow-sm border-l-4 border-l-rose-500">
                    <div class="text-[9px] font-black text-rose-500 uppercase tracking-widest mb-1">ต้องแก้ไข</div>
                    <div id="reconStatIssues" class="text-2xl font-black text-rose-600">0</div>
                  </div>
                  <div class="bg-white dark:bg-surface-900 p-5 rounded-2xl border border-surface-100 dark:border-surface-800 shadow-sm">
                    <div class="text-[9px] font-black text-amber-500 uppercase tracking-widest mb-1">ยกเลิก</div>
                    <div id="reconStatCancelled" class="text-2xl font-black text-amber-500">0</div>
                  </div>
                </div>
                <!-- Row 2: Financial Stats -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                  <div class="bg-gradient-to-br from-blue-50 to-blue-100/50 dark:from-blue-900/20 dark:to-blue-800/10 p-5 rounded-2xl border border-blue-200/50 dark:border-blue-800/30">
                    <div class="text-[9px] font-black text-blue-500 uppercase tracking-widest mb-1">💰 ยอดขาย Shipnity</div>
                    <div id="reconStatShipSales" class="text-lg font-black text-blue-700 dark:text-blue-400">฿0</div>
                  </div>
                  <div class="bg-gradient-to-br from-indigo-50 to-indigo-100/50 dark:from-indigo-900/20 dark:to-indigo-800/10 p-5 rounded-2xl border border-indigo-200/50 dark:border-indigo-800/30">
                    <div class="text-[9px] font-black text-indigo-500 uppercase tracking-widest mb-1">📄 มูลค่ารวมภาษี PEAK</div>
                    <div id="reconStatPeakAmount" class="text-lg font-black text-indigo-700 dark:text-indigo-400">฿0</div>
                  </div>
                  <div class="bg-gradient-to-br from-purple-50 to-purple-100/50 dark:from-purple-900/20 dark:to-purple-800/10 p-5 rounded-2xl border border-purple-200/50 dark:border-purple-800/30">
                    <div class="text-[9px] font-black text-purple-500 uppercase tracking-widest mb-1">🧾 ภาษีมูลค่าเพิ่ม</div>
                    <div id="reconStatPeakTax" class="text-lg font-black text-purple-700 dark:text-purple-400">฿0</div>
                  </div>
                  <div id="reconDiffCard" class="bg-gradient-to-br from-emerald-50 to-emerald-100/50 dark:from-emerald-900/20 dark:to-emerald-800/10 p-5 rounded-2xl border border-emerald-200/50 dark:border-emerald-800/30">
                    <div class="text-[9px] font-black text-emerald-500 uppercase tracking-widest mb-1">📊 ส่วนต่าง</div>
                    <div id="reconStatDiff" class="text-lg font-black text-emerald-700 dark:text-emerald-400">฿0</div>
                  </div>
                </div>
                <!-- Download Buttons -->
                <div class="flex justify-end gap-2">
                  <button id="downloadReconReportBtn" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-[10px] font-black uppercase transition-all">
                    <i data-lucide="download" class="w-3.5 h-3.5"></i> ดาวน์โหลด Excel ทั้งหมด
                  </button>
                  <button id="downloadFilteredBtn" class="flex items-center gap-2 px-4 py-2 bg-surface-200 dark:bg-surface-800 hover:bg-surface-300 dark:hover:bg-surface-700 rounded-xl text-[10px] font-black uppercase transition-all">
                    <i data-lucide="filter" class="w-3.5 h-3.5"></i> ดาวน์โหลดเฉพาะที่กรอง
                  </button>
                </div>
              </div>

              <!-- Data Table -->
              <div id="reconResultsArea" class="hidden bg-white dark:bg-surface-900 rounded-3xl border border-surface-100 dark:border-surface-800 shadow-xl overflow-hidden animate-in fade-in slide-in-from-bottom-4">
                <div class="p-6 border-b border-surface-100 dark:border-surface-800 space-y-4">
                  <div class="flex justify-between items-center">
                    <h3 class="font-black text-xs uppercase tracking-widest">รายละเอียดผลการตรวจสอบ</h3>
                    <span id="reconFilterCount" class="text-[10px] text-surface-400 font-bold">แสดง 0 / 0 รายการ</span>
                  </div>
                  <div class="relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400"></i>
                    <input type="text" id="reconSearchInput" placeholder="ค้นหา Order ID, Shipnity ID, Invoice..."
                      class="w-full pl-10 pr-4 py-2.5 bg-surface-50 dark:bg-surface-800 border-2 border-surface-100 dark:border-surface-700 rounded-xl text-xs focus:ring-4 focus:ring-indigo-600/10 focus:border-indigo-600 transition-all outline-none">
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <button data-recon-filter="all" class="recon-filter-btn active px-3 py-1.5 bg-surface-100 dark:bg-surface-800 rounded-lg text-[9px] font-black uppercase transition-all">ทั้งหมด</button>
                    <button data-recon-filter="issues" class="recon-filter-btn px-3 py-1.5 bg-rose-50 dark:bg-rose-900/20 text-rose-600 rounded-lg text-[9px] font-black uppercase transition-all">เฉพาะปัญหา</button>
                    <button data-recon-filter="normal" class="recon-filter-btn px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 rounded-lg text-[9px] font-black uppercase transition-all">ปกติ</button>
                    <div class="w-px h-6 bg-surface-200 dark:bg-surface-700 mx-1"></div>
                    <button data-recon-filter="cancelled" class="recon-filter-btn px-3 py-1.5 bg-amber-50 dark:bg-amber-900/20 text-amber-600 rounded-lg text-[9px] font-black uppercase transition-all">ยกเลิกแล้ว</button>
                    <button data-recon-filter="no-shipnity" class="recon-filter-btn px-3 py-1.5 bg-orange-50 dark:bg-orange-900/20 text-orange-600 rounded-lg text-[9px] font-black uppercase transition-all">ไม่พบใน Shipnity</button>
                    <button data-recon-filter="no-peak" class="recon-filter-btn px-3 py-1.5 bg-purple-50 dark:bg-purple-900/20 text-purple-600 rounded-lg text-[9px] font-black uppercase transition-all">ไม่มีใน PEAK</button>
                    <button data-recon-filter="amount-mismatch" class="recon-filter-btn px-3 py-1.5 bg-yellow-50 dark:bg-yellow-900/20 text-yellow-600 rounded-lg text-[9px] font-black uppercase transition-all">ยอดไม่ตรง</button>
                    <div class="w-px h-6 bg-surface-200 dark:bg-surface-700 mx-1"></div>
                    <select id="reconPlatformFilter" class="px-3 py-1.5 bg-surface-50 dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-lg text-[9px] font-black uppercase outline-none">
                      <option value="all">ทุกแพลตฟอร์ม</option>
                      <option value="Shopee">Shopee</option>
                      <option value="Lazada">Lazada</option>
                    </select>
                    <select id="reconBrandFilter" class="px-3 py-1.5 bg-surface-50 dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-lg text-[9px] font-black uppercase outline-none">
                      <option value="all">ทุกแบรนด์</option>
                      <option value="DUIT">DUIT</option>
                      <option value="Thumb Toe">Thumb Toe</option>
                      <option value="Bytuneller">Bytuneller</option>
                    </select>
                  </div>
                </div>
                <div class="overflow-x-auto max-h-[500px] custom-scrollbar">
                  <table class="w-full text-left border-collapse text-[11px]">
                    <thead class="sticky top-0 bg-surface-50 dark:bg-surface-800 z-10">
                      <tr>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">Order ID</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">ระบบขาย</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">แบรนด์</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">Shipnity ID</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">PEAK Invoice</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">สถานะ</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px] text-right">ยอด Shipnity</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px] text-right">ยอด PEAK</th>
                        <th class="p-3 font-black uppercase text-surface-400 text-[9px]">สรุปปัญหา</th>
                      </tr>
                    </thead>
                    <tbody id="reconResultsBody" class="divide-y divide-surface-100 dark:divide-surface-800">
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- LINE Management View -->
        <section id="view-line-manager" class="view hidden flex-1 flex flex-col overflow-hidden animate-in fade-in duration-300 bg-surface-50/50 dark:bg-surface-950/50 relative">
          <!-- Animated Background Elements -->
          <div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-[#00B900]/10 to-transparent pointer-events-none -z-10"></div>
          <div class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-[#00B900]/10 rounded-full blur-[100px] pointer-events-none -z-10"></div>
          
          <header class="h-16 border-b border-surface-200/50 dark:border-surface-800/50 flex items-center justify-between px-8 bg-white/60 dark:bg-surface-900/60 backdrop-blur-xl shrink-0 z-10 sticky top-0">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#00B900]/10 rounded-xl flex items-center justify-center text-[#00B900]">
                <i data-lucide="message-circle" class="w-5 h-5"></i>
              </div>
              <div>
                <h2 class="font-black text-base tracking-tight text-surface-900 dark:text-white leading-none mb-1">จัดการ LINE Official</h2>
                <div class="flex items-center gap-1.5 text-[10px] font-bold text-[#00B900] uppercase tracking-widest">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00B900] opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00B900]"></span>
                  </span>
                  เชื่อมต่อระบบแล้ว
                </div>
              </div>
