                    <h3 class="text-lg font-black tracking-tight flex items-center gap-2 text-surface-900 dark:text-white">
                      <i data-lucide="check-square" class="w-5 h-5 text-rose-600"></i> งานที่รอดำเนินการ
                    </h3>
                  </div>
                  <div id="dashTaskList" class="space-y-3">
                     <!-- Placeholder -->
                     <div class="p-4 bg-white dark:bg-surface-900 rounded-2xl border border-surface-100 dark:border-surface-800 flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-amber-500"></div>
                        <span class="text-sm font-medium text-surface-500">กำลังโหลดงาน...</span>
                     </div>
                  </div>
