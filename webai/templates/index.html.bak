<!DOCTYPE html>
<html lang="th" class="h-full h-[100dvh]">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="mobile-web-app-capable" content="yes">
  <title>OrgChat — Corporate AI Assistant</title>
  <script src="https://cdn.tailwindcss.com/3.4.16"></script>
  <script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script>
    window.onerror = function (m, u, l) { console.error("Early Error:", m, u, l); };
    if (typeof tailwind === 'undefined') {
      console.warn("Tailwind CDN not loaded yet. Waiting...");
    }
  </script>
  <script>
    if (typeof tailwind !== 'undefined') {
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: {
              brand: {
                50: '#f0f5ff', 100: '#e0ebff', 600: '#2563eb', 700: '#1d4ed8', 800: '#1e40af', 900: '#1e3a8a',
              },
              surface: {
                50: '#f8fafc', 100: '#f1f5f9', 200: '#e2e8f0', 300: '#cbd5e1', 400: '#94a3b8', 500: '#64748b', 600: '#475569', 700: '#334155', 800: '#1e293b', 900: '#0f172a', 950: '#020617',
              }
            },
            fontFamily: {
              sans: ['Inter', 'Sarabun', 'sans-serif'],
            },
          }
        }
      };
    }
  </script>
  <link rel="stylesheet" href="/static/style.css?v=2.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sarabun:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
  <script src="https://accounts.google.com/gsi/client"
    onload="if(typeof initGoogleSignIn === 'function') initGoogleSignIn()" async defer></script>
  <script>
    window.GOOGLE_CLIENT_ID = "{{ google_client_id if google_client_id else '' }}";
    window.VAPID_PUBLIC_KEY = "{{ vapid_public_key if vapid_public_key else '' }}";
  </script>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#2563eb" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="apple-touch-icon" href="/static/icon-192.png" />
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.workerRegistration = navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('PWA Service Worker registered:', reg.scope))
          .catch(err => console.error('PWA Service Worker registration failed:', err));
      });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mobile-drag-drop@2.3.0/index.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mobile-drag-drop@2.3.0/default.css">
</head>

<body class="h-full h-[100dvh] overflow-hidden dark:bg-surface-950 dark:text-surface-100">
  <!-- Login Overlay -->
  <div id="loginOverlay"
    class="fixed inset-0 z-[200] bg-surface-50 dark:bg-surface-950 flex items-center justify-center p-4">
    <div class="max-w-md w-full animate-in zoom-in duration-300">
      <div
        class="bg-white dark:bg-surface-900 rounded-3xl shadow-2xl border border-surface-200 dark:border-surface-800 overflow-hidden">
        <div class="p-8 pb-0 text-center">
          <div
            class="w-16 h-16 bg-brand-600 text-white rounded-2xl shadow-lg flex items-center justify-center mx-auto mb-6 transform -rotate-6">
            <i data-lucide="building-2" class="w-10 h-10"></i>
          </div>
          <h1 class="text-3xl font-black tracking-tight text-surface-900 dark:text-white mb-2">OrgChat</h1>
          <p class="text-surface-500 text-sm">เข้าสู่ระบบเพื่อใช้งานสมอง AI ขององค์กร</p>
        </div>
        <div class="p-8 space-y-4">
          <div class="space-y-1.5">
            <label class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">ชื่อผู้ใช้งาน</label>
            <div class="relative">
              <i data-lucide="user" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400"></i>
              <input id="loginUsername" type="text" placeholder="Username" class="input-field w-full pl-11 py-3" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label
              class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-1">รหัสผ่านพื้นฐาน</label>
            <div class="relative">
              <i data-lucide="lock" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400"></i>
              <input id="loginPassword" type="password" placeholder="••••••••" class="input-field w-full pl-11 py-3" />
            </div>
          </div>
          <div id="loginError"
            class="hidden animate-in fade-in slide-in-from-top-1 text-xs text-red-500 bg-red-50 dark:bg-red-900/10 p-3 rounded-xl border border-red-100 dark:border-red-800/50 flex items-center gap-2">
            <i data-lucide="alert-circle" class="w-4 h-4"></i>
            <span id="loginErrorMsg"></span>
          </div>
          <button id="loginBtn"
            class="btn-primary w-full py-3.5 rounded-2xl font-bold text-base shadow-lg shadow-brand-500/20 group">
            เข้าสู่ระบบองค์กร
            <i data-lucide="arrow-right"
              class="w-4 h-4 inline-block ml-1 group-hover:translate-x-1 transition-transform"></i>
          </button>

          <div class="flex items-center justify-between mt-1">
            <a href="/forgot-password" class="text-sm text-surface-400 hover:text-brand-600 hover:underline transition-colors">ลืมรหัสผ่าน?</a>
            <a href="/signup" class="text-sm font-bold text-brand-600 hover:text-brand-700 hover:underline transition-colors">
              สมัครใช้งานฟรี →
            </a>
          </div>

          <div class="relative flex items-center py-2 hidden" id="googleSignInSeparator">
            <div class="flex-grow border-t border-surface-200 dark:border-surface-700"></div>
            <span class="flex-shrink-0 mx-4 text-surface-400 text-xs">หรือเข้าระบบด้วย</span>
            <div class="flex-grow border-t border-surface-200 dark:border-surface-700"></div>
          </div>
          <div id="googleSignInBtn" class="w-full flex justify-center mt-2"></div>

          <!-- QR Login -->
          <div class="relative flex items-center py-2 mt-2">
            <div class="flex-grow border-t border-surface-200 dark:border-surface-700"></div>
            <span class="flex-shrink-0 mx-4 text-surface-400 text-xs">หรือ</span>
            <div class="flex-grow border-t border-surface-200 dark:border-surface-700"></div>
          </div>
          <button onclick="showQRLogin()" class="w-full py-3 rounded-2xl border-2 border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-bold text-sm hover:border-brand-500 hover:text-brand-600 transition-all flex items-center justify-center gap-3 group">
            <i data-lucide="qr-code" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
            แสดง QR Code (ให้มือถือสแกน)
          </button>
          <button onclick="openQRScanner()" class="w-full py-3 rounded-2xl border-2 border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-800 text-surface-700 dark:text-surface-200 font-bold text-sm hover:border-emerald-500 hover:text-emerald-600 transition-all flex items-center justify-center gap-3 group mt-2">
            <i data-lucide="camera" class="w-5 h-5 group-hover:scale-110 transition-transform"></i>
            เปิดกล้องสแกน QR Code
          </button>
        </div>

        <!-- QR Code Modal (inside login overlay) -->
        <div id="qrLoginModal" class="hidden">
          <div class="p-8 text-center">
            <button onclick="hideQRLogin()" class="absolute top-4 right-4 p-2 text-surface-400 hover:text-surface-600 transition-colors">
              <i data-lucide="arrow-left" class="w-5 h-5"></i>
            </button>
            <div class="w-16 h-16 bg-brand-50 dark:bg-brand-900/30 text-brand-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i data-lucide="qr-code" class="w-9 h-9"></i>
            </div>
            <h2 class="text-xl font-black text-surface-900 dark:text-white mb-1">QR Code Login</h2>
            <p class="text-surface-400 text-xs mb-6">เปิดกล้องมือถือสแกน QR นี้เพื่อเข้าสู่ระบบ</p>
            <div id="qrCodeContainer" class="bg-white p-6 rounded-2xl inline-block shadow-inner border border-surface-100 dark:border-surface-700 mb-4">
              <div id="qrCodeCanvas" class="mx-auto" style="width:200px;height:200px;"></div>
            </div>
            <div id="qrStatus" class="text-xs font-bold text-surface-400 flex items-center justify-center gap-2 mb-2">
              <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
              รอการสแกน...
            </div>
            <div id="qrTimer" class="text-[10px] text-surface-300 mb-4">หมดอายุใน <span id="qrCountdown">5:00</span></div>
            <button onclick="hideQRLogin()" class="text-xs text-brand-600 font-bold hover:underline">← กลับไปใช้ Username/Password</button>
          </div>
        </div>

        <div id="loginFooter" class="bg-surface-50 dark:bg-surface-800/50 p-6 text-center border-t border-surface-100 dark:border-surface-800">
          <p
            class="text-[10px] font-bold text-surface-400 uppercase tracking-widest flex items-center justify-center gap-2">
            <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
            Secure Enterprise Gateway
          </p>
        </div>
      </div>
    </div>
  </div>
  <!-- QR Scanner Modal (Full Screen Camera) -->
  <div id="qrScannerModal" class="fixed inset-0 z-[300] bg-black hidden">
    <div class="relative flex-1 flex flex-col h-screen">
      <div class="absolute top-0 left-0 right-0 z-10 p-4 flex items-center justify-between bg-gradient-to-b from-black/80 to-transparent">
        <button onclick="closeQRScanner()" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-lg flex items-center justify-center text-white">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
        <span class="text-white font-bold text-sm">สแกน QR Code</span>
        <div class="w-10"></div>
      </div>
      <div id="qrScannerView" class="w-full h-full"></div>
      <div class="absolute bottom-0 left-0 right-0 z-10 p-6 text-center bg-gradient-to-t from-black/80 to-transparent">
        <p class="text-white/90 text-sm font-bold mb-1">เล็งกล้องไปที่ QR Code บนหน้าจอ Desktop</p>
        <p class="text-white/50 text-xs">QR จะถูกสแกนอัตโนมัติ</p>
      </div>
    </div>
  </div>
  <div id="apiModal"
    class="fixed inset-0 z-[9999] bg-black/40 backdrop-blur-sm hidden">
    <div
      class="bg-white dark:bg-surface-900 w-full h-full sm:w-[90%] sm:max-w-md sm:h-auto p-8 sm:rounded-xl shadow-2xl border-0 sm:border border-surface-100 dark:border-surface-800 text-center flex flex-col justify-center">
      <div
        class="w-16 h-16 bg-brand-50 dark:bg-brand-900/30 text-brand-600 rounded-full flex items-center justify-center mx-auto mb-4">
        <i data-lucide="key-round" class="w-8 h-8"></i>
      </div>
      <h2 class="text-xl font-bold mb-2">Google Gemini API Key</h2>
      <p class="text-surface-500 text-sm mb-6">กรุณาใส่ API Key ของคุณเพื่อเริ่มต้นใช้งานระบบอัจฉริยะองค์กร</p>
      <div class="relative mb-4">
        <input id="apiKeyInput" type="password" placeholder="AIza..." class="input-field w-full" />
        <button id="apiKeyToggle"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-surface-400 hover:text-surface-600">
          <i data-lucide="eye" class="w-4 h-4"></i>
        </button>
      </div>
      <button id="saveApiKeyBtn" class="btn-primary w-full mt-2">ยืนยันและเริ่มต้น</button>
      <p class="text-[10px] text-surface-400 mt-6 flex items-center justify-center gap-1.5 grayscale opacity-70">
        <i data-lucide="shield-check" class="w-3 h-3"></i> รหัสของคุณจะถูกเก็บไว้ปลอดภัยในเครื่องเท่านั้น
      </p>
    </div>
  </div>

  <div id="csvEditorModal"
    class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/50 backdrop-blur-md hidden">
    <div
      class="bg-white dark:bg-surface-900 w-full h-full sm:w-[95%] sm:max-w-6xl sm:h-[85vh] flex flex-col sm:rounded-2xl shadow-2xl border-0 sm:border border-surface-200 dark:border-surface-800">
      <header class="p-6 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold flex items-center gap-2">
            <i data-lucide="table-2" class="w-6 h-6 text-brand-600"></i>
            <span>แก้ไขไฟล์: <span id="editingFileName" class="text-surface-500">...</span></span>
          </h2>
          <p class="text-xs text-surface-400 mt-1">คุณสามารถแก้ไขข้อมูลในตารางแล้วกดบันทึกเพื่ออัปเดตสมอง AI ได้ทันที
          </p>
        </div>
        <button id="closeCsvEditor"
          class="p-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-lg transition-colors">
          <i data-lucide="x" class="w-6 h-6"></i>
        </button>
      </header>
      <div id="csvTableContainer" class="flex-1 overflow-auto p-2 bg-surface-50 dark:bg-surface-950/20">
        <table id="csvDataTable" class="w-full border-collapse bg-white dark:bg-surface-900 text-sm">
          <thead id="csvHeaders" class="sticky top-0 bg-surface-100 dark:bg-surface-800 z-10"></thead>
          <tbody id="csvBody"></tbody>
        </table>
      </div>
      <footer
        class="p-6 border-t border-surface-100 dark:border-surface-800 flex items-center justify-between bg-white dark:bg-surface-900 rounded-b-2xl">
        <div class="text-xs text-surface-400">
          <span id="csvStatusInfo">แถวทั้งหมด: 0</span>
        </div>
        <div class="flex gap-3">
          <button id="addRowBtn" class="btn-secondary flex items-center gap-2 text-xs">
            <i data-lucide="plus" class="w-3 h-3"></i> เพิ่มแถว
          </button>
          <button id="saveCsvBtn" class="btn-primary min-w-[120px]">
            <i data-lucide="save" class="w-4 h-4"></i> บันทึกข้อมูล
          </button>
        </div>
      </footer>
    </div>
  </div>

  <div id="txtEditorModal"
    class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/50 backdrop-blur-md hidden">
    <div
      class="bg-white dark:bg-surface-900 w-full h-full sm:w-[90%] sm:max-w-4xl sm:h-[80vh] flex flex-col sm:rounded-2xl shadow-2xl border-0 sm:border border-surface-200 dark:border-surface-800">
      <header
        class="h-16 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between px-8 bg-surface-50/50 dark:bg-surface-900/50 rounded-t-2xl">
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 bg-brand-50 dark:bg-brand-900/30 text-brand-600 rounded-xl flex items-center justify-center">
            <i data-lucide="file-text" class="w-5 h-5"></i>
          </div>
          <div>
            <h2 class="font-bold text-base leading-none mb-1" id="txtEditorTitle">แก้ไขไฟล์ข้อความ</h2>
            <p class="text-[10px] text-surface-400 font-bold uppercase tracking-widest">Text Editor • Auto Re-indexing
            </p>
          </div>
        </div>
        <button onclick="txtEditorModal.classList.add('hidden'); txtEditorModal.classList.remove('flex', 'items-center', 'justify-center')"
          class="p-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-full transition-colors text-surface-400">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </header>
      <div class="flex-1 p-6 bg-white dark:bg-surface-950 overflow-hidden">
        <textarea id="txtEditorContent"
          class="w-full h-full bg-transparent border-none outline-none resize-none font-mono text-sm leading-relaxed text-surface-700 dark:text-surface-300 p-4 rounded-xl border border-surface-100 dark:border-surface-800 focus:ring-2 focus:ring-brand-600/20"
          placeholder="พิมพ์เนื้อหาที่นี่..."></textarea>
      </div>
      <footer
        class="p-6 border-t border-surface-100 dark:border-surface-800 flex items-center justify-between bg-white dark:bg-surface-900 rounded-b-2xl">
        <div class="text-xs text-surface-400 font-medium italic">* การบันทึกจะทำให้ AI เรียนรู้ข้อมูลใหม่ทันที</div>
        <div class="flex gap-3">
          <button onclick="txtEditorModal.classList.add('hidden'); txtEditorModal.classList.remove('flex', 'items-center', 'justify-center')" class="btn-secondary">ยกเลิก</button>
          <button id="saveTxtBtn" class="btn-primary min-w-[120px]">
            <i data-lucide="save" class="w-4 h-4"></i> บันทึกข้อมูล
          </button>
        </div>
      </footer>
    </div>
  </div>

  <!-- Image Lightbox Modal -->
  <div id="imageLightbox"
    class="fixed inset-0 z-[300] bg-black/90 backdrop-blur-xl flex items-center justify-center p-4 md:p-10 hidden animate-in fade-in duration-300">
    <div class="absolute top-6 right-6 flex items-center gap-4 z-10">
      <a id="lightboxDownload" href="#" download
        class="p-3 bg-white/10 hover:bg-white/20 text-white rounded-full transition-colors backdrop-blur-md border border-white/20 group"
        title="ดาวน์โหลดรูปภาพ">
        <i data-lucide="download" class="w-6 h-6 group-hover:scale-110 transition-transform"></i>
      </a>
      <button onclick="closeLightbox()"
        class="p-3 bg-white/10 hover:bg-white/20 text-white rounded-full transition-colors backdrop-blur-md border border-white/20 group"
        title="ปิด">
        <i data-lucide="x" class="w-6 h-6 group-hover:rotate-90 transition-transform"></i>
      </button>
    </div>
    <div class="relative max-w-full max-h-full flex items-center justify-center">
      <img id="lightboxImage" src=""
        class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl animate-in zoom-in duration-500">
    </div>
  </div>

  <div class="flex h-full relative overflow-hidden">
    <!-- Mobile Sidebar Overlay -->
    <div id="sidebarOverlay" class="sidebar-overlay"></div>
    <aside id="navSidebar"
      class="w-64 flex-shrink-0 bg-white dark:bg-surface-900 border-r border-surface-200 dark:border-surface-800 flex flex-col h-full z-50">
      <div class="p-6 border-b border-surface-100 dark:border-surface-800 flex items-center justify-between logo-container">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-brand-600 text-white rounded flex items-center justify-center flex-shrink-0">
            <i data-lucide="building-2" class="w-5 h-5"></i>
          </div>
          <span class="font-bold text-lg tracking-tight logo-text">OrgChat</span>
        </div>
        <button id="sidebarCollapseBtn" class="flex items-center justify-center w-8 h-8 rounded-lg text-surface-400 hover:text-brand-600 hover:bg-brand-50 dark:hover:bg-brand-900/20 transition-all border border-surface-100 dark:border-surface-800 flex-shrink-0" title="หุบ/กางเมนู">
          <i data-lucide="chevron-left" class="w-5 h-5 transition-transform duration-300" id="collapseBtnIcon"></i>
        </button>
      </div>
      <div id="sidebarUserBox"
        class="p-4 mx-4 my-2 bg-surface-50 dark:bg-surface-800/50 rounded-2xl border border-surface-100 dark:border-surface-700 flex items-center gap-3 cursor-pointer hover:bg-surface-100 dark:hover:bg-surface-800 transition-colors"
        onclick="showView('profile')">
        <div id="sidebarAvatar"
          class="w-10 h-10 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-brand-600 overflow-hidden">
          <i data-lucide="user" class="w-5 h-5"></i>
        </div>
        <div class="flex-1 min-w-0 user-info">
          <p id="sidebarDisplayName" class="text-sm font-bold truncate">Loading...</p>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span id="sidebarUserRole" class="text-[9px] text-surface-400 font-bold uppercase tracking-widest">Member</span>
            <span id="sidebarPlanBadge" class="hidden px-1.5 py-0.5 rounded text-[8px] font-extrabold uppercase tracking-wider">FREE</span>
          </div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-1 overflow-y-auto custom-scrollbar">
        <button class="nav-item w-full active relative" data-view="home" id="nav-home">
          <i data-lucide="home" class="w-4 h-4"></i> <span>หน้าหลัก</span>
        </button>
        <button class="nav-item w-full" onclick="openMobileChat()" id="nav-messages">
          <i data-lucide="messages-square" class="w-4 h-4 text-brand-600"></i> <span>ข้อความ</span>
        </button>
        <button class="nav-item w-full" data-view="chat" id="nav-chat">
          <i data-lucide="sparkles" class="w-4 h-4 text-brand-600"></i> <span>แชทผู้ช่วย AI</span>
        </button>
        <button class="nav-item w-full" data-view="kb" id="nav-kb">
          <i data-lucide="folder-open" class="w-4 h-4"></i> <span>คลังข้อมูล</span>
        </button>
        <button class="nav-item w-full" data-view="calendar" id="nav-calendar">
          <i data-lucide="calendar" class="w-4 h-4"></i> <span>ปฏิทินกิจกรรม</span>
        </button>
        <button class="nav-item w-full" data-view="leave" id="nav-leave">
          <i data-lucide="log-out" class="w-4 h-4 text-rose-500"></i> <span>ระบบลางาน</span>
        </button>
        <button class="nav-item w-full" data-view="dashboard" id="nav-dashboard">
          <i data-lucide="wallet" class="w-4 h-4 text-emerald-600"></i> <span>แดชบอร์ดรายจ่าย</span>
        </button>
        <!-- --- Others Collapsible --- -->
        <div class="mt-4 pt-4 border-t border-surface-100 dark:border-surface-800 others-group">
          <button onclick="document.getElementById('othersMenu').classList.toggle('hidden'); document.getElementById('othersIcon').classList.toggle('rotate-180');" 
                  class="flex items-center justify-between w-full px-3 py-2 text-[10px] font-bold text-surface-400 hover:text-brand-600 transition-all uppercase tracking-widest group others-title">
            <span>เครื่องมืออื่นๆ</span>
            <i data-lucide="chevron-down" class="w-3 h-3 transition-transform duration-300" id="othersIcon"></i>
          </button>
          
          <div id="othersMenu" class="hidden flex flex-col gap-1 mt-2">
            <button class="nav-item w-full" data-view="search" id="nav-search">
              <i data-lucide="search" class="w-4 h-4"></i> <span>ค้นหาอัจฉริยะ</span>
            </button>
            <button class="nav-item w-full" data-view="viz" id="nav-viz">
              <i data-lucide="line-chart" class="w-4 h-4 text-indigo-500"></i> <span>วิเคราะห์ข้อมูล</span>
            </button>
            <button class="nav-item w-full" data-view="csv-explorer" id="nav-csv-explorer">
              <i data-lucide="file-spreadsheet" class="w-4 h-4 text-emerald-500"></i> <span>สำรวจข้อมูล CSV</span>
            </button>
            <button class="nav-item w-full" data-view="summary" id="nav-summary">
              <i data-lucide="sparkles" class="w-4 h-4"></i> <span>สรุปอัจฉริยะ</span>
            </button>
            <button class="nav-item w-full" data-view="feed" id="nav-feed">
              <i data-lucide="layout-list" class="w-4 h-4"></i> <span>ฟีดกิจกรรม</span>
            </button>
            <button class="nav-item w-full" data-view="kanban" id="nav-kanban">
              <i data-lucide="layout-dashboard" class="w-4 h-4"></i> <span>Kanban Board</span>
            </button>
            <button class="nav-item w-full" data-view="wiki" id="nav-wiki">
              <i data-lucide="book-open" class="w-4 h-4"></i> <span>Internal Wiki</span>
            </button>
            <button class="nav-item w-full" data-view="drive" id="nav-drive" onclick="showView('drive')">
              <i data-lucide="cloud" class="w-4 h-4 text-sky-500"></i> <span>Google Drive</span>
            </button>
            <button class="nav-item w-full" data-view="whiteboard" id="nav-whiteboard" onclick="showView('whiteboard')">
              <i data-lucide="palette" class="w-4 h-4"></i> <span>ไวท์บอร์ด</span>
            </button>
            <button class="nav-item w-full" data-view="quotation" id="nav-quotation" onclick="showView('quotation')">
              <i data-lucide="file-signature" class="w-4 h-4 text-orange-500"></i> <span>ใบเสนอราคา</span>
            </button>
          </div>
        </div>
        <!-- Removed redundant sidebar entry for group chat -->
        <!-- Redundant Profile Link Removed -->
        <div class="pt-4 pb-2 text-[10px] font-bold text-surface-400 uppercase tracking-widest px-4 system-title">ระบบ</div>
        <button class="nav-item w-full" data-view="settings" id="nav-settings" onclick="showView('settings')">
          <i data-lucide="settings" class="w-4 h-4"></i> <span>การตั้งค่า</span>
        </button>
        <button class="nav-item w-full" data-view="stats" id="nav-stats" onclick="showView('stats')">
          <i data-lucide="bar-chart-3" class="w-4 h-4"></i> <span>สถิติองค์กร</span>
        </button>
        <!-- Admin-only buttons (shown only to admin role) -->
        <button class="nav-item w-full {{ '' if is_admin else 'hidden' }} text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900/10"
          data-view="admin" id="nav-admin" onclick="showView('admin')">
          <i data-lucide="shield-check" class="w-4 h-4"></i> <span>แผงควบคุม</span>
        </button>
        <a href="/admin/customers" class="nav-item w-full {{ '' if is_admin else 'hidden' }} text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900/10" style="text-decoration:none">
          <i data-lucide="users" class="w-4 h-4"></i> <span>จัดการลูกค้า</span>
        </a>
        <!-- Super Admin-only button -->
        <a href="/admin/super" class="nav-item w-full {{ '' if is_superadmin else 'hidden' }} text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-900/10 font-bold" style="text-decoration:none" id="nav-super-admin">
          <i data-lucide="crown" class="w-4 h-4"></i> <span>แผงควบคุมระบบ (Super Admin)</span>
        </a>
        <button class="nav-item w-full {{ '' if is_admin else 'hidden' }} text-green-600 hover:bg-green-50 dark:hover:bg-green-900/10"
          data-view="line-groups" id="nav-line-groups" onclick="showView('line-groups'); loadLineGroups()">
          <i data-lucide="message-square" class="w-4 h-4"></i> <span>LINE Groups</span>
        </button>
        <button class="nav-item w-full hidden text-indigo-600 hover:bg-indigo-50 dark:hover:bg-indigo-900/10"
          data-view="reconciliation" id="nav-reconciliation">
          <i data-lucide="scale" class="w-4 h-4"></i> <span>ระบบกระทบยอด</span>
        </button>
        <button class="nav-item w-full hidden text-green-600 hover:bg-green-50 dark:hover:bg-green-900/10"
          data-view="line-manager" id="nav-line-manager" onclick="showView('line-manager')">
          <i data-lucide="message-circle" class="w-4 h-4"></i> <span>จัดการ LINE</span>
        </button>
        <button id="logoutBtn" class="nav-item w-full text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10">
          <i data-lucide="log-out" class="w-4 h-4"></i> <span>ออกจากระบบ</span>
        </button>
      </nav>
      <div class="p-4 border-t border-surface-100 dark:border-surface-800">
        <button id="themeToggle" class="nav-item w-full text-sm">
          <i data-lucide="moon" id="themeIcon" class="w-4 h-4"></i>
          <span id="themeText">โหมดกลางคืน</span>
        </button>
        <div class="mt-4 flex items-center gap-2">
          <button id="nav-notifications" data-view="notifications"
            class="nav-item p-2 w-auto bg-surface-50 dark:bg-surface-800 rounded-xl border border-surface-100 dark:border-surface-700 text-surface-400 hover:text-brand-600 transition-colors relative"
            onclick="showView('notifications')" title="การแจ้งเตือน">
            <i data-lucide="bell" class="w-4 h-4"></i>
            <span id="navNotifBadge"
              class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[9px] font-black rounded-full flex items-center justify-center hidden border-2 border-white dark:border-surface-900">0</span>
          </button>
          <div
            class="flex-1 px-4 py-2 bg-surface-50 dark:bg-surface-800 rounded-xl border border-surface-100 dark:border-surface-700 flex items-center justify-between">
            <span class="text-[11px] font-bold text-surface-400 tracking-wide leading-none">เวลาปัจจุบัน</span>
            <span id="realtimeClock" class="text-xs font-mono font-bold text-brand-600 leading-none">00:00:00</span>
          </div>
        </div>
      </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <!-- Mobile Top Header -->
      <header
        class="mobile-header hidden items-center justify-between px-4 h-14 bg-white dark:bg-surface-900 border-b border-surface-100 dark:border-surface-800 sticky top-0 z-50">
        <button id="mobileMenuBtn"
          class="p-2 -ml-2 hover:bg-surface-100 dark:hover:bg-surface-800 rounded-lg transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center">
          <i data-lucide="menu" class="w-6 h-6"></i>
        </button>
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 bg-brand-600 text-white rounded-lg flex items-center justify-center shadow-lg">
            <i data-lucide="sparkles" class="w-4 h-4"></i>
          </div>
          <span class="font-bold text-base tracking-tight">OrgChat</span>
          <span id="mobilePlanBadge" class="hidden px-1.5 py-0.5 rounded text-[8px] font-extrabold uppercase tracking-wider">FREE</span>
        </div>
        <div id="statusBadgeMobile" class="scale-75 origin-right"></div>
      </header>

      <main class="flex-1 flex flex-col min-w-0 bg-white dark:bg-surface-950 overflow-hidden">
        <!-- Chat View -->
        <section id="view-chat"
          class="view hidden flex-1 flex flex-col items-center overflow-hidden animate-in fade-in duration-300">
          <header
            class="h-14 border-b border-surface-100 dark:border-surface-800 hidden lg:flex items-center justify-between px-6 bg-white dark:bg-surface-900 sticky top-0 z-10 w-full">
            <div class="flex items-center gap-2">
              <h2 class="font-semibold text-sm">การสนทนาปัจจุบัน</h2>
              <div id="statusBadge"
                class="flex items-center gap-1.5 px-2 py-0.5 rounded bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold border border-emerald-100 dark:border-emerald-800">
                <span class="w-1 h-1 rounded-full bg-emerald-500"></span> พร้อมทำงาน
              </div>
            </div>
            <div class="flex items-center gap-1">
              <button id="exportBtn" class="p-2 text-surface-400 hover:text-surface-600 rounded-md transition-colors"
                title="Export Markdown"><i data-lucide="download" class="w-4 h-4"></i></button>
              <button id="clearChatBtn" class="p-2 text-surface-400 hover:text-red-600 rounded-md transition-colors"
                title="Clear Chat"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
            </div>
          </header>

          <div id="mainChat" class="flex-1 min-h-0 overflow-y-auto w-full max-w-4xl p-4 lg:p-6 space-y-4 custom-scrollbar">
            <!-- Messages will be injected here -->
          </div>

          <!-- Typing Indicator (Main Chat) -->
          <div id="mainTypingIndicator" class="px-6 py-2 hidden">
            <div class="flex items-center gap-2 text-surface-400">
              <div class="meta-typing">
                <span></span><span></span><span></span>
              </div>
              <span class="text-[10px] italic" id="mainTypingText">กำลังพิมพ์...</span>
            </div>
          </div>
          <div id="chatInputContainer" class="w-full max-w-4xl p-4 mb-2">
            <div id="suggestions"
              class="flex items-center justify-start lg:justify-center gap-2 mb-3 overflow-x-auto no-scrollbar py-1 px-4">
              <button class="quick-action-chip" data-q="สรุปความเคลื่อนไหววันนี้ให้หน่อย">
                <i data-lucide="sparkles" class="w-3.5 h-3.5"></i> สรุปวันนี้
              </button>
              <button class="quick-action-chip" data-q="พรุ่งนี้ฉันมีประชุมหรือนัดหมายอะไรบ้าง">
                <i data-lucide="calendar-clock" class="w-3.5 h-3.5"></i> เช็คคิวพรุ่งนี้
              </button>
              <button class="quick-action-chip" data-q="ร่างประกาศข่าวกิจกรรมบริษัทให้หน่อย">
                <i data-lucide="megaphone" class="w-3.5 h-3.5"></i> ร่างประกาศ
              </button>
              <button class="quick-action-chip" data-q="ช่วยสรุปไฟล์ PDF ล่าสุดที่ฉันอัปโหลด">
                <i data-lucide="file-text" class="w-3.5 h-3.5"></i> สรุปไฟล์ล่าสุด
              </button>
            </div>
            <div
              class="relative bg-white dark:bg-surface-900 border border-surface-200 dark:border-surface-800 rounded-xl shadow-sm focus-within:ring-2 focus-within:ring-brand-600/20 transition-all">
              <div class="flex items-end px-3 py-1.5 flex-col">
                <!-- AI Vision Image Preview -->
                <div id="chatImagePreview" class="hidden w-full px-2 py-2 flex items-center gap-2 border-b border-surface-100 dark:border-surface-800">
                  <div class="relative group">
                    <img id="chatImageThumbnail" src="" class="w-12 h-12 rounded-lg object-cover border border-surface-200 shadow-sm">
                    <button id="removeChatImage" class="absolute -top-1.5 -right-1.5 bg-red-500 text-white rounded-full p-0.5 shadow-md hover:bg-red-600 transition-colors">
                      <i data-lucide="x" class="w-3 h-3"></i>
                    </button>
                  </div>
                  <span class="text-[10px] text-surface-400 font-medium">แนบรูปภาพสำหรับ AI วิเคราะห์</span>
                </div>

                <div class="flex items-end w-full">
                  <textarea id="msgInput" rows="1" placeholder="พิมพ์ข้อถามหรือสิ่งที่ต้องการค้นหา..."
                    class="flex-1 bg-transparent border-none focus:ring-0 text-sm py-2 px-1 resize-none max-h-32 outline-none"></textarea>
                  <div class="relative group mb-1 mr-1">
                    <button id="personaBtn"
                      class="p-2 text-surface-400 hover:text-brand-600 rounded-lg transition-all flex items-center gap-1.5"
                      title="เลือกตัวตน AI">
                      <i data-lucide="bot" class="w-4 h-4"></i>
                      <span id="activePersonaName" class="text-[10px] font-bold hidden md:inline">Default</span>
                    </button>
                    <div id="personaDropdown"
                      class="hidden absolute bottom-full right-0 mb-2 w-48 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-xl shadow-xl z-50 p-2 animate-in fade-in slide-in-from-bottom-2 duration-200">
                      <div class="text-[10px] font-black uppercase tracking-widest text-surface-400 px-2 py-1 mb-1">AI
                        Personas</div>
                      <div id="personaList" class="space-y-1 max-h-48 overflow-y-auto custom-scrollbar">
                        <!-- Personas injected here -->
                      </div>
                    </div>
                  </div>
                  <input type="file" id="chatImageInput" class="hidden" accept="image/*">
                  <button id="chatAttachBtn"
                    class="mb-1 p-2 mr-1 text-surface-400 hover:text-brand-600 rounded-lg transition-all"
                    title="แนบรูปภาพภาพ"><i data-lucide="camera" class="w-4 h-4"></i></button>
                  <button id="autoSpeakBtn"
                    class="mb-1 p-2 mr-1 text-surface-400 hover:text-brand-600 rounded-lg transition-all"
                    title="อ่านข้อความอัตโนมัติ (Auto-Speak)">
                    <i data-lucide="volume-2" class="w-4 h-4"></i>
                  </button>
                  <button id="voiceBtn"
                    class="mb-1 p-2 mr-1 text-surface-400 hover:text-brand-600 rounded-lg transition-all"
                    title="สั่งงานด้วยเสียง"><i data-lucide="mic" class="w-4 h-4"></i></button>
                  <button id="sendBtn"
                    class="mb-1 p-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 shadow-sm transition-colors disabled:opacity-50"><i
                      data-lucide="send" class="w-4 h-4"></i></button>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Home Dashboard View (Smart Dashboard) -->
        <section id="view-home" class="view hidden flex-1 flex flex-col items-center overflow-y-auto custom-scrollbar animate-in fade-in duration-500 bg-surface-50/50 dark:bg-surface-950/50">
          <div class="w-full max-w-[1600px] p-6 lg:p-10 space-y-10">
            
            <!-- Dashboard Header -->
            <header class="w-full flex items-center justify-between mb-2 animate-in fade-in slide-in-from-top-4 duration-700">
              <div>
                <h2 class="text-2xl font-black text-surface-900 dark:text-white tracking-tight">Smart Dashboard</h2>
                <p class="text-xs text-surface-400 font-bold uppercase tracking-widest mt-1">Real-time Intelligence & Operations</p>
              </div>
              <div class="flex items-center gap-3">
                <button onclick="loadDashboard()" class="p-2.5 bg-white dark:bg-surface-900 text-surface-600 dark:text-surface-400 rounded-2xl border border-surface-100 dark:border-surface-800 hover:bg-brand-50 dark:hover:bg-brand-900/20 hover:text-brand-600 transition-all shadow-sm group">
                  <i data-lucide="refresh-cw" class="w-4 h-4 group-active:rotate-180 transition-transform duration-500"></i>
                </button>
                <div id="dashSystemStatus" class="hidden md:flex items-center gap-2 px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 rounded-full border border-emerald-100 dark:border-emerald-800">
                  <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                  <span id="dashSystemStatusText" class="text-[10px] font-black uppercase tracking-widest">System Live</span>
                </div>
              </div>
            </header>

            <!-- 🌟 AI Hero Section (Daily Intelligence) -->
            <div class="w-full">
              <!-- Full Width: Greeting & Briefing -->
              <div class="relative overflow-hidden rounded-[3rem] bg-gradient-to-br from-brand-600 to-indigo-700 p-8 md:p-12 text-white shadow-2xl shadow-brand-600/20">
                <div class="absolute top-0 right-0 p-12 opacity-10 pointer-events-none">
                  <i data-lucide="sparkles" class="w-48 h-48"></i>
                </div>
                <div class="relative z-10 space-y-6">
                  <div class="flex items-center gap-3">
                    <div class="p-2 bg-white/20 backdrop-blur-md rounded-2xl">
                      <i data-lucide="zap" class="w-4 h-4 text-yellow-300"></i>
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-widest text-brand-100">สรุปข่าวสารโดยน้องพั้นซ์</span>
                  </div>
                  <div class="max-w-3xl space-y-4">
                    <h1 class="text-3xl md:text-5xl font-black tracking-tight leading-tight" id="dashGreeting">
                      Good Morning, User
                    </h1>
                    <p class="text-base md:text-xl text-brand-50/80 font-medium leading-relaxed italic" id="dashAISummary">
                      คุณมีกำหนดการสำคัญ 3 อย่างในวันนี้ และมีความเคลื่อนไหวใหม่ในแผนกของคุณ...
                    </p>
                  </div>
                  <div class="flex gap-4 pt-4">
                    <button onclick="showView('chat')" class="px-8 py-3 bg-white text-brand-700 rounded-2xl text-sm font-black hover:bg-brand-50 transition-all shadow-xl flex items-center gap-2">
                      <i data-lucide="message-square" class="w-4 h-4"></i> ถาม AI
                    </button>
                    <button onclick="loadDashboard()" class="px-8 py-3 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-2xl text-sm font-black hover:bg-white/20 transition-all flex items-center gap-2">
                      <i data-lucide="refresh-cw" class="w-4 h-4"></i> รีเฟรช
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- 🌦️ Weather Widget -->
            <div id="weatherCard" class="glass p-6 rounded-[2.5rem] border border-surface-100 dark:border-surface-100/10 bg-white/70 dark:bg-surface-900/70 shadow-xl shadow-brand-500/5 hover:shadow-brand-500/10 hover:-translate-y-1 transition-all cursor-pointer group flex flex-col md:flex-row items-center justify-between gap-6" onclick="showWeatherDetail()">
              <div class="flex items-center gap-6 w-full md:w-auto">
                <div id="weatherIconContainer" class="w-20 h-20 bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-900/30 dark:to-indigo-900/30 text-brand-600 rounded-3xl flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform duration-500">
                  <i data-lucide="cloud-sun" id="mainWeatherIcon" class="w-12 h-12"></i>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <i data-lucide="map-pin" class="w-3 h-3 text-brand-600"></i>
                    <span class="text-[11px] font-black uppercase tracking-widest text-surface-400">Bangkok, Thailand</span>
                    <span class="mx-1 text-surface-200">|</span>
                    <span id="weatherLastUpdate" class="text-[9px] font-bold text-surface-300">--:--</span>
                  </div>
                  <div class="flex items-baseline gap-3">
                    <span id="currentTemp" class="text-5xl font-black tracking-tighter text-surface-900 dark:text-white">--°C</span>
                    <div class="flex flex-col">
                      <span id="weatherCondition" class="text-sm font-black text-surface-600 dark:text-surface-300">กำลังโหลด...</span>
                      <span id="rainChance" class="text-[10px] font-bold text-blue-500 flex items-center gap-1">
                        <i data-lucide="droplets" class="w-3 h-3"></i> โอกาสฝน --%
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              
              <div class="flex items-center gap-3 w-full md:w-auto justify-between md:justify-end border-t md:border-t-0 border-surface-100 dark:border-surface-800 pt-4 md:pt-0">
                <div class="flex flex-col items-end px-4 border-r border-surface-100 dark:border-surface-800">
                  <span class="text-[9px] font-black text-surface-400 uppercase tracking-widest mb-0.5">Feels Like</span>
                  <span id="dashFeelsLike" class="text-sm font-black text-surface-700 dark:text-surface-200">--°C</span>
                </div>
                <div class="flex flex-col items-center px-4 border-r border-surface-100 dark:border-surface-800">
                  <span class="text-[9px] font-black text-surface-400 uppercase tracking-widest mb-0.5">UV Index</span>
                  <span id="dashUV" class="text-sm font-black text-emerald-500">--</span>
                </div>
                <div class="flex flex-col items-center px-4 border-r border-surface-100 dark:border-surface-800">
                  <span class="text-[9px] font-black text-surface-400 uppercase tracking-widest mb-0.5">PM 2.5</span>
                  <span id="dashPM25" class="text-sm font-black text-emerald-500">--</span>
                </div>
                <div class="flex flex-col items-end px-4">
                  <span class="text-[9px] font-black text-surface-400 uppercase tracking-widest mb-0.5">Humidity</span>
                  <span id="dashHumidity" class="text-sm font-black text-surface-700 dark:text-surface-200">--%</span>
                </div>
                <button onclick="event.stopPropagation(); fetchWeather();" class="w-10 h-10 rounded-2xl bg-surface-50 dark:bg-surface-800 text-surface-400 flex items-center justify-center hover:bg-brand-50 dark:hover:bg-brand-900/30 hover:text-brand-600 transition-all ml-2" title="Refresh Weather">
                  <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                </button>
                <div class="w-10 h-10 rounded-2xl bg-brand-600 text-white flex items-center justify-center shadow-lg group-hover:rotate-12 transition-all">
                  <i data-lucide="chevron-right" class="w-5 h-5"></i>
                </div>
              </div>
            </div>

            <!-- 🍱 Lunch & Tips Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <!-- Lunch Randomizer Card -->
              <div class="glass p-8 rounded-[2.5rem] border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-xl overflow-hidden group">
                <div class="flex items-center justify-between mb-6">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 bg-rose-50 dark:bg-rose-900/30 text-rose-600 rounded-2xl flex items-center justify-center group-hover:rotate-12 transition-transform">
                      <i data-lucide="dice-5" class="w-6 h-6"></i>
                    </div>
                    <div>
                      <h3 class="text-lg font-black text-surface-900 dark:text-white">Lunch Randomizer</h3>
                      <p class="text-[10px] text-surface-400 font-bold uppercase tracking-widest">เที่ยงนี้กินอะไรดี?</p>
                    </div>
                  </div>
                  <button onclick="openLunchModal()" class="p-2 text-surface-400 hover:text-rose-600 transition-colors">
                    <i data-lucide="settings" class="w-4 h-4"></i>
                  </button>
                </div>
                
                <div id="dashLunchResultArea" class="bg-surface-50 dark:bg-surface-800/50 rounded-3xl p-6 border border-dashed border-surface-200 dark:border-surface-700 text-center relative min-h-[120px] flex flex-col justify-center transition-all">
                  <div id="dashLunchQuickPreview" class="flex items-center justify-center gap-2 mb-2">
                    <span class="w-2 h-2 rounded-full bg-surface-300"></span>
                    <span class="text-[10px] font-black text-surface-400 uppercase">Ready to Roll</span>
                  </div>
                  <div id="dashLunchPlaceName" class="text-2xl font-black text-surface-900 dark:text-white">...</div>
                  <div id="dashLunchPlaceType" class="text-xs text-surface-400 font-bold mt-1">กดปุ่มเพื่อเริ่มสุ่มร้านเด็ด</div>
                  <div id="dashLunchPlaceLocation" class="text-[10px] text-brand-600 mt-2 font-black flex items-center justify-center gap-1"></div>
                  
                  <!-- Rolling Overlay -->
                  <div id="dashLunchRollingOverlay" class="absolute inset-0 bg-white/80 dark:bg-surface-900/80 backdrop-blur-sm hidden flex flex-col items-center justify-center animate-in fade-in">
                    <div class="w-12 h-12 border-4 border-rose-500/20 border-t-rose-500 rounded-full animate-spin"></div>
                    <span class="text-[10px] font-black text-rose-500 uppercase tracking-widest mt-3">Rolling...</span>
                  </div>
                </div>
                
                <button onclick="rollLunch()" class="w-full mt-6 py-4 bg-gradient-to-r from-rose-600 to-pink-600 text-white rounded-2xl text-sm font-black shadow-lg shadow-rose-600/20 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2">
                  <i data-lucide="sparkles" class="w-4 h-4"></i> สุ่มเลย!
                </button>
              </div>

              <!-- Productivity Tip Card -->
              <div class="glass p-8 rounded-[2.5rem] border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-xl overflow-hidden group">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-12 h-12 bg-amber-50 dark:bg-amber-900/30 text-amber-600 rounded-2xl flex items-center justify-center">
                    <i data-lucide="lightbulb" class="w-6 h-6"></i>
                  </div>
                  <div>
                    <h3 class="text-lg font-black text-surface-900 dark:text-white">Daily Productivity</h3>
                    <p class="text-[10px] text-surface-400 font-bold uppercase tracking-widest">เคล็ดลับความโปรวันนี้</p>
                  </div>
                </div>
                <div class="space-y-4">
                  <div class="p-4 bg-amber-50/50 dark:bg-amber-900/10 rounded-2xl border border-amber-100/50 dark:border-amber-800/30">
                    <p class="text-sm font-bold text-surface-700 dark:text-surface-200 leading-relaxed">
                      "ลองใช้เทคนิค Pomodoro: ทำงาน 25 นาที พัก 5 นาที เพื่อรักษาโฟกัสให้คมชัดตลอดทั้งวัน!"
                    </p>
                  </div>
                  <div class="flex items-center justify-between text-[10px] font-black uppercase tracking-widest text-surface-400">
                    <span>Focus Score: 85%</span>
                    <span class="text-emerald-500">Keep it up!</span>
                  </div>
                  <div class="w-full bg-surface-100 dark:bg-surface-800 h-1.5 rounded-full overflow-hidden">
                    <div class="bg-amber-500 h-full w-[85%] rounded-full"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Row for Stats & Schedule -->

            <!-- 📊 Quick Stats Grid -->
