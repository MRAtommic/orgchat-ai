                  <div class="flex items-center justify-between mb-6">
                    <h3 class="text-sm font-black tracking-tight flex items-center gap-2 text-surface-900 dark:text-white uppercase">
                      <i data-lucide="folder-clock" class="w-4 h-4 text-blue-600"></i> คลังความรู้ล่าสุด
                    </h3>
                    <button onclick="showView('kb')" class="text-[9px] font-black uppercase tracking-widest text-brand-600 hover:underline">ดูทั้งหมด</button>
                  </div>
