                      <div class="w-12 h-12 bg-surface-100 dark:bg-surface-800 rounded-xl"></div>
                      <div class="flex-1 space-y-2">
                        <div class="h-3 bg-surface-100 dark:bg-surface-800 rounded w-1/3"></div>
                        <div class="h-4 bg-surface-200 dark:bg-surface-700 rounded w-2/3"></div>
                      </div>
                   </div>
                </div>

                <!-- ✅ Pending Tasks (MOVED HERE) -->
                <div class="space-y-6 pt-8 border-t border-surface-100 dark:border-surface-800">
