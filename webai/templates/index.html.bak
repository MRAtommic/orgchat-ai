             </div>
             <div class="glass p-5 rounded-3xl border border-surface-100 dark:border-surface-800 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 bg-orange-50 dark:bg-orange-900/30 rounded-xl flex items-center justify-center mb-3">
                   <i data-lucide="sun" class="w-5 h-5 text-orange-600"></i>
