              </div>

              <!-- Total Financial Amount -->
              <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-sm hover:shadow-md transition-all group">
                <div class="flex items-start justify-between mb-4">
                  <div class="p-2 bg-rose-100 dark:bg-rose-900/30 text-rose-600 rounded-xl group-hover:scale-110 transition-transform">
                    <i data-lucide="banknote" class="w-5 h-5"></i>
                  </div>
                  <span class="text-[10px] font-black uppercase text-rose-500 tracking-widest">Financial Total</span>
