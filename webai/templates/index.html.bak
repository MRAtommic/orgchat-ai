             <i data-lucide="x" class="w-6 h-6"></i>
          </button>
       </header>
       
       <div class="px-8 pt-8 bg-surface-50 dark:bg-surface-950/40 overflow-y-auto max-h-[75vh] custom-scrollbar">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
             <div class="glass p-5 rounded-3xl border border-surface-100 dark:border-surface-800 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 bg-brand-50 dark:bg-brand-900/30 rounded-xl flex items-center justify-center mb-3">
                   <i data-lucide="thermometer" class="w-5 h-5 text-brand-600"></i>
                </div>
                <span class="text-[10px] font-black text-surface-400 uppercase tracking-widest mb-1">Feels Like</span>
