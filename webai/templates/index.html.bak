                <div class="text-2xl font-black text-surface-900 dark:text-white truncate" id="dashStatTotalAmount">฿0.00</div>
                <div class="text-[11px] font-bold tracking-wide text-surface-400 mt-1">ยอดรวมจากเอกสารการเงิน</div>
              </div>

              <!-- Category Distribution Summary -->
              <div class="glass p-6 rounded-3xl border border-surface-100 dark:border-surface-800 bg-white dark:bg-surface-900 shadow-sm hover:shadow-md transition-all group lg:col-span-1">
