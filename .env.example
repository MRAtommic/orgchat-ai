# ============================================================
#  OrgChat — ไฟล์ตัวอย่าง Environment Variables
#  คัดลอกไฟล์นี้เป็น  .env  แล้วใส่ค่าจริงทุกช่อง
#  cp .env.example .env
# ============================================================
# สัญลักษณ์:
#   [REQUIRED] = จำเป็นต้องใส่ ระบบไม่ทำงานถ้าไม่มี
#   [OPTIONAL] = ใส่หรือไม่ก็ได้ มี default อยู่แล้ว
#   [FEATURE]  = ต้องใส่ถ้าจะใช้ฟีเจอร์นั้น ไม่ใส่ = ปิดฟีเจอร์
# ============================================================


# ────────────────────────────────────────────────────────────
# 1. FLASK & SERVER
# ────────────────────────────────────────────────────────────

# [REQUIRED] Secret key สำหรับ sign session cookie
# สร้างได้ด้วย:  python -c "import secrets; print(secrets.token_hex(32))"
# ห้ามใช้ค่า default ใน production!
FLASK_SECRET_KEY=your-super-secret-key-here

# [OPTIONAL] Port ที่ให้ server ฟัง (Railway/Render จะ inject ให้อัตโนมัติ)
PORT=8080

# [REQUIRED] URL สาธารณะของแอป (ใช้สร้าง webhook URL, reset password link ฯลฯ)
# ใส่ domain จริง เช่น https://openchat.sbs หรือ https://xxx.railway.app
BASE_URL=https://openchat.sbs

# [OPTIONAL] alias ของ BASE_URL (ถ้า Railway inject เป็น PUBLIC_URL)
# PUBLIC_URL=https://xxx.up.railway.app

# [OPTIONAL] URL ที่ใช้ register LINE Webhook อัตโนมัติ (ถ้าต่างจาก BASE_URL)
# ACTIVE_PUBLIC_URL=https://openchat.sbs


# ────────────────────────────────────────────────────────────
# 2. SUPER ADMIN
# ────────────────────────────────────────────────────────────

# [OPTIONAL] username ที่เข้า /admin/super ได้ (คั่นด้วย comma ถ้าหลายคน)
# default = Admin  (username ที่สร้างตอนแรก)
SUPERADMIN_USERS=Admin


# ────────────────────────────────────────────────────────────
# 3. AI PROVIDER — เลือก 1 อย่าง (groq หรือ gemini)
# ────────────────────────────────────────────────────────────

# [REQUIRED] เลือก provider หลัก: groq | gemini
AI_PROVIDER=groq

# --- GROQ (แนะนำ — ฟรี, เร็ว) ---
# [REQUIRED ถ้า AI_PROVIDER=groq]
# สมัครที่ https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Backup key เผื่อ rate limit
# GROQ_API_KEY_BACKUP=gsk_yyyyyyyyyyyyyyyyyyyyyyyyyyyy

# --- GOOGLE GEMINI ---
# [REQUIRED ถ้า AI_PROVIDER=gemini]
# สมัครที่ https://aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Backup key เผื่อ rate limit
# GEMINI_API_KEY_BACKUP=AIzaSyyyyyyyyyyyyyyyyyyyyyyyyy


# ────────────────────────────────────────────────────────────
# 4. AI EMBEDDING (Knowledge Base / RAG)
# ────────────────────────────────────────────────────────────

# [OPTIONAL] provider สำหรับ vector embedding: gemini | ollama
# default = gemini (ใช้ GEMINI_API_KEY ด้านบน)
AI_EMBEDDING_PROVIDER=gemini

# [OPTIONAL] ถ้าใช้ Ollama (self-hosted) ระบุ model ที่ต้องการ
# OLLAMA_EMBED_MODEL=nomic-embed-text

# [OPTIONAL] ตั้งเป็น 1 เพื่อข้ามการ sync KB ตอน startup (เร็วขึ้น ใช้ตอน dev)
# SKIP_SYNC=0


# ────────────────────────────────────────────────────────────
# 5. LINE MESSAGING API
# ────────────────────────────────────────────────────────────
# ใช้สำหรับ: รับ-ส่งข้อความผ่าน LINE, LINE Login, เชื่อม group LINE
#
# วิธีสมัคร:
#   1. ไป https://developers.line.biz/console/
#   2. สร้าง Provider → สร้าง Messaging API Channel
#   3. Basic settings → Channel Secret  →  LINE_CHANNEL_SECRET
#   4. Messaging API → Channel access token (long-lived) → LINE_CHANNEL_ACCESS_TOKEN
#   5. Webhook URL ตั้งเป็น:  https://<BASE_URL>/webhook/line

# [FEATURE] ถ้าจะใช้ LINE Bot / LINE Login
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=


# ────────────────────────────────────────────────────────────
# 6. GOOGLE OAUTH2 (Sign in with Google)
# ────────────────────────────────────────────────────────────
# วิธีสมัคร:
#   1. ไป https://console.cloud.google.com/
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs เพิ่ม:
#        https://<BASE_URL>/auth/google/callback
#   5. คัดลอก Client ID และ Client Secret

# [FEATURE] ถ้าจะให้ login ด้วย Google
GOOGLE_OAUTH2_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] ถ้า redirect URI ต่างจาก BASE_URL/auth/google/callback
# OAUTH2_REDIRECT_URI=https://openchat.sbs/auth/google/callback

# [OPTIONAL] Google Client ID สำหรับ One-Tap Sign-In (JavaScript SDK)
# ใช้ค่าเดียวกับ GOOGLE_OAUTH2_CLIENT_ID ได้เลย
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com


# ────────────────────────────────────────────────────────────
# 7. GOOGLE SERVICE ACCOUNT (Drive / Sheets integration)
# ────────────────────────────────────────────────────────────
# ใช้สำหรับ: บันทึกใบเสนอราคาลง Google Sheets, แชร์ไฟล์ Google Drive
#
# วิธีสมัคร:
#   1. ไป https://console.cloud.google.com/
#   2. IAM & Admin → Service Accounts → Create Service Account
#   3. Keys → Add Key → JSON → Download
#   4. เปิดไฟล์ JSON → copy เนื้อหาทั้งหมด
#   5. ใส่ใน GOOGLE_SERVICE_ACCOUNT_JSON เป็น JSON string บรรทัดเดียว
#      (ใช้ jq -c . service-account.json เพื่อ minify)
#   6. Share Google Sheet/Folder กับ email ของ Service Account (Editor)

# [FEATURE] ถ้าจะใช้ Google Drive/Sheets
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}


# ────────────────────────────────────────────────────────────
# 8. STRIPE (ระบบชำระเงิน)
# ────────────────────────────────────────────────────────────
# วิธีสมัคร:
#   1. ไป https://dashboard.stripe.com/
#   2. Developers → API keys → Secret key (เริ่มด้วย sk_live_ หรือ sk_test_)
#   3. สร้าง Products และ Prices สำหรับแต่ละ plan:
#      - Pro  ฿299/month  → ได้ Price ID เริ่มด้วย price_xxx (Card)
#      - Pro  ฿299/month  → PromptPay version (Webhook จะ confirm อัตโนมัติ)
#      - Ultra ฿599/month → Card และ PromptPay
#   4. Developers → Webhooks → Add endpoint:
#      URL: https://<BASE_URL>/webhook/stripe
#      Events: checkout.session.completed, invoice.payment_succeeded
#      → คัดลอก Signing secret  →  STRIPE_WEBHOOK_SECRET

# [FEATURE] ถ้าจะรับชำระเงิน
STRIPE_SECRET_KEY=your_stripe_secret_key_here


# Price IDs จาก Stripe Dashboard (Products → Prices)
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_PROMPTPAY=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS_PROMPTPAY=price_xxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Price สำหรับทดสอบ 1 บาท
# STRIPE_PRICE_TEST_1THB=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret (จาก Stripe → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ────────────────────────────────────────────────────────────
# 9. WEB PUSH NOTIFICATIONS (VAPID Keys)
# ────────────────────────────────────────────────────────────
# ใช้สำหรับ browser push notification
#
# วิธีสร้าง VAPID keys (ทำครั้งเดียว):
#   pip install py-vapid
#   vapid --gen
#   → ได้ไฟล์ private_key.pem และ public_key.pem
#   หรือใช้ online generator: https://web-push-codelab.glitch.me/
#
# หรือสร้างผ่าน Python:
#   from py_vapid import Vapid
#   v = Vapid()
#   v.generate_keys()
#   print("PUBLIC:", v.public_key)
#   print("PRIVATE:", v.private_key)

# [OPTIONAL] ถ้าไม่ใส่จะใช้ค่า default (ควร generate ของตัวเองใน production)
VAPID_PUBLIC_KEY=BNW7f7p3Ush_rg9vjIXxz1KTthTsiy3rz17oaygTy1-l4bTQJKpLeYEj4v3jYQkggo1VLa7w7sNb6mWDaIVH5eU
VAPID_PRIVATE_KEY=iVj1ybjnV5yP34d1BZ9ydP6Ad_m_24FC6AhYkc2On04
# [OPTIONAL] email ของ admin ที่ใช้ใน VAPID claims (แค่ format email ก็พอ)
VAPID_CONTACT_EMAIL=admin@openchat.sbs


# ────────────────────────────────────────────────────────────
# 10. DATABASE
# ────────────────────────────────────────────────────────────

# [OPTIONAL] path ของไฟล์ SQLite (default = chat_history.db ในโฟลเดอร์เดียวกัน)
# DB_PATH=chat_history.db

# ห้ามตั้ง DB_TYPE=postgres — ระบบนี้ใช้ SQLite เท่านั้น


# ────────────────────────────────────────────────────────────
# ไม่ต้องตั้ง (ลบออกแล้ว)
# ────────────────────────────────────────────────────────────
# REDIS_URL, REDIS_HOST, REDIS_PORT  → ใช้ in-memory แทน
# DB_TYPE=postgres, POSTGRES_*       → ลบ postgres branch ออกแล้ว
# SENTRY_DSN                         → ไม่ได้ใช้
