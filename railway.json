{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["./**/*.py", "./**/*.html", "./**/*.css", "./**/*.js"]
  },
  "deploy": {
    "startCommand": "gunicorn app:app --worker-class gthread --workers 1 --threads 4 --bind 0.0.0.0:$PORT --timeout 300",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
