[Unit]
Description=Gunicorn instance to serve OrgChat
After=network.target

[Service]
User=arka
Group=www-data
WorkingDirectory=/home/arka/webai
Environment="PATH=/home/arka/webai/venv/bin"
ExecStart=/home/arka/webai/venv/bin/gunicorn --workers 3 --bind 0.0.0.0:5000 app:app

[Install]
WantedBy=multi-user.target
